---
import ImagePlaceholder from '../components/common/ImagePlaceholder.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import { message } from '../data/siteContent';

interface Props {
  id?: string;
}
const { id } = Astro.props;
---

<section class="p-message" id={id}>
  <div class="p-message__inner">
    <div class="p-message__lead">
      <SectionHeading ja="メッセージ" en="MESSAGE" theme="light" class="p-message__heading" />
      <h2 class="p-message__headline">
        {message.headline.map((line) => <span>{line}</span>)}
      </h2>
    </div>
    <div class="p-message__body">
      {message.body.map((p) => <p class="p-message__text">{p}</p>)}
      <div class="p-message__sign">
        <div class="p-message__signName">
          <span class="p-message__signRole">{message.signRole}</span>
          <span class="p-message__signPerson">{message.signName}</span>
        </div>
        <div class="p-message__portrait">
          <ImagePlaceholder label="代表写真" rounded="10px" />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundation/index' as *;

  .p-message {
    background: linear-gradient(160deg, $brand-blue 0%, #1f6fc4 55%, $brand-blue-pale 100%);
    padding-block: size(140);

    @include mq('sp') {
      padding-block: size(80);
    }

    &__inner {
      display: grid;
      grid-template-columns: size(314) 1fr;
      gap: size(160);
      max-width: size(1098);
      margin-inline: auto;
      padding-inline: size(24);

      @include mq('sp') {
        grid-template-columns: 1fr;
        gap: size(40);
      }
    }

    &__headline {
      display: flex;
      flex-direction: column;
      gap: size(8);
      margin-top: size(48);
      font-family: $Font;
      font-weight: 700;
      font-size: size(40);
      line-height: 1.5;
      color: $brand-white;

      @include mq('sp') {
        font-size: size(30);
        margin-top: size(24);
      }
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: size(24);
    }

    &__text {
      @include ty-body;
      color: $brand-white;
      text-align: justify;
    }

    &__sign {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      gap: size(22);
      margin-top: size(24);
    }

    &__signName {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: size(3);
      color: $brand-white;
    }

    &__signRole {
      font-family: $Font;
      font-size: size(18);
    }

    &__signPerson {
      font-family: $Font;
      font-weight: 500;
      font-size: size(35);
      line-height: 1.4;

      @include mq('sp') {
        font-size: size(28);
      }
    }

    &__portrait {
      flex-shrink: 0;
      width: size(132);
      height: size(164);
    }
  }
</style>
