---
interface Props {
	/** 画像のソースURL */
	src: string;
	/** 画像の代替テキスト */
	alt: string;
	/** レスポンシブ画像の幅配列 */
	widths: readonly number[];
	/** メディアクエリのサイズ指定 */
	sizes: string;
	/** 追加のCSSクラス */
	className?: string;
	/** 画像の読み込み方式 */
	loading?: 'lazy' | 'eager';
	/** 画像のデコード方式 */
	decoding?: 'async' | 'sync' | 'auto';
}

const {
	src,
	alt,
	widths,
	sizes,
	className = '',
	loading = 'lazy',
	decoding = 'async',
} = Astro.props;

// 画像の基本URLを取得（拡張子を除く）
const baseUrl = src.replace(/\.[^/.]+$/, '');

// パフォーマンス向上のためプリロード時は最大幅の画像を使用
const largestWidth = Math.max(...widths);
---

<picture class={className}>
	<source
		type="image/webp"
		srcset={widths.map((w) => `${baseUrl}-${w}.webp ${w}w`).join(', ')}
		sizes={sizes}
	/>
	<source
		type="image/jpeg"
		srcset={widths.map((w) => `${baseUrl}-${w}.jpg ${w}w`).join(', ')}
		sizes={sizes}
	/>
	<img
		src={`${baseUrl}-${widths[0]}.jpg`}
		alt={alt}
		loading={loading}
		decoding={decoding}
		width={largestWidth}
		height="auto"
	/>
</picture>
