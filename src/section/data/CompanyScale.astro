---
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import StatValue from '../../components/common/StatValue.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';
import building from '../../images/keitasplan/data/building.svg';
import mapPc from '../../images/keitasplan/data/map-pc.svg';
import mapSp from '../../images/keitasplan/data/map-sp.svg';
import people from '../../images/keitasplan/data/people.svg';

interface Props {
	id?: string;
	foundedYear: string;
	employeeCount: string;
	officeCount: string;
}
const { id, foundedYear, employeeCount, officeCount } = Astro.props;
---

<section class="p-data-company" id={id}>
	<div class="p-data-company__inner">
		<VerticalLabel text="COMPANY SCALE" />
		<div class="p-data-company__body">
			<DataSectionHead ja="会社規模" />
			<ul class="p-data-company__grid">
				<li class="p-data-company__cell">
					<div class="p-data-company__card">
						<span
							class="p-data-company__illust p-data-company__illust--building"
							aria-hidden="true"
						>
							<img src={building.src} alt="" />
						</span>
						<div class="p-data-company__text">
							<p class="p-data-company__figure">
								<StatValue value={foundedYear} unit="年" />
								<span class="p-data-company__statLabel">
									創業
								</span>
							</p>
							<p class="p-data-company__caption">
								着実に積み上げてきた確かな実績
							</p>
						</div>
					</div>
				</li>

				<li class="p-data-company__cell">
					<div class="p-data-company__card">
						<span
							class="p-data-company__illust p-data-company__illust--people"
							aria-hidden="true"
						>
							<img src={people.src} alt="" />
						</span>
						<div class="p-data-company__text">
							<p class="p-data-company__figure">
								<span class="p-data-company__statLabel">
									従業員数
								</span>
								<StatValue
									prefix="約"
									value={employeeCount}
									unit="人"
								/>
							</p>
							<p class="p-data-company__caption">
								委託業務・パート含む
							</p>
						</div>
					</div>
				</li>

				<li class="p-data-company__cell p-data-company__cell--wide">
					<div class="p-data-company__card p-data-company__card--map">
						<span class="p-data-company__map" aria-hidden="true">
							<img
								class="p-data-company__mapImg p-data-company__mapImg--pc"
								src={mapPc.src}
								alt=""
								width="493"
								height="374"
							/>
							<img
								class="p-data-company__mapImg p-data-company__mapImg--sp"
								src={mapSp.src}
								alt=""
								width="257"
								height="230"
							/>
						</span>
						<div class="p-data-company__mapBody">
							<p
								class="p-data-company__figure p-data-company__figure--map"
							>
								<span
									class="p-data-company__statLabel p-data-company__statLabel--map"
								>
									拠点数
								</span>
								<StatValue value={officeCount} unit="拠点" />
							</p>
							<p
								class="p-data-company__caption p-data-company__caption--map"
							>
								北海道から沖縄まで<br
									class="u-sp-only"
								/>全国対応しております
							</p>
						</div>
					</div>
				</li>
			</ul>
		</div>
	</div>
</section>

<style lang="scss">
	.p-data-company {
		position: relative;

		&__inner {
			display: flex;
			align-items: stretch;
			gap: size(81);
			margin-inline: auto;
			padding-inline: size(128) size(243);

			@include mq('sp') {
				padding-inline: size(45) size(94);
			}
		}

		&__body {
			flex: 1;
			min-width: 0;
		}

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: size(60) size(42);
			margin-top: size(100);

			@include mq('sp') {
				grid-template-columns: minmax(0, 1fr);
				gap: size(70);
			}
		}

		&__cell {
			min-width: 0;

			&--wide {
				grid-column: 1 / -1;
			}
		}

		// --- カード ---
		&__card {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: size(16);
			height: 100%;
			min-height: size(374);
			padding: size(36) size(40);
			background: $brand-white;
			border-radius: size(7);
		}

		&__illust {
			display: block;

			img {
				display: block;
				width: 100%;
				height: 100%;
			}

			&--building {
				width: size(163);
				height: size(155);
			}

			&--people {
				width: size(289);
				height: size(173);
			}
		}

		&__text {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		&__figure {
			display: flex;
			align-items: center;
			gap: size(6);

			// 地図カード: PCは横並び / SPは縦積み（拠点数 の下に 0拠点）
			&--map {
				gap: size(18);

				@include mq('sp') {
					flex-direction: column;
					align-items: flex-start;
					gap: size(4);
				}
			}
		}

		&__statLabel {
			font-family: $Font;
			font-weight: 700;
			font-size: size(35);
			line-height: 1.4;
			letter-spacing: size(1.05);
			color: $brand-text;
			margin-top: size(26);

			@include mq('sp') {
				font-size: size(40);

				&--map {
					margin-top: 0;
				}
			}
		}

		&__caption {
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(24);
			}
		}

		// --- 拠点数（地図・横長。地図と図版のインライン横並び） ---
		&__card--map {
			flex-direction: row;
			gap: size(59);
			padding: 0;

			// SP: 地図＋図版の横並びの下に注釈を全幅で配置
			@include mq('sp') {
				flex-wrap: wrap;
				gap: size(16) size(32);
				padding: size(41) size(40);
			}
		}

		&__map {
			display: block;
			flex-shrink: 0;
			width: size(493);

			@include mq('sp') {
				width: size(257);
			}
		}

		&__mapImg {
			display: block;
			width: 100%;
			height: auto;

			&--pc {
				@include mq('sp') {
					display: none;
				}
			}

			&--sp {
				display: none;

				@include mq('sp') {
					display: block;
				}
			}
		}

		&__mapBody {
			display: flex;
			flex-direction: column;
			align-items: center;

			// SP: 図版と注釈をカード直下に展開（注釈を地図の下へ回す）
			@include mq('sp') {
				display: contents;
			}
		}

		&__caption--map {
			@include mq('sp') {
				order: 3;
				width: 100%;
				font-size: size(25);
				text-align: center;
			}
		}
	}
</style>
