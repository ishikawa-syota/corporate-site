---
// 矢印付きピルボタン（Figma: button1 / button1_s / button2 / button_saiyou）
// variant でサイズ・配色を切り替え、どこでも流用できる汎用ボタン
interface Props {
  href?: string;
  label: string;
  variant?: 'white' | 'blue';
  size?: 'md' | 'sm' | 'lg';
  class?: string;
}

const {
  href = '#',
  label,
  variant = 'white',
  size = 'md',
  class: className,
} = Astro.props;
---

<a
  href={href}
  class:list={['c-arrowBtn', `c-arrowBtn--${variant}`, `c-arrowBtn--${size}`, className]}
>
  <span class="c-arrowBtn__label">{label}</span>
  <span class="c-arrowBtn__icon" aria-hidden="true">
    <svg viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="14.5" cy="14.5" r="14.5"></circle>
      <path d="M12.5 9.5 17.5 14.5 12.5 19.5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
    </svg>
  </span>
</a>

<style lang="scss">
  @use '../../styles/foundation/index' as *;

  .c-arrowBtn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: size(15);
    width: size(220);
    height: size(60);
    padding: 0 size(24);
    border-radius: 999px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;

    &__label {
      @include ty-button;
    }

    &__icon {
      position: absolute;
      right: size(15);
      display: inline-flex;
      width: size(29);
      height: size(29);

      svg {
        width: 100%;
        height: 100%;
      }
    }

    // --- 配色バリアント ---
    &--white {
      background-color: $brand-white;
      box-shadow: 0 size(4) size(20) rgba($brand-blue, 0.12);

      .c-arrowBtn__label {
        color: $brand-text;
      }
      .c-arrowBtn__icon circle {
        fill: $brand-blue;
      }
      .c-arrowBtn__icon path {
        stroke: $brand-white;
      }

      @media (hover: hover) and (pointer: fine) {
        &:hover {
          transform: translateY(#{size(-2)});
          box-shadow: 0 size(8) size(24) rgba($brand-blue, 0.22);
        }
      }
    }

    &--blue {
      background-color: $brand-blue;

      .c-arrowBtn__label {
        color: $brand-white;
      }
      .c-arrowBtn__icon circle {
        fill: $brand-white;
      }
      .c-arrowBtn__icon path {
        stroke: $brand-blue;
      }

      @media (hover: hover) and (pointer: fine) {
        &:hover {
          transform: translateY(#{size(-2)});
          background-color: $brand-blue-light;
        }
      }
    }

    // --- サイズバリアント ---
    &--sm {
      width: size(197);
      height: size(50);

      .c-arrowBtn__icon {
        right: size(12);
      }
    }

    &--lg {
      width: size(301);
      height: size(60);
    }
  }
</style>
