---
import DataStat from '../../components/card/DataStat.astro';
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';

interface Card {
	label: string;
	prefix?: string;
	value: string;
	unit: string;
	caption?: string;
	illust?: 'top' | 'left' | 'right';
	inline?: boolean;
	labelAfter?: boolean;
	figureFirst?: boolean;
	overlay?: boolean;
	illustW?: number;
	illustH?: number;
	illustLabel?: string;
	wide?: boolean;
}
interface Props {
	id?: string;
	en: string;
	ja: string;
	sub?: string;
	note?: string;
	cards: Card[];
}
const { id, en, ja, sub, note, cards } = Astro.props;
---

<section class="p-data-sec" id={id}>
	<div class="p-data-sec__inner">
		<VerticalLabel text={en} />
		<div class="p-data-sec__body">
			<DataSectionHead ja={ja} sub={sub} />
			<ul class="p-data-sec__grid">
				{
					cards.map((c) => (
						<li
							class:list={[
								'p-data-sec__cell',
								c.wide && 'p-data-sec__cell--wide',
							]}
						>
							<DataStat {...c} />
						</li>
					))
				}
			</ul>
			{note && <p class="p-data-sec__note">{note}</p>}
		</div>
	</div>
</section>

<style lang="scss">
	.p-data-sec {
		position: relative;

		&__inner {
			display: flex;
			align-items: stretch;
			gap: size(81);
			margin-inline: auto;
			padding-inline: size(128) size(243);

			@include mq('sp') {
				gap: size(80);
				padding-inline: size(45) size(94);
			}
		}

		&__body {
			flex: 1;
			min-width: 0;
		}

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: size(60) size(42);
			margin-top: size(100);

			@include mq('sp') {
				grid-template-columns: minmax(0, 1fr);
				gap: size(70);
			}
		}

		&__cell {
			min-width: 0;

			&--wide {
				grid-column: 1 / -1;
			}
		}

		&__note {
			margin-top: size(40);
			font-family: $Font;
			font-weight: 400;
			font-size: size(14);
			line-height: 1.6;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(20);
			}
		}
	}
</style>
