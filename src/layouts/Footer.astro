---
import OptImage from '../components/common/OptImage.astro';
import { companyInfo } from '../data/siteContent';
import logoWhite from '../images/keitasplan/common/footer-01.png';

interface Props {
	id?: string;
}
const { id } = Astro.props;

// フッターナビ（Figmaの4カラム構成）
const footerNav = [
	[
		{ ja: '事業紹介', href: '#business' },
		{ ja: '数字で見る', href: '#data' },
		{ ja: 'メンバー', href: '#member' },
	],
	[
		{ ja: 'お客様の声', href: '#voice' },
		{ ja: 'ニュース', href: '#news' },
		{ ja: '代表メッセージ', href: '#message' },
	],
	[
		{ ja: '会社概要', href: '#about' },
		{ ja: 'よくある質問', href: '#faq' },
		{ ja: 'お問い合わせ', href: '#contact' },
	],
	[
		{ ja: '特定商取引法表記', href: '#' },
		{ ja: 'プライバシーポリシー', href: '#' },
	],
];
---

<footer class="l-footer" id={id}>
	<div class="l-footer__inner">
		<div class="l-footer__info">
			<span class="l-footer__logo">
				<OptImage src={logoWhite} alt={companyInfo.name} width={301} fit="contain" />
			</span>
			<p class="l-footer__address">
				{companyInfo.name}<br />
				{companyInfo.address}<br />
				TEL: {companyInfo.tel}
			</p>
			<p class="l-footer__license">{companyInfo.license}</p>
		</div>

		<div class="l-footer__right">
			<nav class="l-footer__nav" aria-label="フッターナビゲーション">
				{
					footerNav.map((col) => (
						<ul class="l-footer__navCol">
							{col.map((item) => (
								<li>
									<a
										href={item.href}
										class="l-footer__navLink"
									>
										{item.ja}
									</a>
								</li>
							))}
						</ul>
					))
				}
			</nav>

			<a href="#contact" class="l-footer__saiyou">
				<span class="l-footer__saiyouText">採用サイトはこちら</span>
				<span class="l-footer__saiyouIcon" aria-hidden="true">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="17"
						height="15"
						viewBox="0 0 17 15"
						fill="none"
					>
						<path
							d="M16.7071 8.07088C17.0976 7.68035 17.0976 7.04719 16.7071 6.65666L10.3431 0.292702C9.95262 -0.0978227 9.31946 -0.0978227 8.92893 0.292702C8.53841 0.683226 8.53841 1.31639 8.92893 1.70692L14.5858 7.36377L8.92893 13.0206C8.53841 13.4111 8.53841 14.0443 8.92893 14.4348C9.31946 14.8254 9.95262 14.8254 10.3431 14.4348L16.7071 8.07088ZM0 7.36377V8.36377H16V7.36377V6.36377H0V7.36377Z"
							fill="white"></path>
					</svg>
				</span>
			</a>
		</div>
	</div>
</footer>

<style lang="scss" is:global>
	@use '../styles/foundation/index' as *;

	.l-footer {
		background-color: $brand-blue;
		padding: size(202) size(40) size(96);
		color: $brand-white;

		@include mq('sp') {
			padding: size(96) size(48) size(80);
		}

		&__inner {
			display: flex;
			align-items: flex-start;
			gap: size(0);
			max-width: size(1058);
			margin-inline: auto;

			@include mq('sp') {
				flex-direction: column;
				gap: size(56);
			}
		}

		&__info {
			flex-shrink: 0;
			width: size(400);

			@include mq('sp') {
				width: 100%;
			}
		}

		&__logo {
			display: block;
			width: size(301);
			aspect-ratio: 2056 / 301;
			margin-bottom: size(57);

			@include mq('sp') {
				width: size(360);
				margin-bottom: size(48);
			}
		}

		&__address {
			font-family: $Font;
			font-size: size(14);
			line-height: 1.8;

			@include mq('sp') {
				font-size: size(26);
			}
		}

		&__license {
			font-family: $Font;
			font-size: size(12);
			line-height: 1.8;
			margin-top: size(24);

			@include mq('sp') {
				font-size: size(22);
				margin-top: size(32);
			}
		}

		&__right {
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: flex-end;

			@include mq('sp') {
				width: 100%;
				align-items: stretch;
			}
		}

		&__nav {
			display: flex;
			gap: size(82);
			width: 100%;
			justify-content: flex-start;

			@include mq('sp') {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: size(40) size(24);
			}
		}

		&__navCol {
			display: flex;
			flex-direction: column;
			gap: size(24);
			list-style: none;
		}

		&__navLink {
			font-family: $Font;
			font-size: size(14);
			line-height: 1.4;
			color: $brand-white;
			transition: opacity 0.3s ease;

			@include mq('sp') {
				font-size: size(26);
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					opacity: 0.7;
				}
			}
		}

		// 採用サイトはこちらボタン（Figma: button_saiyou）
		&__saiyou {
			position: relative;
			display: inline-flex;
			align-items: center;
			justify-content: space-between;
			gap: size(28);
			width: size(301);
			height: size(51);
			margin-top: size(60);
			padding: size(10) size(11) size(10) size(52);
			border-radius: size(140);
			background: linear-gradient(180deg, #ffffff 0%, #e9e9e9 100%);
			transition:
				transform 0.3s ease,
				box-shadow 0.3s ease;

			@include mq('sp') {
				width: size(440);
				height: size(88);
				margin-top: size(56);
				margin-inline: auto;
				padding: size(16) size(18) size(16) size(80);
				gap: size(28);
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					box-shadow: 0 size(8) size(20) rgba(#000, 0.15);
				}
			}
		}

		&__saiyouText {
			font-family: $Font;
			font-weight: 500;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-blue;
			white-space: nowrap;

			@include mq('sp') {
				font-size: size(32);
			}
		}

		&__saiyouIcon {
			flex-shrink: 0;
			display: grid;
			place-items: center;
			width: size(30);
			height: size(30);
			background-color: $brand-blue;
			border-radius: 50%;

			@include mq('sp') {
				width: size(56);
				height: size(56);
			}

			svg {
				width: size(15);
				height: size(13);

				@include mq('sp') {
					width: size(28);
					height: size(24);
				}
			}
		}
	}
</style>
