---
import ArrowButton from '../components/button/ArrowButton.astro';
import NumberStat from '../components/card/NumberStat.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import { stats } from '../data/siteContent';

interface Props {
  id?: string;
}
const { id } = Astro.props;
---

<section class="p-data" id={id}>
  <div class="p-data__inner">
    <SectionHeading
      ja="数字で見る"
      en="DATA"
      lead="ケイタスプランにまつわる様々な数字をご紹介します"
      align="center"
      class="p-data__heading"
    />
    <div class="p-data__grid">
      {stats.map((stat) => (
        <NumberStat
          label={stat.label}
          prefix={stat.prefix}
          value={stat.value}
          unit={stat.unit}
          note={stat.note}
        />
      ))}
    </div>
    <ArrowButton href="#about" label="詳しく見る" variant="white" class="p-data__btn" />
  </div>
</section>

<style lang="scss">
  @use '../styles/foundation/index' as *;

  .p-data {
    background: linear-gradient(180deg, $brand-white 0%, $brand-blue-sky 100%);
    padding-block: size(100);

    @include mq('sp') {
      padding-block: size(80);
    }

    &__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      max-width: size(1098);
      margin-inline: auto;
      padding-inline: size(24);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: size(50);
      width: 100%;
      max-width: size(910);
      margin-top: size(72);

      @include mq('sp') {
        grid-template-columns: 1fr;
        gap: size(24);
        margin-top: size(40);
      }
    }

    &__btn {
      margin-top: size(64);

      @include mq('sp') {
        margin-top: size(40);
      }
    }
  }
</style>
