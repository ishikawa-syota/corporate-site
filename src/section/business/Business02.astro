---
// 出張買取（BUSINESS 02）セクション
import BlockHeading from '../../components/common/BlockHeading.astro';
import Picture from '../../components/common/Picture.astro';
import badgeShape from '../../images/keitasplan/business/badge-jisseki.svg?raw';
import bgPc from '../../images/keitasplan/business/business-02-bg-pc.png';
import bgSp from '../../images/keitasplan/business/business-02-bg-sp.png';
import introPc from '../../images/keitasplan/business/business-02-intro-pc.png';
import introSp from '../../images/keitasplan/business/business-02-intro-sp.png';
import item1Pc from '../../images/keitasplan/business/business-02-item-1-pc.png';
import item1Sp from '../../images/keitasplan/business/business-02-item-1-sp.png';
import item2Pc from '../../images/keitasplan/business/business-02-item-2-pc.png';
import item2Sp from '../../images/keitasplan/business/business-02-item-2-sp.png';
import item3Pc from '../../images/keitasplan/business/business-02-item-3-pc.png';
import item3Sp from '../../images/keitasplan/business/business-02-item-3-sp.png';
import item4Pc from '../../images/keitasplan/business/business-02-item-4-pc.png';
import item4Sp from '../../images/keitasplan/business/business-02-item-4-sp.png';
import item5Pc from '../../images/keitasplan/business/business-02-item-5-pc.png';
import item5Sp from '../../images/keitasplan/business/business-02-item-5-sp.png';
import item6Pc from '../../images/keitasplan/business/business-02-item-6-pc.png';
import item6Sp from '../../images/keitasplan/business/business-02-item-6-sp.png';
import item7Pc from '../../images/keitasplan/business/business-02-item-7-pc.png';
import item7Sp from '../../images/keitasplan/business/business-02-item-7-sp.png';
import item8Pc from '../../images/keitasplan/business/business-02-item-8-pc.png';
import item8Sp from '../../images/keitasplan/business/business-02-item-8-sp.png';
import statIcon01 from '../../images/keitasplan/business/business-02-stat-01.svg';
import statIcon02 from '../../images/keitasplan/business/business-02-stat-02.svg';
import statIcon03 from '../../images/keitasplan/business/business-02-stat-03.svg';
import featureIcon01 from '../../images/keitasplan/business/feature-icon-01.svg';
import featureIcon02 from '../../images/keitasplan/business/feature-icon-02.svg';
import featureIcon03 from '../../images/keitasplan/business/feature-icon-03.svg';
import featureIcon04 from '../../images/keitasplan/business/feature-icon-04.svg';
import mark from '../../images/keitasplan/common/mark.svg?raw';

import AreaContact from './AreaContact.astro';

interface Props {
	id?: string;
}
const { id } = Astro.props;

const stats = [
	{ icon: statIcon01, label: '年間買取件数', num: '00', unit: '件' },
	{ icon: statIcon02, label: 'お客様満足度', num: '00', unit: '%' },
	{ icon: statIcon03, label: '平均訪問時間', num: '00', unit: '分' },
];

const features = [
	{
		no: 'FEATURE 01',
		icon: featureIcon01,
		title: '1点から買取',
		desc: '1点のお品物でも出張いたします。',
	},
	{
		no: 'FEATURE 02',
		icon: featureIcon02,
		title: '最短即日',
		desc: 'お電話当日の訪問も対応可能です。',
	},
	{
		no: 'FEATURE 03',
		icon: featureIcon03,
		title: '現金手渡し',
		desc: 'その場で現金にてお支払い。',
	},
	{
		no: 'FEATURE 04',
		icon: featureIcon04,
		title: '女性査定士対応',
		desc: 'ご希望に応じて調整いたします。',
	},
];

const items = [
	{ label: 'ブランド品', pc: item1Pc, sp: item1Sp },
	{ label: '貴金属・宝石', pc: item2Pc, sp: item2Sp },
	{ label: '時計', pc: item3Pc, sp: item3Sp },
	{ label: '骨董品・美術品', pc: item4Pc, sp: item4Sp },
	{ label: '着物', pc: item5Pc, sp: item5Sp },
	{ label: 'カメラ', pc: item6Pc, sp: item6Sp },
	{ label: '楽器', pc: item7Pc, sp: item7Sp },
	{ label: '切手・古銭', pc: item8Pc, sp: item8Sp },
];

const flow = [
	{
		no: '1',
		label: 'ご予約',
		desc: 'お電話またはフォームで訪問日時をご予約ください。',
	},
	{
		no: '2',
		label: 'ご訪問',
		desc: '査定員がお客様のご自宅まで伺います。',
	},
	{
		no: '3',
		label: '査定',
		desc: 'その場で査定を行い、査定金額をお伝えします。',
	},
	{
		no: '4',
		label: 'お支払い',
		desc: 'ご納得いただければ、その場で現金お支払い。',
	},
];
---

<section class="p-biz02" id={id}>
	<div class="p-biz02__bg" aria-hidden="true">
		<Picture src={bgPc} srcSp={bgSp} alt="" class="p-biz02__bgImg" />
	</div>

	<div class="p-biz02__inner">
		<div class="p-biz02__head">
			<span class="p-biz02__mark" aria-hidden="true" set:html={mark} />
			<span class="p-biz02__titles">
				<span class="p-biz02__ja">出張買取「エコクリア」</span>
				<span class="p-biz02__en">BUSINESS 02</span>
			</span>
		</div>

		<div class="p-biz02__intro">
			<div class="p-biz02__introText">
				<h3 class="p-biz02__introHeading">
					1点から、最短即日。<br />ご自宅で、なんでも出張買取。
				</h3>
				<p class="p-biz02__introDesc">
					ご自宅まで査定員が伺い、その場で現金でお支払いいたします。<br
					/>
					1点からの買取に対応し、最短即日の訪問も可能。女性査定士のご指定もご相談ください。
				</p>
			</div>
			<div class="p-biz02__introImg">
				<Picture src={introPc} srcSp={introSp} alt="" />
			</div>
		</div>

		<div class="p-biz02__stats">
			<span class="p-biz02__statsBadge">
				<span
					class="p-biz02__statsBadgeShape"
					aria-hidden="true"
					set:html={badgeShape}
				/>
				<span class="p-biz02__statsBadgeText">出張買取実績</span>
			</span>
			<div class="p-biz02__statsInner">
				{
					stats.map((s) => (
						<div class="p-biz02__stat">
							<span class="p-biz02__statIcon" aria-hidden="true">
								<img src={s.icon.src} alt="" />
							</span>
							<div class="p-biz02__statBody">
								<span class="p-biz02__statLabel">
									{s.label}
								</span>
								<span class="p-biz02__statValue">
									<span class="p-biz02__statNum">
										{s.num}
									</span>
									<span class="p-biz02__statUnit">
										{s.unit}
									</span>
								</span>
							</div>
						</div>
					))
				}
			</div>
		</div>

		<div class="p-biz02__features">
			<BlockHeading text="エコクリアの特徴" />
			<ul class="p-biz02__featureList">
				{
					features.map((f) => (
						<li class="p-biz02__feature">
							<span class="p-biz02__featureNo">{f.no}</span>
							<span
								class="p-biz02__featureIcon"
								aria-hidden="true"
							>
								<img src={f.icon.src} alt="" />
							</span>
							<span class="p-biz02__featureTitle">{f.title}</span>
							<span class="p-biz02__featureDesc">{f.desc}</span>
						</li>
					))
				}
			</ul>
		</div>

		<div class="p-biz02__items">
			<BlockHeading text="買取品目" />
			<ul class="p-biz02__itemList">
				{
					items.map((item) => (
						<li class="p-biz02__item">
							<div class="p-biz02__itemImg">
								<Picture
									src={item.pc}
									srcSp={item.sp}
									alt={item.label}
								/>
							</div>
							<span class="p-biz02__itemLabel">{item.label}</span>
						</li>
					))
				}
			</ul>
			<p class="p-biz02__itemsNote">
				上記以外のお品物もまずはご相談ください。
			</p>
		</div>

		<div class="p-biz02__flow">
			<span class="p-biz02__statsBadge p-biz02__flowBadge">
				<span
					class="p-biz02__statsBadgeShape"
					aria-hidden="true"
					set:html={badgeShape}
				/>
				<span class="p-biz02__statsBadgeText">買取のながれ</span>
			</span>
			<div class="p-biz02__flowInner">
				<span class="p-biz02__flowLine" aria-hidden="true"></span>
				{
					flow.map((f) => (
						<div class="p-biz02__flowStep">
							<span class="p-biz02__flowNum">{f.no}</span>
							<span class="p-biz02__flowLabel">{f.label}</span>
							<span class="p-biz02__flowDesc">{f.desc}</span>
						</div>
					))
				}
			</div>
		</div>

		<AreaContact />
	</div>
</section>

<style lang="scss">
	.p-biz02 {
		$num-size-pc: 50;
		$num-size-sp: 60;

		position: relative;
		z-index: 1;
		overflow: hidden;
		margin-top: size(-$section-card-radius);
		border-radius: size($section-card-radius);

		// セクション背景（Figma Rectangle 105 フレーム = 白→#e9e9e9 縦グラデ）
		background: linear-gradient(180deg, $brand-white 0%, #e9e9e9 100%);

		// 全面背景写真（Figma Rectangle 105・不透明度20%を焼き込み済み）
		&__bg {
			position: absolute;
			inset: 0 0 auto;
			z-index: 0;

			:global(picture),
			:global(img) {
				display: block;
				width: 100%;
				height: auto;
			}
		}

		&__inner {
			position: relative;
			z-index: 1;
			max-width: size(1052);
			margin-inline: auto;
			padding-top: size(190);
			padding-bottom: size(164);

			@include mq('sp') {
				max-width: size(580);
				padding-top: size(116);
				padding-bottom: size(143);
			}
		}

		// --- 見出し ---
		&__head {
			display: flex;
			align-items: flex-start;
		}

		&__mark {
			flex-shrink: 0;
			width: size(91);
			height: size(91);
			margin-top: size(10);

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}
		}

		&__titles {
			display: flex;
			flex-direction: column;
			gap: size(3);
		}

		&__ja {
			font-family: $Font;
			font-weight: 500;
			font-size: size(60);
			line-height: 1.4;
			letter-spacing: 0.1em;
			color: $brand-text;
			padding-inline: size(15);

			@include mq('sp') {
				font-size: size(60);
				line-height: 1.2;
			}
		}

		&__en {
			font-family: $Font-Readex;
			font-weight: 500;
			font-size: size(18);
			line-height: 1.4;
			letter-spacing: 0.1em;
			color: $brand-text;
			padding-inline: size(18);

			@include mq('sp') {
				font-size: size(20);
			}
		}

		// --- 導入 ---
		&__intro {
			display: flex;
			gap: size(161);
			margin-top: size(189);

			@include mq('sp') {
				flex-direction: column-reverse;
				gap: size(99);
				margin-top: size(99);
			}
		}

		&__introText {
			flex-shrink: 0;
			width: size(363);
			display: flex;
			flex-direction: column;
			gap: size(57);

			@include mq('sp') {
				width: 100%;
			}
		}

		&__introHeading {
			font-family: $Font;
			font-weight: 500;
			font-size: size(25);
			line-height: 1.4;
			letter-spacing: 0.03em;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(40);
			}
		}

		&__introDesc {
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.7;
			color: $brand-text;
			width: size(357);

			@include mq('sp') {
				font-size: size(30);
				width: auto;
			}
		}

		&__introImg {
			flex-shrink: 0;
			width: size(525);
			height: size(299);
			border-radius: size(10);
			overflow: hidden;

			@include mq('sp') {
				width: 100%;
				height: size(370);
			}

			:global(picture) {
				display: block;
				width: 100%;
				height: 100%;
			}

			:global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		}

		// --- 出張買取実績 stats（Business01 と同一パターン） ---
		&__stats {
			position: relative;
			margin-top: size(115);
		}

		&__statsBadge {
			position: absolute;
			top: size(-30);
			left: 50%;
			transform: translateX(-50%);
			z-index: 2;
			width: size(240);
			height: size(80);

			@include mq('sp') {
				top: size(-29);
				width: size(274);
				height: size(92);
			}
		}

		&__statsBadgeShape {
			position: absolute;
			inset: 0;

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}
		}

		&__statsBadgeText {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			padding-bottom: size(16);
			font-family: $Font;
			font-weight: 500;
			font-size: size(25);
			letter-spacing: size(1.5);
			color: $brand-white;

			@include mq('sp') {
				font-size: size(34);
			}
		}

		&__statsInner {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			padding: size(69) size(60) size(49);
			background: linear-gradient(180deg, #fff 0%, #e9e9e9 100%);
			border-radius: size(10);
			box-shadow: 0 0 size(7.5) rgba(#000, 0.25);

			@include mq('sp') {
				flex-direction: column;
				align-items: stretch;
				gap: size(33);
				padding: size(60) size(76);
			}
		}

		&__stat {
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: size(8);

			@include mq('sp') {
				flex-direction: row;
				align-items: center;
				gap: size(33);
				padding-bottom: size(23);
				border-left: none;
				border-bottom: size(1) solid $brand-blue;

				&:last-child {
					padding-bottom: 0;
					border-bottom: none;
				}
			}

			&:not(:first-child) {
				border-left: size(1) solid rgba($brand-blue, 0.15);
			}
		}

		// アイコンはグラデ円+グリフを焼き込んだ単一SVG（business-02-stat-0X.svg）
		&__statIcon {
			flex-shrink: 0;
			width: size(139);
			height: size(139);

			img {
				display: block;
				width: 100%;
				height: 100%;
			}
		}

		&__statBody {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: size(5);

			@include mq('sp') {
				align-items: flex-start;
			}
		}

		&__statLabel {
			font-family: $Font;
			font-weight: 400;
			font-size: size(19);
			line-height: 1.4;
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(25);
			}
		}

		&__statValue {
			display: flex;
			align-items: flex-end;
			gap: size(4);
		}

		&__statNum {
			font-family: $Font-Num;
			font-weight: 700;
			font-size: size(70);
			line-height: size(64);
			color: $brand-text;
		}

		&__statUnit {
			font-family: $Font-Num;
			font-weight: 700;
			font-size: size(28);
			line-height: size(24);
			color: $brand-text;
			padding-bottom: size(7);
		}

		// --- エコクリアの特徴 ---
		&__features {
			margin-top: size(115);
		}

		&__featureList {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: size(49);
			margin-top: size(34);

			@include mq('sp') {
				grid-template-columns: repeat(2, 1fr);
				gap: size(30);
			}
		}

		&__feature {
			display: flex;
			flex-direction: column;
			align-items: center;
			padding: size(21) size(33) size(29);
			border-radius: size(10);
			background: $brand-gradient;
			filter: drop-shadow(0 0 size(6.5) rgba(#000, 0.05));
		}

		&__featureNo {
			font-family: $Font-Readex;
			font-weight: 400;
			font-size: size(14);
			line-height: 1.4;
			letter-spacing: size(2.8);
			color: $brand-white;
			text-align: center;

			@include mq('sp') {
				font-size: size(20);
			}
		}

		// アイコンは円+グリフを焼き込んだ単一SVG（feature-icon-0X.svg）
		&__featureIcon {
			width: size(119);
			height: size(119);
			margin-top: size(14);

			img {
				display: block;
				width: 100%;
				height: 100%;
			}
		}

		&__featureTitle {
			margin-top: size(17);
			font-family: $Font;
			font-weight: 700;
			font-size: size(22);
			line-height: 1.4;
			letter-spacing: size(0.73);
			color: $brand-white;
			text-align: center;

			@include mq('sp') {
				font-size: size(30);
			}
		}

		&__featureDesc {
			margin-top: size(13);
			font-family: $Font;
			font-weight: 500;
			font-size: size(15);
			line-height: 1.4;
			color: $brand-white;
			text-align: justify;

			@include mq('sp') {
				font-size: size(22);
			}
		}

		// --- 買取品目 ---
		&__items {
			margin-top: size(115);
		}

		&__itemList {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: size(25) size(34);
			margin-top: size(34);

			@include mq('sp') {
				grid-template-columns: repeat(2, 1fr);
				gap: size(51) size(22);
			}
		}

		&__item {
			display: flex;
			flex-direction: column;
			gap: size(4);
		}

		&__itemImg {
			display: block;
			width: 100%;
			aspect-ratio: 237 / 142;
			border-radius: size(10);
			overflow: hidden;

			:global(picture) {
				display: block;
				width: 100%;
				height: 100%;
			}

			:global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		}

		&__itemLabel {
			font-family: $Font;
			font-weight: 500;
			font-size: size(18);
			line-height: 1.4;
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(24);
			}
		}

		&__itemsNote {
			margin-top: size(52);
			font-family: $Font;
			font-weight: 400;
			font-size: size(16);
			line-height: 1.4;
			color: $brand-text;
			text-align: center;
			padding-bottom: size(10);
			border-bottom: size(1) solid $brand-blue;
			width: fit-content;
			margin-inline: auto;

			@include mq('sp') {
				font-size: size(69);
			}
		}

		// --- 買取のながれ ---
		&__flow {
			position: relative;
			margin-top: size(125);
			padding: size(98) size(66) size(56);
			background: $brand-white;
			border-radius: size(10);
			box-shadow: 0 0 size(7.5) rgba(#000, 0.1);

			@include mq('sp') {
				margin-top: size(148);
				padding: size(98) size(40) size(56);
			}
		}

		&__flowInner {
			position: relative;
			display: flex;
			justify-content: space-between;
			gap: size(78);
			max-width: size(914);
			margin-inline: auto;

			// SP: 縦組みタイムライン（左に番号+縦線, 右にラベル+説明）Figma 1024:2856
			@include mq('sp') {
				flex-direction: column;
				align-items: stretch;
				gap: size(40);
				max-width: size(470);
			}
		}

		&__flowLine {
			position: absolute;
			top: size($num-size-pc / 2);
			left: size(85);
			right: size(85);
			height: size(2);
			background: $brand-blue;

			@include mq('sp') {
				inset: size(30) auto size(30) size(30);
				width: size(2);
				height: auto;
			}
		}

		&__flowStep {
			position: relative;
			z-index: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
