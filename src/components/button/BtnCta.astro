---

interface Props {
  mainText?: string;
  subText?: string;
  badgeText?: string;
  footerText?: string;
  href?: string;
  class?: string;
  size?: 'default' | 'large';
}

const { 
  mainText = "返金診断する",
  subText = "まずは診断でお金が取り返せるか確認", 
  badgeText = "無料",
  footerText = "受付時間：24時間365日",
  href = "#",
  class: className,
  size = 'default'
} = Astro.props;
---

<div class={`c-btn-cta ${size === 'large' ? 'c-btn-cta--large' : ''} ${className || ''}`}>
  <!-- 上部メッセージ -->
  <div class="c-btn-cta__message">
    {subText}
    <span class="c-btn-cta__message-icon">
    </span>
  </div>
  
  <!-- メインボタン -->
  <a href={href} class="c-btn-cta__button">
    <!-- 無料バッジ（円形） -->
    <div class="c-btn-cta__badge">
      {badgeText}
    </div>
    
    <!-- メインテキスト -->
    <span class="c-btn-cta__text">
      {mainText}
    </span>
    
    <!-- 矢印アイコン -->
    <div class="c-btn-cta__icon">
    </div>
  </a>
  
  <!-- 下部テキスト -->
  <div class="c-btn-cta__footer">
    {footerText}
  </div>
</div>

<style lang="scss">
  @use "../../styles/foundation/index" as *;


</style>