{
	"name": "astro-lp-template",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "run-s lint:check 'astro build' 'replace-html' 'replace-path'",
		"build:ecforce": "run-s lint:check 'astro build' 'replace-html' 'replace-path-ecforce'",
		"build:check": "NODE_ENV=production astro build",
		"replace-html": "node replaceHtml.mjs",
		"replace-path": "node replacePath.mjs",
		"replace-path-ecforce": "node replacePathEcforce.mjs",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint . --ext .js,.ts,.astro",
		"lint:fix": "eslint . --ext .js,.ts,.astro --fix",
		"lint:check": "eslint . --ext .js,.ts,.astro --max-warnings 0"
	},
	"dependencies": {
		"@splidejs/splide": "^4.1.4",
		"@splidejs/splide-extension-auto-scroll": "^0.5.3",
		"astro": "^5.13.5",
		"gsap": "^3.13.0",
		"swiper": "^8.4.7"
	},
	"devDependencies": {
		"@astrojs/sitemap": "^3.6.0",
		"@eslint/js": "^9.34.0",
		"@types/node": "^20.11.0",
		"@typescript-eslint/parser": "^8.42.0",
		"astro-relative-links": "^0.4.2",
		"astro-seo": "^0.8.4",
		"chalk": "^5.4.1",
		"cheerio": "^1.1.2",
		"cssnano": "^7.0.6",
		"eslint": "^9.34.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-astro": "^1.3.1",
		"eslint-plugin-import-x": "^4.16.1",
		"glob": "^11.0.3",
		"node-html-parser": "^6.1.13",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.3",
		"postcss-combine-media-query": "^1.0.1",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "^0.14.1",
		"sass": "^1.92.0",
		"sharp": "^0.34.3",
		"terser": "^5.39.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.42.0",
		"vite-plugin-image-optimizer": "^1.1.7"
	}
}
