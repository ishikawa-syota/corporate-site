---
import watermark from '../../images/keitasplan/common/logo_S.svg?raw';

interface Props {
	id?: string;
	ja: string;
	en: string;
	// SPの見出しサイズ（タイトルが短いページは大きめ）
	spTitleLarge?: boolean;
}
const { id, ja, en, spTitleLarge = false } = Astro.props;
---

<section
	class:list={['c-page-hero', spTitleLarge && 'c-page-hero--sp-lg']}
	id={id}
>
	<div class="c-page-hero__titles">
		<span class="c-page-hero__ja" set:html={ja} />
		<span class="c-page-hero__en">{en}</span>
	</div>
	<span class="c-page-hero__mark" aria-hidden="true" set:html={watermark} />
</section>

<style lang="scss">
	.c-page-hero {
		position: relative;
		overflow: hidden;
		padding: size(234) size(108) size(64);

		@include mq('sp') {
			padding: size(183) size(45) size(58);

			&__ja {
				font-size: size(60);
			}

			&__en {
				font-size: size(35);
			}

			&__mark {
				top: size(120);
				width: size(587);
				height: size(587);
			}
		}

		&--sp-lg {
			@include mq('sp') {
				.c-page-hero__ja {
					font-size: size(80);
				}
			}
		}

		&__titles {
			display: flex;
			flex-direction: column;
			gap: size(3);
			position: relative;
			z-index: 1;
		}

		&__ja {
			font-family: $Font;
			font-weight: 500;
			font-size: size(56);
			line-height: 1.4;
			letter-spacing: size(5.6);
			color: $brand-text;
		}

		&__en {
			font-family: $Font-Readex;
			font-weight: 500;
			font-size: size(29);
			line-height: 1.4;
			letter-spacing: size(2.9);
			color: $brand-text;
		}

		&__mark {
			position: absolute;
			top: size(118);
			right: 0;
			width: size(434);
			height: size(434);
			pointer-events: none;

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}
		}
	}
</style>
