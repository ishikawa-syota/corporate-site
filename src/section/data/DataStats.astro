---
import CompanyScale from './CompanyScale.astro';
import Events from './Events.astro';
import HomeVisit from './HomeVisit.astro';
import Staff from './Staff.astro';
import StatSection from './StatSection.astro';

const social = {
	en: 'SOCIAL CONTRIBUTION',
	ja: '環境・社会貢献',
	sub: 'リユース事業を通じて、資源循環に貢献しています。',
	cards: [
		{
			label: '年間買取物品数',
			value: '000,000',
			unit: '点',
			caption: 'リユースに回る点数',
			illustLabel: 'nenkanre',
			illustW: 158,
			illustH: 151,
		},
		{
			label: '再流通率',
			prefix: '約',
			value: '00',
			unit: '%',
			caption: '買取品の再販売率',
			overlay: true,
			illustLabel: 'sairyutsu',
			illustW: 432,
			illustH: 195,
		},
		{
			label: 'CO2削減貢献',
			value: '00.0',
			unit: 't',
			caption: 'リユースによる削減量推定',
			wide: true,
			illust: 'left' as const,
			illustLabel: 'co2',
			illustW: 556,
			illustH: 214,
		},
	],
};
---

<div class="p-data-stats">
	<CompanyScale id="data-company" />
	<HomeVisit id="data-home-visit" />
	<Events id="data-events" />
	<Staff id="data-staff" />
	<StatSection id="data-social" {...social} />
</div>

<style lang="scss">
	// 指標グループ全体の背景（淡いブルー）。上部を角丸にしてヒーロー(白)から切り替わる
	.p-data-stats {
		position: relative;
		background: linear-gradient(360deg, #dfefff 48.08%, #b8dbff 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;
		padding-block: size(86) size(152);
		display: flex;
		flex-direction: column;
		gap: size(161);

		@include mq('sp') {
			padding-block: size(137) size(141);
		}
	}
</style>
