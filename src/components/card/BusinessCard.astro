---
// 事業紹介カード（左：写真 / 右：ブルーパネル）
import ArrowButton from '../button/ArrowButton.astro';
import ImagePlaceholder from '../common/ImagePlaceholder.astro';

interface Props {
  title: string;
  desc: string;
  href?: string;
}

const { title, desc, href = '#' } = Astro.props;
---

<article class="c-bizCard">
  <div class="c-bizCard__media">
    <ImagePlaceholder label={title} class="c-bizCard__img" rounded="0" />
  </div>
  <div class="c-bizCard__body">
    <h3 class="c-bizCard__title">{title}</h3>
    <p class="c-bizCard__desc">{desc}</p>
    <ArrowButton href={href} label="詳しく見る" variant="white" size="sm" class="c-bizCard__btn" />
  </div>
</article>

<style lang="scss">
  @use '../../styles/foundation/index' as *;

  .c-bizCard {
    display: flex;
    align-items: stretch;
    width: 100%;
    border-radius: size(7);
    overflow: hidden;
    box-shadow: 0 size(10) size(30) rgba($brand-blue, 0.1);

    @include mq('sp') {
      flex-direction: column;
    }

    &__media {
      flex-shrink: 0;
      width: size(226);

      @include mq('sp') {
        width: 100%;
        height: size(180);
      }
    }

    &__img {
      height: 100%;
    }

    &__body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: size(28);
      padding: size(50) size(30);
      background-color: $brand-blue;

      @include mq('sp') {
        padding: size(32) size(24);
        gap: size(20);
      }
    }

    &__title {
      font-family: $Font;
      font-weight: 700;
      font-size: size(30);
      line-height: 1.4;
      color: $brand-white;
    }

    &__desc {
      @include ty-body-s;
      color: $brand-white;
      text-align: justify;
    }
  }
</style>
