---
import ArrowButton from '../components/button/ArrowButton.astro';
import MemberCard from '../components/card/MemberCard.astro';
import OptImage from '../components/common/OptImage.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import { members } from '../data/siteContent';
import watermarkLogo from '../images/keitasplan/member/logo_S.png';
import memberA from '../images/keitasplan/member/member-01.png';
import memberAHover from '../images/keitasplan/member/member-01_hover.png';
import memberB from '../images/keitasplan/member/member-02.png';
import memberBHover from '../images/keitasplan/member/member-02_hover.png';
import memberC from '../images/keitasplan/member/member-03.png';
import memberCHover from '../images/keitasplan/member/member-03_hover.png';
import memberD from '../images/keitasplan/member/member-04.png';
import memberDHover from '../images/keitasplan/member/member-04_hover.png';

interface Props {
	id?: string;
}
const { id } = Astro.props;

// 各メンバーの通常画像とhover画像（1:1対応）
const memberImages = [memberA, memberB, memberC, memberD];
const memberHoverImages = [
	memberAHover,
	memberBHover,
	memberCHover,
	memberDHover,
];
---

<section class="p-member" id={id}>
	<span class="p-member__watermark" aria-hidden="true">
		<OptImage src={watermarkLogo} alt="" width={900} fit="contain" />
	</span>
	<div class="p-member__inner">
		<SectionHeading
			ja="メンバー"
			en="MEMBERS"
			lead="買取のプロフェッショナルが丁寧に対応します"
			theme="light"
			class="p-member__heading"
		/>
		<div class="p-member__carousel">
			<div
				class="splide p-member__splide"
				data-member-splide
				aria-label="メンバー"
			>
				<div class="splide__track p-member__track">
					<div class="splide__list p-member__grid">
						{
							members.map((m, i) => (
								<div class="splide__slide p-member__item">
									<MemberCard
										role={m.role}
										name={m.name}
										img={memberImages[i]}
										imgHover={memberHoverImages[i]}
									/>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>
		<div class="p-member__btn">
			<ArrowButton
				href="#member"
				label="詳しく見る"
				variant="white"
				class="p-member__btn"
			/>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../styles/foundation/index' as *;

	.p-member {
		position: relative;

		// overflow: hidden;
		// Figma: 濃紺グラデ背景（人物写真がくっきり映える）
		// background: linear-gradient(180deg, $brand-blue 0%, #cfe6ff 100%);
		padding-block: size(100);

		@include mq('sp') {
			padding-block: size(80);
			padding-inline: size(94);
		}

		&::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: size(1611);
			border-radius: 130px;
			background: linear-gradient(
				180deg,
				var(--0054-ac, #0054ac) 0%,
				#98cbff 51.44%,
				rgb(255 255 255 / 0%) 100%
			);

			@include mq('sp') {
				border-radius: size(94);
			}
		}

		// 中央の大きな⊗透かしロゴ
		&__watermark {
			position: absolute;
			top: 50%;
			left: 50%;
			width: size(900);
			transform: translate(-50%, -40%);
			pointer-events: none;

			:global(.c-img),
			:global(img) {
				width: 100%;
				height: auto;
			}
		}

		&__inner {
			position: relative;
			z-index: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			max-width: size(1098);
			margin-inline: auto;
			padding-inline: size(24);

			@include mq('sp') {
				padding-inline: 0;
			}
		}

		// PC: 4枚を重ねて中央配置（=splide__list。SPではSplideが制御）
		// Figma: カード幅402 / ピッチ302 → 隣同士100px重なり
		&__grid {
			display: flex;
			justify-content: center;
			align-items: flex-start;
			width: 100%;
			margin-top: size(72);

			@include mq('sp') {
				// SP: Splideのリスト。重なり/位置はSplideのgapが制御
				// PC用のcenter寄せを解除し左寄せに（先頭カードが余白直後にフル表示される）
				justify-content: flex-start;
				width: auto;
				margin-top: 0;
				padding-inline: 0;
			}
		}

		// カルーセルラッパー（透明・レイアウト無影響）
		&__carousel {
			width: 100%;
		}

		// Splideルート。PC(>=769)では破棄され素のブロック → 上のgridが効く
		&__splide {
			width: 100%;

			@include mq('sp') {
				// 左端はセクション余白(size(94))を確保し、右端だけ画面端までフルブリード
				width: calc(100% + #{size(94)});
				margin-left: 0;
				margin-top: size(151);
			}
		}

		// Splideトラック。SPのみクリッピング有効化（コアCSS非読込のため自前）
		&__track {
			@include mq('sp') {
				overflow: hidden;
			}
		}

		&__item {
			// 重なり配置のためカード幅を固定
			width: size(402);
			flex: 0 0 auto;
			position: relative;

			// hover中のカードを手前へ（重なりで隣に隠れないように）
			@media (hover: hover) and (pointer: fine) {
				&:hover {
					z-index: 2;
				}
			}

			// PC: 先頭以外を左にずらして100px重ねる（SPはSplideが制御するので0に戻す）
			&:not(:first-child) {
				margin-left: size(-100);

				@include mq('sp') {
					margin-left: 0;
				}
			}
		}

		&__btn {
			margin-top: size(64);

			@include mq('sp') {
				margin-top: size(40);
			}
		}
	}
</style>

<script>
	import Splide from '@splidejs/splide';

	import { BREAKPOINT_PC_MIN } from '@/data/config';

	// SPのみカルーセル化。PC(>=769)は mediaQuery:'min' + destroy で破棄され、
	// マークアップが素のdivに戻る＝CSSの4カラムgridがそのまま効く（PC無影響）
	document
		.querySelectorAll<HTMLElement>('[data-member-splide]')
		.forEach((el) => {
			new Splide(el, {
				fixedWidth: '52.34vw', // = size(402)（768基準: 402/768*100vw）
				focus: 'center',
				gap: '-19.53vw', // = margin-right size(-150) 相当の重なり（768基準換算）
				arrows: false,
				pagination: false,
				drag: true,
				speed: 500,
				mediaQuery: 'min',
				breakpoints: {
					[BREAKPOINT_PC_MIN]: {
						destroy: true,
					},
				},
			}).mount();
		});
</script>
