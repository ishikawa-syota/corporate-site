---
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import StatValue from '../../components/common/StatValue.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';
import items from '../../images/keitasplan/data/items.svg';
import satisfaction from '../../images/keitasplan/data/satisfaction.svg';
import visit from '../../images/keitasplan/data/visit.svg';

interface Props {
	id?: string;
}
const { id } = Astro.props;
---

<section class="p-data-home" id={id}>
	<div class="p-data-home__inner">
		<VerticalLabel text="SERVICE RECORD - HOME VISIT" />
		<div class="p-data-home__body">
			<DataSectionHead ja="出張買取の実績" />
			<ul class="p-data-home__grid">
				<li class="p-data-home__cell p-data-home__cell--wide">
					<div class="p-data-home__card p-data-home__card--wide">
						<span
							class="p-data-home__illust p-data-home__illust--items"
							aria-hidden="true"
						>
							<img src={items.src} alt="" />
						</span>
						<div class="p-data-home__text">
							<p class="p-data-home__label">年間買取件数</p>
							<StatValue prefix="約" value="48,000" unit="件超" />
						</div>
					</div>
				</li>

				<li class="p-data-home__cell">
					<div class="p-data-home__card">
						<span
							class="p-data-home__illust p-data-home__illust--pie"
							aria-hidden="true"
						>
							<img src={satisfaction.src} alt="" />
							<span
								class="p-data-home__overlay p-data-home__overlay--pie"
							>
								<StatValue light value="97" unit="%" />
							</span>
						</span>
						<div class="p-data-home__text">
							<p class="p-data-home__label">お客様満足度</p>
							<p class="p-data-home__caption">
								自社アンケート調べ
							</p>
						</div>
					</div>
				</li>

				<li class="p-data-home__cell">
					<div class="p-data-home__card">
						<span
							class="p-data-home__illust p-data-home__illust--visit"
							aria-hidden="true"
						>
							<img src={visit.src} alt="" />
							<span
								class="p-data-home__overlay p-data-home__overlay--visit"
							>
								<StatValue prefix="約" value="00" unit="分" />
							</span>
						</span>
						<div class="p-data-home__text">
							<p class="p-data-home__label">平均訪問時間</p>
							<p class="p-data-home__caption">
								ご予約から訪問まで
							</p>
						</div>
					</div>
				</li>
			</ul>
		</div>
	</div>
</section>

<style lang="scss">
	.p-data-home {
		position: relative;

		&__inner {
			display: flex;
			align-items: stretch;
			gap: size(81);
			margin-inline: auto;
			padding-inline: size(128) size(243);

			@include mq('sp') {
				padding-inline: size(45) size(94);
			}
		}

		&__body {
			flex: 1;
			min-width: 0;
		}

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: size(60) size(42);
			margin-top: size(100);

			@include mq('sp') {
				grid-template-columns: minmax(0, 1fr);
				gap: size(70);
			}
		}

		&__cell {
			min-width: 0;

			&--wide {
				grid-column: 1 / -1;
			}
		}

		// --- カード ---
		&__card {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: size(16);
			height: 100%;
			min-height: size(374);
			padding: size(36) size(40);
			background: $brand-white;
			border-radius: size(7);

			// 年間買取件数: PCは横並び（イラスト左+テキスト右）、SPは縦積み
			&--wide {
				flex-direction: row;
				justify-content: center;
				gap: size(60);

				@include mq('sp') {
					flex-direction: column;
					gap: size(30);
				}
			}
		}

		&__illust {
			display: block;
			flex-shrink: 0;

			img {
				display: block;
				width: 100%;
				height: 100%;
			}

			&--items {
				width: size(433);
				height: size(256);
			}

			// 数値を重ねるイラストは相対配置
			&--pie {
				position: relative;
				width: size(475);
				height: size(228);
			}

			&--visit {
				position: relative;
				width: size(376);
				height: size(229);
			}
		}

		// イラスト上に重ねる数値
		&__overlay {
			position: absolute;
			inset: 0;
			display: flex;
			height: fit-content;

			// 円グラフ中央（左寄り）に配置
			&--pie {
				left: size(162);
				top: size(96);

				@include mq('sp') {
					left: size(153);
					top: size(90);
				}
			}

			&--visit {
				left: size(96);
				top: size(64);
				width: size(240);
				justify-content: center;
			}
		}

		&__text {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: size(10);
		}

		// 年間買取件数の右側テキストは左寄せ（SPは中央）
		&__card--wide &__text {
			align-items: flex-start;

			@include mq('sp') {
				align-items: center;
			}
		}

		&__label {
			font-family: $Font;
			font-weight: 700;
			font-size: size(35);
			line-height: 1.4;
			letter-spacing: size(1.05);
			color: $brand-text;

			@include mq('sp') {
				font-size: size(40);
			}
		}

		&__caption {
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(24);
			}
		}
	}
</style>
