---
import OptImage from '../components/common/OptImage.astro';
import { companyInfo } from '../data/siteContent';
import logoWhite from '../images/keitasplan/common/footer-01.png';

interface Props {
	id?: string;
}
const { id } = Astro.props;

// フッターナビ（Figmaの4カラム構成）
const footerNav = [
	[
		{ ja: '事業紹介', href: '#business' },
		{ ja: '数字で見る', href: '#data' },
		{ ja: 'メンバー', href: '#member' },
	],
	[
		{ ja: 'お客様の声', href: '#voice' },
		{ ja: 'ニュース', href: '#news' },
		{ ja: '代表メッセージ', href: '#message' },
	],
	[
		{ ja: '会社概要', href: '#about' },
		{ ja: 'よくある質問', href: '#faq' },
		{ ja: 'お問い合わせ', href: '#contact' },
	],
	[
		{ ja: '特定商取引法表記', href: '#' },
		{ ja: 'プライバシーポリシー', href: '#' },
	],
];
---

<footer class="l-footer" id={id}>
	{/* お問い合わせ CTA カード。フッター先頭に配置し負マージンで上方向へ引き上げ、
	    FAQ(白→グレー)とフッター(青)の境界線上にカード中央が乗るように重ねる */}
	<div class="p-contactCta" id="contact">
		<div class="p-contactCta__inner">
			<div class="p-contactCta__head">
				<div class="p-contactCta__heading">
					<span class="p-contactCta__ja">お問い合わせ</span>
					<span class="p-contactCta__en">CONTACT</span>
				</div>
				<p class="p-contactCta__lead">
					サービスや採用について、お気軽にお問い合わせください
				</p>
			</div>

			<div class="p-contactCta__actions">
				<a href={companyInfo.telHref} class="p-contactCta__tel">
					<span class="p-contactCta__telIcon" aria-hidden="true">
						<svg
							viewBox="0 0 24 24"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.21z"
								fill="#0054ac"></path>
						</svg>
					</span>
					<span class="p-contactCta__telBody">
						<span class="p-contactCta__telNum">{companyInfo.tel}</span>
						<span class="p-contactCta__telHours"
							>{companyInfo.hours}</span
						>
					</span>
				</a>

				<a href="#contact" class="p-contactCta__form">
					<span class="p-contactCta__formLabel">お問い合わせフォーム</span
					>
					<span class="p-contactCta__formArrow" aria-hidden="true">
						<svg
							viewBox="0 0 58 58"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
						>
							<circle cx="29" cy="29" r="29" fill="#ffffff"></circle>
							<g
								stroke="#0054ac"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<line x1="19" y1="29" x2="38" y2="29"></line>
								<path d="M31 22 L38 29 L31 36"></path>
							</g>
						</svg>
					</span>
				</a>
			</div>

			<a href="#contact" class="p-contactCta__feedback">
				サービスへのご意見・ご要望はこちら
			</a>
		</div>
	</div>

	<div class="l-footer__inner">
		<div class="l-footer__info">
			<span class="l-footer__logo">
				<OptImage
					src={logoWhite}
					alt={companyInfo.name}
					width={301}
					fit="contain"
				/>
			</span>
			<p class="l-footer__address">
				{companyInfo.name}<br />
				{companyInfo.address}<br />
				TEL: {companyInfo.tel}
			</p>
			<p class="l-footer__license">{companyInfo.license}</p>
		</div>

		<div class="l-footer__right">
			<nav class="l-footer__nav" aria-label="フッターナビゲーション">
				{
					footerNav.map((col) => (
						<ul class="l-footer__navCol">
							{col.map((item) => (
								<li>
									<a
										href={item.href}
										class="l-footer__navLink"
									>
										{item.ja}
									</a>
								</li>
							))}
						</ul>
					))
				}
			</nav>

			<a href="#contact" class="l-footer__saiyou">
				<span class="l-footer__saiyouText">採用サイトはこちら</span>
				<span class="l-footer__saiyouIcon" aria-hidden="true">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="17"
						height="15"
						viewBox="0 0 17 15"
						fill="none"
					>
						<path
							d="M16.7071 8.07088C17.0976 7.68035 17.0976 7.04719 16.7071 6.65666L10.3431 0.292702C9.95262 -0.0978227 9.31946 -0.0978227 8.92893 0.292702C8.53841 0.683226 8.53841 1.31639 8.92893 1.70692L14.5858 7.36377L8.92893 13.0206C8.53841 13.4111 8.53841 14.0443 8.92893 14.4348C9.31946 14.8254 9.95262 14.8254 10.3431 14.4348L16.7071 8.07088ZM0 7.36377V8.36377H16V7.36377V6.36377H0V7.36377Z"
							fill="white"></path>
					</svg>
				</span>
			</a>
		</div>
	</div>
</footer>

<style lang="scss" is:global>
	@use '../styles/foundation/index' as *;

	.l-footer {
		position: relative;
		z-index: 2; // FAQ(z:1)より前面。内包するお問い合わせカードを境界線上に重ねる
		display: flow-root; // カードの負マージンを内包（margin相殺/はみ出しを制御）
		background-color: $brand-blue;
		// 上端paddingはお問い合わせカードの重なりで担うため0
		padding: 0 size(40) size(96);
		color: $brand-white;

		@include mq('sp') {
			padding: 0 size(96) size(80);
		}

		&__inner {
			display: flex;
			align-items: flex-start;
			gap: size(0);
			max-width: size(1058);
			margin-inline: auto;

			@include mq('sp') {
				flex-direction: column-reverse;
				align-items: center;
				gap: size(126);
			}
		}

		&__info {
			flex-shrink: 0;
			width: size(400);

			@include mq('sp') {
				width: 100%;
			}
		}

		&__logo {
			display: block;
			width: size(301);
			aspect-ratio: 2056 / 301;
			margin-bottom: size(57);

			@include mq('sp') {
				width: size(576);
				margin-bottom: size(24);
			}
		}

		&__address {
			font-family: $Font;
			font-size: size(14);
			line-height: 1.8;

			@include mq('sp') {
				font-size: size(25);
			}
		}

		&__license {
			font-family: $Font;
			font-size: size(12);
			line-height: 1.8;
			margin-top: size(24);

			@include mq('sp') {
				font-size: size(20);
				margin-top: size(32);
			}
		}

		&__right {
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: flex-end;

			@include mq('sp') {
				width: 100%;
				align-items: center;
				gap: size(96);
			}
		}

		&__nav {
			display: flex;
			gap: size(82);
			width: 100%;
			justify-content: flex-start;

			@include mq('sp') {
				// 全項目を列方向（上→下→次列）に流し、Figmaの3カラム(4/4/3)を再現
				display: grid;
				grid-auto-flow: column;
				grid-template-rows: repeat(4, auto);
				grid-template-columns: auto auto auto;
				column-gap: size(66);
				row-gap: size(25);
				justify-content: start;
				width: auto;
			}
		}

		&__navCol {
			display: flex;
			flex-direction: column;
			gap: size(24);
			list-style: none;

			// SPではul境界を解体し、全liをnavのgridアイテムにする
			@include mq('sp') {
				display: contents;
			}
		}

		&__navLink {
			font-family: $Font;
			font-size: size(14);
			line-height: 1.4;
			color: $brand-white;
			transition: opacity 0.3s ease;

			@include mq('sp') {
				font-size: size(20);
				white-space: nowrap;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					opacity: 0.7;
				}
			}
		}

		// 採用サイトはこちらボタン（Figma: button_saiyou）
		&__saiyou {
			position: relative;
			display: inline-flex;
			align-items: center;
			justify-content: space-between;
			gap: size(28);
			width: size(301);
			height: size(51);
			margin-top: size(60);
			padding: size(10) size(11) size(10) size(52);
			border-radius: size(140);
			background: linear-gradient(180deg, #ffffff 0%, #e9e9e9 100%);
			transition:
				transform 0.3s ease,
				box-shadow 0.3s ease;

			@include mq('sp') {
				height: size(60);
				width: fit-content;
				margin-top: 0;
				margin-inline: auto;
				border-radius: size(180);
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					box-shadow: 0 size(8) size(20) rgba(#000, 0.15);
				}
			}
		}

		&__saiyouText {
			font-family: $Font;
			font-weight: 500;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-blue;
			white-space: nowrap;

			@include mq('sp') {
				font-size: size(23);
			}
		}

		&__saiyouIcon {
			flex-shrink: 0;
			display: grid;
			place-items: center;
			width: size(30);
			height: size(30);
			background-color: $brand-blue;
			border-radius: 50%;

			svg {
				width: size(15);
				height: size(13);
			}
		}
	}

	// =========================================================
	// お問い合わせ CTA カード（旧 10ContactCta.astro を統合）
	// Figma: sec8 / 白→#f9f9f9 グラデのカード。FAQ↔フッターの境界線上に中央が乗る
	// =========================================================
	.p-contactCta {
		position: relative;
		z-index: 2;
		// margin-top = カード高さの半分（負）。カード中央をフッター上端(=FAQとの境界線)に乗せる
		margin-top: size(-176);
		// フッターナビとの余白（Figma: フッター上端→ナビ 202 − カード半分 176）
		margin-bottom: size(26);

		@include mq('sp') {
			margin-top: size(-326);
			margin-bottom: size(40);
		}

		&__inner {
			position: relative;
			max-width: size(1211);
			margin-inline: auto;
			padding: size(36) size(51) size(50);
			background: linear-gradient(180deg, $brand-white 0%, #f9f9f9 100%);
			border-radius: size(20);
			box-shadow: 0 size(4) size(17) rgba(#000, 0.25);
			overflow: clip;

			@include mq('sp') {
				padding: size(54) size(49) size(81);
				border-radius: size(10);
				box-shadow: size(4) size(4) size(25) rgba(#000, 0.1);
				background: #fff;
			}
		}

		// --- 見出し + リード（横並び） ---
		&__head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: size(40);

			@include mq('sp') {
				flex-direction: column;
				align-items: flex-start;
				gap: size(20);
			}
		}

		&__heading {
			display: flex;
			flex-direction: column;
			flex-shrink: 0;
		}

		&__ja {
			font-family: $Font;
			font-weight: 500;
			font-size: size(33);
			line-height: 1.4;
			letter-spacing: 0.1em;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(38);
			}
		}

		&__en {
			font-family: $Font-Readex;
			font-weight: 500;
			font-size: size(13);
			line-height: 1.4;
			letter-spacing: 0.1em;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(17);
			}
		}

		&__lead {
			font-family: $Font;
			font-weight: 400;
			font-size: size(19);
			line-height: 1.4;
			letter-spacing: 0.053em;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(30);
				letter-spacing: 0.033em;
			}
		}

		// --- 電話 / フォームボタン（横並び・カード中央） ---
		&__actions {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: size(48);
			margin-top: size(37);

			@include mq('sp') {
				flex-direction: column;
				gap: size(33);
				margin-top: size(34);
			}
		}

		// --- 電話ピル ---
		&__tel {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: size(12);
			width: size(425);
			height: size(108);
			padding: 0 size(22);
			border-radius: size(150);
			background: linear-gradient(180deg, #e9e9e9 0%, #efefef 100%);

			@include mq('sp') {
				width: 100%;
				height: size(108);
				gap: size(12);
			}
		}

		&__telIcon {
			display: grid;
			place-items: center;
			flex-shrink: 0;
			width: size(64);
			height: size(64);
			border-radius: 50%;
			background-color: $brand-white;

			@include mq('sp') {
				width: size(64);
				height: size(64);
			}

			svg {
				width: size(34);
				height: size(34);

				@include mq('sp') {
					width: size(34);
					height: size(38);
				}
			}
		}

		&__telBody {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		&__telNum {
			font-family: $Font-Sub;
			font-weight: 700;
			font-size: size(39);
			line-height: 1.4;
			letter-spacing: 0.018em;
			color: $brand-blue;
			white-space: nowrap;

			@include mq('sp') {
				font-size: size(39);
			}
		}

		&__telHours {
			font-family: $Font;
			font-weight: 400;
			font-size: size(12);
			line-height: 1.4;
			color: $brand-blue;
			white-space: nowrap;

			@include mq('sp') {
				font-size: size(17);
			}
		}

		// --- フォームボタン ---
		&__form {
			position: relative;
			display: flex;
			align-items: center;
			justify-content: flex-start;
			width: size(425);
			height: size(108);
			padding: 0 size(80) 0 size(51);
			border-radius: size(150);
			background: linear-gradient(
				180deg,
				$brand-blue 0%,
				$brand-blue-pale 100%
			);
			transition:
				transform 0.3s ease,
				box-shadow 0.3s ease;

			@include mq('sp') {
				width: 100%;
				height: size(108);
				justify-content: center;
				padding: 0 size(115) 0 size(56);
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					box-shadow: 0 size(8) size(20) rgba($brand-blue, 0.3);
				}
			}
		}

		&__formLabel {
			font-family: $Font;
			font-weight: 500;
			font-size: size(27);
			line-height: 1.4;
			color: $brand-white;
			white-space: nowrap;

			@include mq('sp') {
				font-size: size(27);
			}
		}

		&__formArrow {
			position: absolute;
			top: 50%;
			right: size(15);
			transform: translateY(-50%);
			display: inline-flex;
			width: size(58);
			height: size(58);

			@include mq('sp') {
				right: size(22);
				width: size(58);
				height: size(58);
			}

			svg {
				width: 100%;
				height: 100%;
			}
		}

		// --- フィードバックリンク ---
		&__feedback {
			display: block;
			width: fit-content;
			margin: size(34) auto 0;
			font-family: $Font;
			font-weight: 400;
			font-size: size(16);
			line-height: 1.4;
			letter-spacing: 0.038em;
			color: $brand-text;
			text-decoration: underline;
			text-underline-offset: 0.15em;
			transition: opacity 0.3s ease;

			@include mq('sp') {
				margin-top: size(24);
				font-size: size(20);
				letter-spacing: 0.03em;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					opacity: 0.6;
				}
			}
		}
	}
</style>
