---
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';
import { companyInfo } from '../../data/siteContent';
import telIcon from '../../images/keitasplan/common/icon-tel.svg';
---

<section class="p-call">
	<div class="p-call__inner">
		<VerticalLabel text="CALL" />
		<div class="p-call__body">
			<DataSectionHead
				ja='お電話での<br class="u-sp-only" />お問い合わせ'
			/>
			<div class="p-call__tel">
				<a class="p-call__row" href={companyInfo.telHref}>
					<span class="p-call__icon">
						<img
							class="p-call__iconImg"
							src={telIcon.src}
							alt=""
							width="34"
							height="38"
						/>
					</span>
					<span class="p-call__num">
						<span class="p-call__label">フリーダイヤル</span>
						<span class="p-call__number">{companyInfo.tel}</span>
					</span>
				</a>
				<p class="p-call__hours">{companyInfo.hours}</p>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	.p-call {
		position: relative;
		background: linear-gradient(360deg, #dfefff 48.08%, #b8dbff 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;
		padding-top: size(135);
		padding-bottom: size(112 + $section-card-radius);

		@include mq('sp') {
			padding-top: size(137);
			padding-bottom: size(142 + $section-card-radius);
		}

		&__inner {
			display: flex;
			align-items: stretch;
			width: size(1166);
			margin-inline: size(128) auto;

			@include mq('sp') {
				width: size(629);
				margin-inline: size(45) auto;
			}
		}

		&__body {
			flex: 1;
			margin-left: size(81);
		}

		&__tel {
			margin-top: size(46);

			@include mq('sp') {
				margin-top: size(50);
			}
		}

		&__row {
			display: flex;
			align-items: center;
			gap: size(20);

			@include mq('sp') {
				gap: size(18);
			}
		}

		&__icon {
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
			width: size(69);
			height: size(69);
			border-radius: size(7);
			background-color: $brand-white;

			@include mq('sp') {
				width: size(99);
				height: size(99);
			}
		}

		&__iconImg {
			display: block;
			width: size(37);
			height: auto;

			@include mq('sp') {
				width: size(52);
			}
		}

		&__num {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
		}

		&__label {
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.4;
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(27);
			}
		}

		&__number {
			margin-top: size(-5);
			font-family: $Font-Sub;
			font-weight: 900;
			font-size: size(46);
			line-height: 1.4;
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(58);
			}
		}

		&__hours {
			margin-top: size(9);
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(30);
			}
		}
	}
</style>
