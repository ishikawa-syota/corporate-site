---
import ArrowButton from '../components/button/ArrowButton.astro';
import MemberCard from '../components/card/MemberCard.astro';
import OptImage from '../components/common/OptImage.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import { members } from '../data/siteContent';
import watermarkLogo from '../images/keitasplan/member/logo_S.png';
import memberA from '../images/keitasplan/member/member-01.png';
import memberB from '../images/keitasplan/member/member-03.png';

interface Props {
	id?: string;
}
const { id } = Astro.props;

// 2枚の写真を交互に使用（デザイン同様）
const memberImages = [memberA, memberB];
---

<section class="p-member" id={id}>
	<span class="p-member__watermark" aria-hidden="true">
		<OptImage src={watermarkLogo} alt="" width={900} fit="contain" />
	</span>
	<div class="p-member__inner">
		<SectionHeading
			ja="メンバー"
			en="MEMBERS"
			lead="買取のプロフェッショナルが丁寧に対応します"
			theme="light"
			class="p-member__heading"
		/>
		<div class="p-member__carousel">
			<div
				class="splide p-member__splide"
				data-member-splide
				aria-label="メンバー"
			>
				<div class="splide__track p-member__track">
					<div class="splide__list p-member__grid">
						{
							members.map((m, i) => (
								<div class="splide__slide p-member__item">
									<MemberCard
										role={m.role}
										name={m.name}
										img={memberImages[i % 2]}
									/>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>
		<div class="p-member__btn">
			<ArrowButton
				href="#member"
				label="詳しく見る"
				variant="white"
				class="p-member__btn"
			/>
		</div>
	</div>
</section>

<style lang="scss">
	@use '../styles/foundation/index' as *;

	.p-member {
		position: relative;
		// overflow: hidden;
		// Figma: 濃紺グラデ背景（人物写真がくっきり映える）
		background: linear-gradient(180deg, $brand-blue 0%, #cfe6ff 100%);
		padding-block: size(100);

		@include mq('sp') {
			padding-block: size(80);
		}

		&::before {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: size(1611);
			border-radius: 130px;
			background: linear-gradient(
				180deg,
				var(--0054-ac, #0054ac) 0%,
				#98cbff 51.44%,
				rgba(255, 255, 255, 0) 100%
			);
		}

		// 中央の大きな⊗透かしロゴ
		&__watermark {
			position: absolute;
			top: 50%;
			left: 50%;
			width: size(900);
			transform: translate(-50%, -55%);
			pointer-events: none;
			opacity: 0.08;

			:global(.c-img),
			:global(img) {
				width: 100%;
				height: auto;
			}
		}

		&__inner {
			position: relative;
			z-index: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			max-width: size(1098);
			margin-inline: auto;
			padding-inline: size(24);
		}

		// PC: 4カラムgrid（=splide__list。SPではSplideが制御）
		&__grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: size(40);
			width: 100%;
			margin-top: size(72);

			@include mq('sp') {
				// SP: Splideのリスト。flex化のみ（重なり/位置はSplideのgapが制御）
				display: flex;
				grid-template-columns: none;
				gap: 0;
				width: auto;
				margin-top: 0;
				padding-inline: 0;
			}
		}

		// カルーセルラッパー（透明・レイアウト無影響）
		&__carousel {
			width: 100%;
		}

		// Splideルート。PC(>=769)では破棄され素のブロック → 上のgridが効く
		&__splide {
			width: 100%;

			@include mq('sp') {
				// 画面端までフル幅で見せる（従来の重なりカルーセル踏襲）
				width: 100vw;
				margin-left: calc(50% - 50vw);
				margin-top: size(151);
			}
		}

		// Splideトラック。SPのみクリッピング有効化（コアCSS非読込のため自前）
		&__track {
			@include mq('sp') {
				overflow: hidden;
			}
		}

		&__item {
			@include mq('sp') {
				// 重なり配置のためカード幅を固定（Splide autoWidthが参照）
				width: size(402);
				flex: 0 0 auto;
			}
		}

		&__btn {
			margin-top: size(64);

			@include mq('sp') {
				margin-top: size(40);
			}
		}
	}
</style>

<script>
	import Splide from '@splidejs/splide';

	// SPのみカルーセル化。PC(>=769)は mediaQuery:'min' + destroy で破棄され、
	// マークアップが素のdivに戻る＝CSSの4カラムgridがそのまま効く（PC無影響）
	document
		.querySelectorAll<HTMLElement>('[data-member-splide]')
		.forEach((el) => {
			new Splide(el, {
				fixedWidth: '52.34vw', // = size(402)（768基準: 402/768*100vw）
				focus: 'center',
				gap: '-19.53vw', // = margin-right size(-150) 相当の重なり（768基準換算）
				arrows: false,
				pagination: false,
				drag: true,
				speed: 500,
				mediaQuery: 'min',
				breakpoints: {
					769: {
						destroy: true,
					},
				},
			}).mount();
		});
</script>
