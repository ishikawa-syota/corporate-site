---
import { Image } from 'astro:assets';

import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  priority?: boolean;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  quality?: number;
  format?: 'avif' | 'webp' | 'png' | 'jpg' | 'jpeg';
  class?: string;
  style?: string;
}

const { 
  src, 
  alt, 
  priority = false, 
  loading = priority ? 'eager' : 'lazy',
  fetchpriority = priority ? 'high' : 'auto',
  width,
  height,
  quality = 80,
  format = 'webp',
  class: className,
  style,
  ...rest 
} = Astro.props;
---

<Image 
  src={src} 
  alt={alt}
  loading={loading}
  fetchpriority={fetchpriority}
  width={width}
  height={height}
  quality={quality}
  format={format}
  class={className}
  style={style}
  {...rest}
/>