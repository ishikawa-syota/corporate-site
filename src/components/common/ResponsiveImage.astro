---
import { getImage } from "astro:assets";

interface Props {
  pcSrc: ImageMetadata;
  mobileSrc: ImageMetadata;
  alt: string;
  className?: string;
  priority?: boolean;
}

const { pcSrc, mobileSrc, alt, className = '', priority = false } = Astro.props;

// PC用のAVIF画像を生成
const optimizedPcAvif = await getImage({
  src: pcSrc,
  format: "avif",
  quality: 65,
});

// PC用のWebP画像を生成
const optimizedPcWebp = await getImage({
  src: pcSrc,
  format: "webp",
  quality: 75,
});

// モバイル用のAVIF画像を生成
const optimizedMobileAvif = await getImage({
  src: mobileSrc,
  format: "avif",
  quality: 65,
});

// モバイル用のWebP画像を生成
const optimizedMobileWebp = await getImage({
  src: mobileSrc,
  format: "webp",
  quality: 75,
});

// 優先度に基づいて読み込み属性を決定
const loadingAttr = priority ? "eager" : "lazy";
const fetchPriority = priority ? "high" : "auto";
---

<picture class={className}>
  <!-- PC用AVIF -->
  <source
    media="(min-width: 960px)"
    srcset={optimizedPcAvif.src}
    type="image/avif"
  />

  <!-- PC用WebP -->
  <source
    media="(min-width: 960px)"
    srcset={optimizedPcWebp.src}
    type="image/webp"
  />
  
  <!-- モバイル用AVIF -->
  <source
    srcset={optimizedMobileAvif.src}
    type="image/avif"
  />
  
  <!-- モバイル用WebP -->
  <source
    srcset={optimizedMobileWebp.src}
    type="image/webp"
  />
  
  <!-- フォールバック用の画像 -->
  <img
    src={optimizedMobileWebp.src}
    alt={alt}
    width={mobileSrc.width}
    height={mobileSrc.height}
    loading={loadingAttr}
    fetchpriority={fetchPriority}
    decoding="async"
  />
</picture>