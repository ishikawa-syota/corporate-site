---
// フォント（fontsource）— Figma準拠
// Zen Kaku Gothic New(本文/$Font) / Noto Sans JP($Font-Sub) / Oswald($Font-En)
// Readex Pro(EN見出し) / Roboto(数字)
// 事前に下記インストールが必要:
//   npm install @fontsource/zen-kaku-gothic-new @fontsource/noto-sans-jp @fontsource/oswald @fontsource/readex-pro @fontsource/roboto
import '@fontsource/noto-sans-jp/400.css';
import '@fontsource/noto-sans-jp/500.css';
import '@fontsource/noto-sans-jp/700.css';
import '@fontsource/oswald/400.css';
import '@fontsource/oswald/500.css';
import '@fontsource/oswald/700.css';
import '@fontsource/readex-pro/400.css';
import '@fontsource/readex-pro/500.css';
import '@fontsource/readex-pro/700.css';
import '@fontsource/roboto/400.css';
import '@fontsource/roboto/500.css';
import '@fontsource/roboto/700.css';
import '@fontsource/zen-kaku-gothic-new/400.css';
import '@fontsource/zen-kaku-gothic-new/500.css';
import '@fontsource/zen-kaku-gothic-new/700.css';
import Meta from '../components/common/Meta.astro';
import '../styles/main.scss';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<Meta
			{...title && { title }}
			{...description && { description }}
			{...ogImage && { ogImage }}
		/>

		<!-- Google Tag Manager -->

		<!--::::::::::::::::::::::::::::::::::::::::::::
			RequireMobile
		::::::::::::::::::::::::::::::::::::::::::::-->
		<meta
			name="viewport"
			content="initial-scale=1, minimum-scale=1, maximum-scale=5"
		/>
		<meta name="format-detection" content="telephone=no" />
		<meta name="msapplication-tap-highlight" content="no" />
		<!--::::::::::::::::::::::::::::::::::::::::::::
			WebFont - fontsource でセルフホスト（フロントマターでimport）
			Zen Kaku Gothic New / Noto Sans JP / Oswald / Readex Pro / Roboto
		::::::::::::::::::::::::::::::::::::::::::::-->

		<!-- スクロールアニメーション用のスタイル -->
		<style is:inline>
			.js-animation {
				opacity: 0;
				visibility: hidden;
				will-change: transform, opacity;
			}

			@media (prefers-reduced-motion: reduce) {
				.js-animation {
					opacity: 1 !important; /* stylelint-disable-line declaration-no-important -- a11y reduced-motion override */
					visibility: visible !important; /* stylelint-disable-line declaration-no-important -- a11y reduced-motion override */
					transform: none !important; /* stylelint-disable-line declaration-no-important -- a11y reduced-motion override */
					transition: none !important; /* stylelint-disable-line declaration-no-important -- a11y reduced-motion override */
				}
			}
		</style>

		<!-- GSAP ローカルから読み込み（メンテナンス性向上）-->
		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			// ScrollTriggerプラグインを登録
			gsap.registerPlugin(ScrollTrigger);

			// グローバルに登録（既存のコードとの互換性のため）
			if (typeof window !== 'undefined') {
				(window as any).gsap = gsap;
				(window as any).ScrollTrigger = ScrollTrigger;
			}
		</script>

		<!-- ページ固有のpreloadやheadコンテンツを注入 -->
		<slot name="head" />

		<!-- クラス・IDはビルド時に自動付与されます -->
	</head>
	<body>
		<div class="l-wrapper">
			<main class="l-container">
				<slot />
			</main>
		</div>
	</body>
</html>
<style lang="scss">
	@use '../styles/foundation/index' as *;
</style>
