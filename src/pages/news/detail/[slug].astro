---
import { parse } from 'node-html-parser';

import ArrowButton from '../../../components/button/ArrowButton.astro';
import OptImage from '../../../components/common/OptImage.astro';
import { siteMetadata } from '../../../data/meta';
import watermark from '../../../images/keitasplan/common/logo_S.svg?raw';
import Footer from '../../../layouts/Footer.astro';
import Header from '../../../layouts/Header.astro';
import Layout from '../../../layouts/Layout.astro';
import { MICROCMS_ASSETS_HOST } from '../../../lib/constants.js';
import {
	cmsImageSize,
	getAllNews,
	getMicroCMSImage,
} from '../../../lib/microcms';
import { formatDotDate } from '../../../utils/date';

export async function getStaticPaths() {
	const news = await getAllNews({ orders: '-date' });
	return news.map((item) => ({
		params: { slug: item.id },
		props: { item },
	}));
}

const { item } = Astro.props;

// リッチテキスト本文のビルド時整形
// 1. idの重複解消: microCMSは見出しにアンカーidを付与するが、エディタ上で
//    ブロックを複製すると同じidが重複しhtml-validate(no-dup-id)で落ちる。
//    2回目以降の出現に連番を振って一意にする（最初のアンカーはそのまま維持）。
// 2. 画像最適化: 本文内のmicroCMS画像に画像APIパラメータを付与（表示幅540の2倍でWebP化）
const transformBody = (html: string) => {
	const root = parse(html);

	const used = new Set<string>();
	for (const el of root.querySelectorAll('[id]')) {
		const id = el.getAttribute('id');
		if (!id) continue;
		if (!used.has(id)) {
			used.add(id);
			continue;
		}
		let n = 2;
		while (used.has(`${id}-${n}`)) n++;
		el.setAttribute('id', `${id}-${n}`);
		used.add(`${id}-${n}`);
	}

	for (const img of root.querySelectorAll('img')) {
		const src = img.getAttribute('src');
		if (
			src?.startsWith(`https://${MICROCMS_ASSETS_HOST}/`) &&
			!src.includes('?')
		) {
			img.setAttribute('src', getMicroCMSImage(src, 1080));
		}
	}

	// テーブルはSPで横スクロールできるようwrapperで囲む
	for (const table of root.querySelectorAll('table')) {
		table.replaceWith(
			`<div class="table-wrapper">${table.toString()}</div>`
		);
	}

	// 埋め込み（YouTube等）: レスポンシブ比率のwrapper divへ余白用クラスを付与。
	// titleが無いiframeはアクセシビリティ（およびhtml-validate）のため補完する
	for (const iframe of root.querySelectorAll('iframe')) {
		if (!iframe.getAttribute('title')) {
			iframe.setAttribute('title', '埋め込みコンテンツ');
		}
		// 埋め込みHTMLに含まれる非推奨属性（html-validateで弾かれる）を除去
		iframe.removeAttribute('scrolling');
		const parent = iframe.parentNode;
		if (parent?.tagName === 'DIV') {
			parent.classList.add('embed-wrapper');
		}
	}

	return root.toString();
};

const body = item.body ? transformBody(item.body) : undefined;
---

<Layout title={`${item.title} | ニュース・催事情報 | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<section class="p-news-detail">
		<span
			class="p-news-detail__mark"
			aria-hidden="true"
			set:html={watermark}
		/>
		<div class="p-news-detail__hero">
			<h1 class="p-news-detail__title">{item.title}</h1>
			{
				item.image && (
					<span class="p-news-detail__photo">
						<OptImage
							class="p-news-detail__img"
							src={item.image.url}
							priority
							{...cmsImageSize(item.image, 880)}
						/>
					</span>
				)
			}
		</div>
		<div class="p-news-detail__card">
			<article class="p-news-detail__article">
				<time
					class="p-news-detail__date"
					datetime={item.date.slice(0, 10)}
				>
					{formatDotDate(item.date)}
				</time>
				{body && <div class="p-news-detail__body" set:html={body} />}
			</article>
		</div>
		<div class="p-news-detail__more">
			<ArrowButton
				href="/news"
				label="すべてのお知らせをみる"
				variant="blue"
				size="lg"
			/>
		</div>
	</section>
	<Footer id="footer" variant="subpage" />
</Layout>

<style lang="scss">
	.p-news-detail {
		position: relative;
		overflow: hidden;
		padding: size(234) 0 size(86);

		@include mq('sp') {
			padding: size(183) 0 size(120);
		}

		&__mark {
			position: absolute;
			top: size(120);
			left: size(-73);
			width: size(469);
			height: size(469);
			pointer-events: none;

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}

			@include mq('sp') {
				left: size(-99);
				width: size(634);
				height: size(634);
			}
		}

		&__hero {
			position: relative;
			min-height: size(273);

			@include mq('sp') {
				min-height: 0;
				width: size(650);
				margin-inline: auto;
			}
		}

		&__title {
			max-width: size(734);
			margin-left: size(108);
			font-family: $Font;
			font-weight: 500;
			font-size: size(50);
			line-height: 1.4;
			letter-spacing: size(5);
			color: $brand-text;

			@include mq('sp') {
				max-width: none;
				margin-left: 0;
				font-size: size(44);
				letter-spacing: size(2.2);
			}
		}

		&__photo {
			position: absolute;
			top: size(13);
			right: size(112);
			display: block;
			width: size(440);
			height: size(260);
			border-radius: size(10);
			overflow: hidden;

			@include mq('sp') {
				position: static;
				width: 100%;
				height: size(364);
				margin-top: size(40);
			}
		}

		&__card {
			margin-top: size(71);
			padding: size(88) 0 size(94);
			border-radius: size(130);
			background: linear-gradient(0deg, #fff -53.33%, #e9e9e9 100%);

			@include mq('sp') {
				margin-top: size(60);
				padding: size(120) 0;
			}
		}

		&__article {
			width: size(1050);
			margin-inline: auto;

			@include mq('sp') {
				width: size(650);
			}
		}

		&__date {
			display: block;
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.6;
			letter-spacing: size(0.54);
			color: #000;

			@include mq('sp') {
				font-size: size(28);
			}
		}

		&__body {
			margin-top: size(12);
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.6;
			letter-spacing: size(0.54);
			text-align: justify;
			overflow-wrap: break-word;
			color: $brand-text;

			@include mq('sp') {
				margin-top: size(16);
				font-size: size(30);
			}

			// CMSリッチテキスト（クラス付与不可）のための整形
			// h1はFigmaの「見出し」スタイル。h2〜h5はサイト内の見出し語彙から降順で独自設計
			:global(h1) {
				margin-bottom: size(39);
				padding-bottom: size(20);
				border-bottom: 1px solid $brand-text;
				font-weight: 700;
				font-size: size(40);
				line-height: 1.6;
				letter-spacing: size(1.2);
				text-align: left;

				@include mq('sp') {
					margin-bottom: size(40);
					padding-bottom: size(24);
					font-size: size(44);
				}
			}

			:global(h1:not(:first-child)) {
				margin-top: size(60);
			}

			// h2〜h5: サイズ違いの太字（装飾なし）
			:global(h2) {
				margin-bottom: size(30);
				font-weight: 700;
				font-size: size(32);
				line-height: 1.5;
				letter-spacing: size(0.96);
				text-align: left;

				@include mq('sp') {
					font-size: size(40);
				}
			}

			:global(h2:not(:first-child)) {
				margin-top: size(60);
			}

			:global(h3) {
				margin-bottom: size(20);
				font-weight: 700;
				font-size: size(26);
				line-height: 1.5;
				letter-spacing: size(0.78);
				text-align: left;

				@include mq('sp') {
					font-size: size(36);
				}
			}

			:global(h3:not(:first-child)) {
				margin-top: size(50);
			}

			:global(h4) {
				margin-bottom: size(16);
				font-weight: 700;
				font-size: size(22);
				line-height: 1.5;
				text-align: left;

				@include mq('sp') {
					font-size: size(34);
				}
			}

			:global(h4:not(:first-child)) {
				margin-top: size(40);
			}

			:global(h5) {
				margin-bottom: size(12);
				font-weight: 700;
				font-size: size(18);
				line-height: 1.6;
				text-align: left;

				@include mq('sp') {
					font-size: size(30);
				}
			}

			:global(h5:not(:first-child)) {
				margin-top: size(32);
			}

			:global(p + p) {
				margin-top: size(24);
			}

			:global(figure) {
				margin: size(50) 0 size(30);
			}

			:global(img) {
				display: block;
				max-width: size(540);
				height: auto;
				border-radius: size(10);

				@include mq('sp') {
					max-width: 100%;
				}
			}

			:global(a) {
				color: #000;
				text-decoration: underline;
				text-underline-position: from-font;
			}

			// リスト（リセットで消えるマーカーとfont-size: 0を復元）
			:global(ul),
			:global(ol) {
				margin-top: size(24);
				padding-left: size(28);
				font-size: inherit;

				@include mq('sp') {
					padding-left: size(44);
				}
			}

			:global(li) {
				font-size: inherit;
			}

			:global(ul) {
				list-style: disc;
			}

			:global(ol) {
				list-style: decimal;
			}

			:global(ul ul) {
				margin-top: 0;
				list-style: circle;
			}

			// テーブル（transformBodyで.table-wrapperに包まれる）
			:global(.table-wrapper) {
				margin-top: size(24);
				overflow-x: auto;
			}

			:global(table) {
				width: 100%;
				border-collapse: collapse;

				// SP: セルは折り返しつつ、潰れないよう最低幅を確保して横スクロール
				@include mq('sp') {
					min-width: size(1100);
				}
			}

			:global(th),
			:global(td) {
				padding: size(10) size(16);
				border: 1px solid #ccc;
				background-color: $brand-white;
				font-size: inherit;
				text-align: left;
				vertical-align: top;

				@include mq('sp') {
					padding: size(16) size(20);
				}
			}

			:global(th) {
				background-color: #dfefff;
				font-weight: 700;
				text-align: center;
				white-space: nowrap;
			}

			// 引用（左バー＋インデントのシンプルな引用表現）
			:global(blockquote) {
				margin-top: size(24);
				padding-left: size(20);
				border-left: size(4) solid $brand-blue;

				@include mq('sp') {
					padding-left: size(30);
					border-left-width: size(6);
				}
			}

			// 埋め込み（角丸・余白は本文画像と揃える）
			:global(.embed-wrapper) {
				margin: size(50) 0 size(30);
				border-radius: size(10);
				overflow: hidden;
			}

			:global(figcaption) {
				margin-top: size(10);
				font-size: size(14);
				color: #666;

				@include mq('sp') {
					font-size: size(24);
				}
			}

			// カスタムclass「arrow-button」: 白ArrowButton（c-arrowBtn --white --md）のCSS版
			// リンクに適用すると <a><span class="arrow-button">…</span></a> の形で出力される
			:global(.arrow-button) {
				@include ty-button;

				position: relative;
				isolation: isolate;
				display: inline-flex;
				align-items: center;
				margin-top: size(24);
				padding: size(12) size(66) size(16) size(54);
				border-radius: 999px;
				background-color: $brand-white;
				box-shadow: 0 size(4) size(20) rgba($brand-blue, 0.12);
				color: $brand-text;

				@include mq('sp') {
					padding: size(21) size(125) size(26) size(90);
					font-size: size(33);
				}
			}

			// ホバー時のグラデーション（component版の::afterフェードと同じ表現）
			:global(.arrow-button::before) {
				content: '';
				position: absolute;
				inset: 0;
				z-index: -1;
				border-radius: 999px;
				background: linear-gradient(90deg, #fff 0%, #dfefff 100%);
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			// 矢印アイコン（青丸＋白矢印）
			:global(.arrow-button::after) {
				content: '';
				position: absolute;
				top: 50%;
				right: size(15);
				width: size(29);
				height: size(29);
				border-radius: 50%;
				background-color: $brand-blue;
				background-image: url('../../../images/keitasplan/common/arrow.svg');
				background-repeat: no-repeat;
				background-position: center;
				background-size: size(17) size(15);
				transform: translateY(-50%);
				transition: transform 0.3s ease;

				@include mq('sp') {
					right: size(20);
					width: size(65);
					height: size(65);
					background-size: size(38) size(34);
				}
			}

			@media (hover: hover) and (pointer: fine) {
				:global(a:hover .arrow-button::before) {
					opacity: 1;
				}

				:global(a:hover .arrow-button::after) {
					transform: translateY(-50%) translateX(#{size(2)});
				}
			}
		}

		&__more {
			display: flex;
			justify-content: center;
			margin-top: size(76);

			@include mq('sp') {
				margin-top: size(80);
			}
		}
	}
</style>
