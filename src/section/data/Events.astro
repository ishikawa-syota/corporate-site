---
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import StatValue from '../../components/common/StatValue.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';
import calendar from '../../images/keitasplan/data/calendar.svg';
import store from '../../images/keitasplan/data/store.svg';
import visitors from '../../images/keitasplan/data/visitors.svg';

interface Props {
	id?: string;
	annualEventCount: string;
	totalStoreCount: string;
	annualVisitorCount: string;
}
const { id, annualEventCount, totalStoreCount, annualVisitorCount } =
	Astro.props;
---

<section class="p-data-events" id={id}>
	<div class="p-data-events__inner">
		<VerticalLabel text="SERVICE RECORD - EVENTS" />
		<div class="p-data-events__body">
			<DataSectionHead ja="催事買取の実績" />
			<ul class="p-data-events__grid">
				<li class="p-data-events__cell">
					<div class="p-data-events__card">
						<span
							class="p-data-events__illust p-data-events__illust--calendar"
							aria-hidden="true"
						>
							<img src={calendar.src} alt="" />
						</span>
						<div class="p-data-events__text">
							<p class="p-data-events__label">年間催事開催件数</p>
							<StatValue value={annualEventCount} unit="件超" />
							<p class="p-data-events__caption">定期開催を含む</p>
						</div>
					</div>
				</li>

				<li class="p-data-events__cell">
					<div class="p-data-events__card">
						<span
							class="p-data-events__illust p-data-events__illust--store"
							aria-hidden="true"
						>
							<img src={store.src} alt="" />
						</span>
						<div class="p-data-events__text">
							<p class="p-data-events__label">累計出店実績</p>
							<StatValue value={totalStoreCount} unit="店舗" />
							<p class="p-data-events__caption">
								提携先の延べ店舗数
							</p>
						</div>
					</div>
				</li>

				<li class="p-data-events__cell p-data-events__cell--wide">
					<div class="p-data-events__card p-data-events__card--wide">
						<span
							class="p-data-events__illust p-data-events__illust--visitors"
							aria-hidden="true"
						>
							<img src={visitors.src} alt="" />
						</span>
						<div class="p-data-events__text">
							<p class="p-data-events__label">年間来場者数</p>
							<StatValue value={annualVisitorCount} unit="名" />
							<p class="p-data-events__caption">全催事合計</p>
						</div>
					</div>
				</li>
			</ul>
		</div>
	</div>
</section>

<style lang="scss">
	.p-data-events {
		position: relative;

		&__inner {
			display: flex;
			align-items: stretch;
			gap: size(81);
			margin-inline: auto;
			padding-inline: size(128) size(243);

			@include mq('sp') {
				padding-inline: size(45) size(94);
			}
		}

		&__body {
			flex: 1;
			min-width: 0;
		}

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: size(60) size(42);
			margin-top: size(100);

			@include mq('sp') {
				grid-template-columns: minmax(0, 1fr);
				gap: size(70);
			}
		}

		&__cell {
			min-width: 0;

			&--wide {
				grid-column: 1 / -1;
			}
		}

		// --- カード ---
		&__card {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: size(12);
			height: 100%;
			min-height: size(374);
			padding: size(36) size(40);
			background: $brand-white;
			border-radius: size(7);

			// 年間来場者数: PCは横並び（イラスト左+テキスト右）、SPは縦積み
			&--wide {
				flex-direction: row;
				justify-content: center;
				gap: size(72);

				@include mq('sp') {
					flex-direction: column;
					align-items: center;
					gap: size(12);
				}
			}
		}

		&__illust {
			display: block;
			flex-shrink: 0;

			img {
				display: block;
				width: 100%;
				height: 100%;
			}

			&--calendar {
				width: size(248);
				height: size(122);
			}

			&--store {
				width: size(142);
				height: size(128);
			}

			&--visitors {
				width: size(344);
				height: size(234);

				@include mq('sp') {
					width: size(177);
					height: size(121);
				}
			}
		}

		&__text {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		&__label {
			font-family: $Font;
			font-weight: 700;
			font-size: size(35);
			line-height: 1.4;
			letter-spacing: size(1.05);
			color: $brand-text;

			@include mq('sp') {
				font-size: size(40);
			}
		}

		&__caption {
			margin-top: size(8);
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(24);
			}
		}
	}
</style>
