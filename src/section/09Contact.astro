---
import { processImages } from "../styles/images";

interface Props {
  id?: string;
  class?: string;
}

const { id } = Astro.props;



const imageStyles = await processImages({});
---

<section class="p-top-contact" id={id} style={imageStyles}>
  <div class="l-inner-l">

    <div class="p-top-contact__form">
        <form id="diagnostic-form" action="./mail.php" method="POST" class="p-top-contact__form-element">
        <div class="p-top-contact__inner">
          
          <!-- セキュリティフィールド（ハニーポット・タイムスタンプ） -->
          <input type="text" name="website" id="website" style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="form_timestamp" id="form_timestamp" value="" />
          
  
          <!-- 個人情報入力フォーム -->
          <div class="p-top-contact__personal-form">
            <div class="p-top-contact__field">
              <label for="name" class="p-top-contact__label">お名前</label>
              <input type="text" id="name" name="name" class="p-top-contact__input" placeholder="山田太郎" />
            </div>
            
            <div class="p-top-contact__field">
              <label for="phone" class="p-top-contact__label">お電話番号</label>
              <input type="tel" id="phone" name="phone" class="p-top-contact__input" placeholder="09012345678" required/>
            </div>
            
            <div class="p-top-contact__field">
              <label for="email" class="p-top-contact__label">メールアドレス（任意）</label>
              <input type="email" id="email" name="email" class="p-top-contact__input" placeholder="you@example.co.jp" required/>
            </div>
          </div>
  
          <!-- プライバシーポリシー -->
          <div class="p-top-contact__privacy">
            <label class="p-top-contact__privacy-label">
              <input type="checkbox" name="privacy_agree" id="privacy_agree" class="p-top-contact__privacy-checkbox" required/>
              <span class="p-top-contact__privacy-checkmark"></span>
              <span>当社規定の<a href="https://www.tennoji-law.jp/shienkin/policy/" target="_blank">プライバシーポリシー</a>への同意します。</span>
            </label>
          </div>
  
          <!-- 診断ボタン -->
          <div class="p-top-contact__submit">
            <button type="submit" class="p-top-contact__submit-button">
              <span class="p-top-contact__submit-text">診断する</span>
             
            </button>
          </div>
          <small class="p-top-contact__submit-small u-sp-only">
            ※ボタンをクリックするとフォームが送信されます
          </small>
        </div>
        </form>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/foundation/index" as *;
  
</style>

<!-- フォーム処理をモジュール化して読み込み -->
<script src="../scripts/contactForm.ts"></script>