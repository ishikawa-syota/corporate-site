---
import Picture from '../../components/common/Picture.astro';
import logoS from '../../images/keitasplan/common/logo_S.svg?raw';
import mark from '../../images/keitasplan/common/mark.svg?raw';
import relatedDataPc from '../../images/keitasplan/common/related-data-pc.png';
import relatedDataSp from '../../images/keitasplan/common/related-data-sp.png';
import relatedMembersPc from '../../images/keitasplan/common/related-members-pc.png';
import relatedMembersSp from '../../images/keitasplan/common/related-members-sp.png';
import relatedVoicePc from '../../images/keitasplan/common/related-voice-pc.png';
import relatedVoiceSp from '../../images/keitasplan/common/related-voice-sp.png';

interface Card {
	ja: string;
	en: string;
	desc: string;
	href: string;
	bgPc?: ImageMetadata;
	bgSp?: ImageMetadata;
}
interface Props {
	id?: string;
	cards?: Card[];
}

const defaultCards: Card[] = [
	{
		ja: '数字で見る<br>ケイタスプラン',
		en: 'DATA',
		desc: '実績・数字で信頼を証明します。',
		href: '/data',
		bgPc: relatedDataPc,
		bgSp: relatedDataSp,
	},
	{
		ja: 'お客様の声',
		en: 'VOICE',
		desc: '実際にご利用いただいた方の声。',
		href: '/voices',
		bgPc: relatedVoicePc,
		bgSp: relatedVoiceSp,
	},
	{
		ja: 'メンバー',
		en: 'MEMBERS',
		desc: 'この会社を動かす人たち。',
		href: '/members',
		bgPc: relatedMembersPc,
		bgSp: relatedMembersSp,
	},
];

const { id, cards = defaultCards } = Astro.props;
---

<section class="p-related" id={id}>
	<div class="p-related__inner">
		<div class="p-related__head">
			<span class="p-related__mark" aria-hidden="true" set:html={mark} />
			<span class="p-related__titles">
				<span class="p-related__ja">関連情報</span>
				<span class="p-related__en">RELATED</span>
			</span>
		</div>

		<ul class="p-related__cards">
			{
				cards.map((c) => (
					<li class="p-related__card">
						{c.bgPc && c.bgSp ? (
							<span class="p-related__cardBg" aria-hidden="true">
								<Picture src={c.bgPc} srcSp={c.bgSp} alt="" />
							</span>
						) : (
							<span
								class="p-related__cardMark"
								aria-hidden="true"
								set:html={logoS}
							/>
						)}
						<a class="p-related__cardLink" href={c.href}>
							<span
								class="p-related__cardTitle"
								set:html={c.ja}
							/>
							<span class="p-related__cardEn">{c.en}</span>
							<span class="p-related__cardDesc">{c.desc}</span>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style lang="scss">
	.p-related {
		position: relative;
		background-color: $brand-white;

		&__inner {
			max-width: size(1051);
			margin-inline: auto;
			padding: size(166) 0 size(256);
			display: flex;
			flex-direction: column;
			gap: size(78);

			@include mq('sp') {
				max-width: size(580);
				padding: size(114) 0 size(123);
				gap: size(50);
			}
		}

		// --- 見出し ---
		&__head {
			display: flex;
			align-items: flex-start;
		}

		&__mark {
			flex-shrink: 0;
			width: size(91);
			height: size(91);
			margin-top: size(8);

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}
		}

		&__titles {
			display: flex;
			flex-direction: column;
			gap: size(3);
		}

		&__ja {
			font-family: $Font;
			font-weight: 500;
			font-size: size(60);
			line-height: 1.4;
			letter-spacing: size(6);
			color: $brand-text;
			padding-inline: size(15);

			@include mq('sp') {
				font-size: size(60);
			}
		}

		&__en {
			font-family: $Font-Readex;
			font-weight: 500;
			font-size: size(18);
			line-height: 1.4;
			letter-spacing: size(1.8);
			color: $brand-text;
			padding-inline: size(24);

			@include mq('sp') {
				font-size: size(20);
			}
		}

		// --- カード ---
		&__cards {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: size(41);

			@include mq('sp') {
				grid-template-columns: 1fr;
				gap: size(45);
			}
		}

		&__card {
			position: relative;
			border-radius: size(10);
			overflow: hidden;

			// グラデ背景（CSS）。上に半透明写真オーバーレイ（&__cardBg）が重なる
			background: linear-gradient(
				180deg,
				$brand-blue 0%,
				$brand-blue-pale 100%
			);
			transition: opacity 0.3s ease;

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					opacity: 0.8;
				}
			}
		}

		&__cardBg {
			position: absolute;
			inset: 0;
			z-index: 0;

			:global(picture),
			:global(img) {
				display: block;
				width: 100%;
				height: 100%;
			}

			:global(img) {
				object-fit: cover;
			}
		}

		&__cardMark {
			position: absolute;
			top: 26.84%;
			left: 39.94%;
			z-index: 0;
			width: 69.35%;
			height: 91.8%;
			opacity: 0.3;
			pointer-events: none;

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}

			:global(path) {
				fill: $brand-white;
				fill-opacity: 1;
			}
		}

		&__cardLink {
			position: relative;
			z-index: 1;
			display: flex;
			flex-direction: column;
			gap: size(8);
			height: size(244);
			padding: size(48) size(41);

			@include mq('sp') {
				height: size(280);
			}
		}

		&__cardTitle {
			font-family: $Font;
			font-weight: 500;
			font-size: size(24);
			line-height: 1.4;
			color: $brand-white;

			@include mq('sp') {
				font-size: size(34);
			}
		}

		&__cardEn {
			font-family: $Font-Readex;
			font-weight: 400;
			font-size: size(14);
			line-height: 1.4;
			letter-spacing: size(2.8);
			color: $brand-white;

			@include mq('sp') {
				font-size: size(20);
			}
		}

		&__cardDesc {
			font-family: $Font;
			font-weight: 400;
			font-size: size(14);
			line-height: 1.4;
			color: $brand-white;

			@include mq('sp') {
				font-size: size(22);
			}
		}
	}
</style>
