---
// 矢印付きピルボタン（Figma: button1 / button1_s / button2 / button_saiyou）
// variant でサイズ・配色を切り替え、どこでも流用できる汎用ボタン
import arrow from '../../images/keitasplan/common/arrow.svg?raw';

interface Props {
	href?: string;
	label: string;
	variant?: 'white' | 'blue';
	size?: 'md' | 'sm' | 'lg';
	class?: string;
}

const {
	href = '#',
	label,
	variant = 'white',
	size = 'md',
	class: className,
} = Astro.props;
---

<a
	href={href}
	class:list={[
		'c-arrowBtn',
		`c-arrowBtn--${variant}`,
		`c-arrowBtn--${size}`,
		className,
	]}
>
	<span class="c-arrowBtn__label">{label}</span>
	<span class="c-arrowBtn__icon" aria-hidden="true" set:html={arrow} />
</a>

<style lang="scss">
	.c-arrowBtn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: size(15);
		width: fit-content;
		padding: size(12) size(66) size(16) size(54);
		border-radius: 999px;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			background-color 0.3s ease;

		@include mq('sp') {
			padding: size(21) size(125) size(26) size(90);
		}

		@media (hover: hover) and (pointer: fine) {
			&:hover {
				&::after {
					opacity: 1;
				}

				.c-arrowBtn__icon {
					transform: translateX(#{size(2)});
				}
			}
		}

		&::after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: linear-gradient(90deg, #fff 0%, #dfefff 100%);
			opacity: 0;
			transition: opacity 0.3s ease;
			border-radius: calc(1px / 0);
		}

		&__label {
			@include ty-button;

			position: relative;
			z-index: 1;
			font-size: size(15);
			font-weight: 500;

			@include mq('sp') {
				font-size: size(33);
			}
		}

		&__icon {
			position: absolute;
			z-index: 1;
			right: size(15);
			width: size(29);
			height: size(29);
			background-color: $brand-blue;
			border-radius: 50%;
			display: grid;
			place-items: center;
			transition: transform 0.3s ease;

			@include mq('sp') {
				right: size(20);
				width: size(65);
				height: size(65);
			}

			:global(svg) {
				display: block;
				width: size(17);
				height: size(15);

				@include mq('sp') {
					width: size(38);
					height: size(34);
				}
			}
		}

		// --- 配色バリアント ---
		&--white {
			background-color: $brand-white;
			box-shadow: 0 size(4) size(20) rgba($brand-blue, 0.12);

			.c-arrowBtn__label {
				color: $brand-text;
			}
		}

		&--blue {
			background: $brand-gradient;
			padding: size(12) size(58) size(16) size(32);

			@include mq('sp') {
				padding: size(22) size(107) size(25) size(80);
			}

			.c-arrowBtn__label {
				font-size: size(20);
				color: $brand-white;

				@include mq('sp') {
					font-size: size(33);
				}
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover .c-arrowBtn__icon {
					transform: translateX(#{size(6)});

					@include mq('sp') {
						transform: translateX(#{size(10)});
					}
				}
			}

			// ホバー時はグラデーション→単色ブルーへ（::afterのフェードで表現）
			&::after {
				background: $brand-blue;
			}

			.c-arrowBtn__icon {
				background-color: $brand-white;
			}

			.c-arrowBtn__icon :global(path) {
				fill: $brand-blue;
			}

			:global(svg) {
				display: block;
				width: size(16);
				height: size(14);

				@include mq('sp') {
					width: size(25);
					height: size(22);
				}
			}
		}

		// --- サイズバリアント ---
		&--lg {
			padding: size(24) size(52) size(24) size(40);

			@include mq('sp') {
				padding: size(22) size(107) size(25) size(80);
			}
		}

		&--sm {
			padding: size(8) size(45) size(10) size(20);

			@include mq('sp') {
				padding: size(16) size(86) size(19) size(43);
			}

			.c-arrowBtn__icon {
				right: size(12);
			}
		}
	}
</style>
