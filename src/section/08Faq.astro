---
import FaqItem from '../components/card/FaqItem.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import { faqs } from '../data/siteContent';

interface Props {
  id?: string;
}
const { id } = Astro.props;
---

<section class="p-faq" id={id}>
  <div class="p-faq__inner">
    <SectionHeading ja="よくある質問" en="FAQ" class="p-faq__heading" />
    <div class="p-faq__list">
      {faqs.map((item) => (
        <FaqItem q={item.q} a={item.a} />
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundation/index' as *;

  // Figma: 上角丸130px / 白背景 / py98 / 前セクション(Message)のグレーに重なるカード表現
  .p-faq {
    position: relative;
    z-index: 1;
    background: $brand-white;
    border-top-left-radius: size(130);
    border-top-right-radius: size(130);
    padding-block: size(98);
    margin-top: size(-80);
    overflow: clip;

    @include mq('sp') {
      border-top-left-radius: size(80);
      border-top-right-radius: size(80);
      padding-block: size(64);
      margin-top: size(-48);
    }

    &__inner {
      max-width: size(1050);
      margin-inline: auto;
      padding-inline: size(24);
    }

    // Figma: 見出し→リスト gap 85 / 上端に区切り線 / 項目間 gap 43
    &__list {
      display: flex;
      flex-direction: column;
      gap: size(43);
      margin-top: size(85);
      padding-top: size(40);
      border-top: 1px solid rgba($brand-text, 0.2);

      @include mq('sp') {
        gap: size(48);
        margin-top: size(48);
        padding-top: size(48);
      }
    }
  }
</style>
