---
import ArrowButton from '../../../components/button/ArrowButton.astro';
import { siteMetadata } from '../../../data/meta';
import watermark from '../../../images/keitasplan/common/logo_S.svg?raw';
import Footer from '../../../layouts/Footer.astro';
import Header from '../../../layouts/Header.astro';
import Layout from '../../../layouts/Layout.astro';
import { getAllNews } from '../../../lib/microcms';
import { formatDotDate } from '../../../utils/date';

export async function getStaticPaths() {
	const news = await getAllNews({ orders: '-date' });
	return news.map((item) => ({
		params: { slug: item.id },
		props: { item },
	}));
}

const { item } = Astro.props;
---

<Layout title={`${item.title} | ニュース・催事情報 | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<section class="p-news-detail">
		<span
			class="p-news-detail__mark"
			aria-hidden="true"
			set:html={watermark}
		/>
		<div class="p-news-detail__hero">
			<h1 class="p-news-detail__title">{item.title}</h1>
			{
				item.image && (
					<span class="p-news-detail__photo">
						<img
							class="p-news-detail__img"
							src={`${item.image.url}?fm=webp&w=880`}
							alt=""
							width={item.image.width}
							height={item.image.height}
							decoding="async"
						/>
					</span>
				)
			}
		</div>
		<div class="p-news-detail__card">
			<article class="p-news-detail__article">
				<time
					class="p-news-detail__date"
					datetime={item.date.slice(0, 10)}
				>
					{formatDotDate(item.date)}
				</time>
				{
					item.body && (
						<div class="p-news-detail__body" set:html={item.body} />
					)
				}
			</article>
		</div>
		<div class="p-news-detail__more">
			<ArrowButton
				href="/news"
				label="すべてのお知らせをみる"
				variant="blue"
				size="lg"
			/>
		</div>
	</section>
	<Footer id="footer" variant="subpage" />
</Layout>

<style lang="scss">
	.p-news-detail {
		position: relative;
		overflow: hidden;
		padding: size(234) 0 size(86);

		@include mq('sp') {
			padding: size(183) 0 size(120);
		}

		&__mark {
			position: absolute;
			top: size(120);
			left: size(-73);
			width: size(469);
			height: size(469);
			pointer-events: none;

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}

			@include mq('sp') {
				left: size(-99);
				width: size(634);
				height: size(634);
			}
		}

		&__hero {
			position: relative;
			min-height: size(273);

			@include mq('sp') {
				min-height: 0;
				width: size(650);
				margin-inline: auto;
			}
		}

		&__title {
			max-width: size(734);
			margin-left: size(108);
			font-family: $Font;
			font-weight: 500;
			font-size: size(50);
			line-height: 1.4;
			letter-spacing: size(5);
			color: $brand-text;

			@include mq('sp') {
				max-width: none;
				margin-left: 0;
				font-size: size(44);
				letter-spacing: size(2.2);
			}
		}

		&__photo {
			position: absolute;
			top: size(13);
			right: size(112);
			display: block;
			width: size(440);
			height: size(260);
			border-radius: size(10);
			overflow: hidden;

			@include mq('sp') {
				position: static;
				width: 100%;
				height: size(364);
				margin-top: size(40);
			}
		}

		&__img {
			display: block;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		&__card {
			margin-top: size(71);
			padding: size(88) 0 size(94);
			border-radius: size(130);
			background: linear-gradient(0deg, #fff -53.33%, #e9e9e9 100%);

			@include mq('sp') {
				margin-top: size(60);
				padding: size(120) 0;
			}
		}

		&__article {
			width: size(1050);
			margin-inline: auto;

			@include mq('sp') {
				width: size(650);
			}
		}

		&__date {
			display: block;
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.6;
			letter-spacing: size(0.54);
			color: #000;

			@include mq('sp') {
				font-size: size(28);
			}
		}

		&__body {
			margin-top: size(12);
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.6;
			letter-spacing: size(0.54);
			text-align: justify;
			overflow-wrap: break-word;
			color: $brand-text;

			@include mq('sp') {
				margin-top: size(16);
				font-size: size(30);
			}

			// CMSリッチテキスト（クラス付与不可）のための整形
			// h1はFigmaの「見出し」スタイル。h2〜h5はサイト内の見出し語彙から降順で独自設計
			:global(h1) {
				margin-bottom: size(39);
				padding-bottom: size(20);
				border-bottom: 1px solid $brand-text;
				font-weight: 700;
				font-size: size(40);
				line-height: 1.6;
				letter-spacing: size(1.2);
				text-align: left;

				@include mq('sp') {
					margin-bottom: size(40);
					padding-bottom: size(24);
					font-size: size(44);
				}
			}

			:global(h1:not(:first-child)) {
				margin-top: size(60);
			}

			// h2〜h5: サイズ違いの太字（装飾なし）
			:global(h2) {
				margin-bottom: size(30);
				font-weight: 700;
				font-size: size(32);
				line-height: 1.5;
				letter-spacing: size(0.96);
				text-align: left;

				@include mq('sp') {
					font-size: size(40);
				}
			}

			:global(h2:not(:first-child)) {
				margin-top: size(60);
			}

			:global(h3) {
				margin-bottom: size(20);
				font-weight: 700;
				font-size: size(26);
				line-height: 1.5;
				letter-spacing: size(0.78);
				text-align: left;

				@include mq('sp') {
					font-size: size(36);
				}
			}

			:global(h3:not(:first-child)) {
				margin-top: size(50);
			}

			:global(h4) {
				margin-bottom: size(16);
				font-weight: 700;
				font-size: size(22);
				line-height: 1.5;
				text-align: left;

				@include mq('sp') {
					font-size: size(34);
				}
			}

			:global(h4:not(:first-child)) {
				margin-top: size(40);
			}

			:global(h5) {
				margin-bottom: size(12);
				font-weight: 700;
				font-size: size(18);
				line-height: 1.6;
				text-align: left;

				@include mq('sp') {
					font-size: size(30);
				}
			}

			:global(h5:not(:first-child)) {
				margin-top: size(32);
			}

			:global(p + p) {
				margin-top: size(24);
			}

			:global(figure) {
				margin: size(50) 0 size(30);
			}

			:global(img) {
				display: block;
				max-width: size(540);
				height: auto;
				border-radius: size(10);

				@include mq('sp') {
					max-width: 100%;
				}
			}

			:global(a) {
				color: #000;
				text-decoration: underline;
				text-underline-position: from-font;
			}
		}

		&__more {
			display: flex;
			justify-content: center;
			margin-top: size(76);

			@include mq('sp') {
				margin-top: size(80);
			}
		}
	}
</style>
