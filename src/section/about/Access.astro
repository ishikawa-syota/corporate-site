---
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';

const offices = [
	{
		name: '池袋本社',
		address: '〒171-0014<br />東京都豊島区池袋2丁目10-7 ビルディングK 7階',
		map: 'https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3238.6!2d139.707851!3d35.732839!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60188d1213b6cce7%3A0xfc6b5af8b712adf0!2z5qCq5byP5Lya56S-44Kx44Kk44K_44K544OX44Op44Oz!5e0!3m2!1sja!2sjp!4v1724139569090!5m2!1sja!2sjp',
	},
	{
		name: '水道橋支店',
		address: '〒113-0033<br />東京都文京区本郷2-15-12 T’sビル',
		map: 'https://www.google.com/maps/embed?pb=!1m13!1m8!1m3!1d3240.5!2d139.7592318!3d35.7043078!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMzXCsDQyJzE1LjUiTiAxMznCsDQ1JzMzLjkiRQ!5e0!3m2!1sja!2sjp!4v1740450120427!5m2!1sja!2sjp',
	},
	{
		name: '宇都宮支店',
		address:
			'〒321-0953<br />栃木県宇都宮市東宿郷5丁目1-16 ルーセントビル2階',
		map: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3204.8319770423564!2d139.906084276388!3d36.558164072317155!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x601f676f0a34c555%3A0x95752f16fa2df21e!2z44CSMzIxLTA5NTMg5qCD5pyo55yM5a6H6YO95a6u5biC5p2x5a6_6YO377yV5LiB55uu77yR4oiS77yR77yWIOODq-ODvOOCu-ODs-ODiOODk-ODqyAy6ZqO!5e0!3m2!1sja!2sjp!4v1724139707524!5m2!1sja!2sjp',
	},
];
---

<section class="p-access">
	<div class="p-access__inner">
		<VerticalLabel text="ACCESS" />
		<div class="p-access__body">
			<div class="p-access__head">
				<DataSectionHead ja="アクセス" />
			</div>
			<ul class="p-access__list">
				{
					offices.map((o) => (
						<li class="p-access__office">
							<div class="p-access__info">
								<h3 class="p-access__name">{o.name}</h3>
								<p
									class="p-access__addr"
									set:html={o.address}
								/>
							</div>
							<iframe
								class="p-access__map"
								src={o.map}
								title={`${o.name}の地図`}
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"
								allowfullscreen
							/>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>

<style lang="scss">
	.p-access {
		position: relative;
		margin-top: size(-$section-card-radius);
		background: linear-gradient(180deg, $brand-white 0%, #e9e9e9 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;

		&__inner {
			display: flex;
			align-items: stretch;
			width: size(1165);
			margin-inline: size(128) size(243);
			padding-block: size(156) size(194);

			@include mq('sp') {
				width: size(629);
				margin-inline: size(46) auto;
				padding-block: size(108) size(215);
			}
		}

		&__body {
			display: flex;
			flex: 1;
			margin-left: size(81);

			@include mq('sp') {
				flex-direction: column;
			}
		}

		&__head {
			flex-shrink: 0;
			width: size(306);

			@include mq('sp') {
				width: auto;
			}
		}

		&__list {
			display: flex;
			flex-direction: column;
			flex: 1;
			gap: size(81);

			@include mq('sp') {
				gap: size(77);
				margin-top: size(81);
			}
		}

		&__office {
			display: flex;
			align-items: flex-start;
			gap: size(36);

			@include mq('sp') {
				flex-direction: column;
			}
		}

		&__info {
			flex-shrink: 0;
			width: size(267);

			@include mq('sp') {
				width: 100%;
			}
		}

		&__name {
			padding-bottom: size(20);
			border-bottom: 1px solid $brand-blue;
			font-family: $Font;
			font-weight: 500;
			font-size: size(30);
			line-height: 1.4;
			color: $brand-text;
		}

		&__addr {
			padding-top: size(20);
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.4;
			text-align: justify;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(30);
			}
		}

		&__map {
			display: block;
			width: size(440);
			height: size(250);
			border: 0;

			@include mq('sp') {
				width: 100%;
			}
		}
	}
</style>
