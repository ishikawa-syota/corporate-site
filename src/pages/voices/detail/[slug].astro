---
import ArrowButton from '../../../components/button/ArrowButton.astro';
import OptImage from '../../../components/common/OptImage.astro';
import { siteMetadata } from '../../../data/meta';
import watermark from '../../../images/keitasplan/common/logo_S.svg?raw';
import quoteTriangle from '../../../images/keitasplan/common/quote-triangle.svg';
import Footer from '../../../layouts/Footer.astro';
import Header from '../../../layouts/Header.astro';
import Layout from '../../../layouts/Layout.astro';
import { cmsImageSize, getAllVoices } from '../../../lib/microcms';

export async function getStaticPaths() {
	const voices = await getAllVoices({ orders: 'system:default' });
	return voices.map((voice) => ({
		params: { slug: voice.id },
		props: { voice },
	}));
}

const { voice } = Astro.props;
---

<Layout title={`${voice.title} | お客様の声 | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<section class="p-voice-detail">
		<span
			class="p-voice-detail__mark"
			aria-hidden="true"
			set:html={watermark}
		/>
		<div class="p-voice-detail__inner">
			<article class="p-voice-detail__article">
				{
					voice.thumbnail && (
						<span class="p-voice-detail__photo">
							<OptImage
								src={voice.thumbnail.url}
								priority
								{...cmsImageSize(voice.thumbnail, 1480)}
							/>
						</span>
					)
				}
				<h1 class="p-voice-detail__head">
					<img
						class="p-voice-detail__quote"
						src={quoteTriangle.src}
						alt=""
						aria-hidden="true"
					/>
					<span class="p-voice-detail__headline">{voice.title}</span>
					<img
						class="p-voice-detail__quote p-voice-detail__quote--close"
						src={quoteTriangle.src}
						alt=""
						aria-hidden="true"
					/>
				</h1>
				<p class="p-voice-detail__meta">{voice.meta}</p>
				<p class="p-voice-detail__body">{voice.body}</p>
			</article>
			<div class="p-voice-detail__back">
				<ArrowButton href="/voices" label="一覧へ戻る" variant="blue" />
			</div>
		</div>
	</section>
	<Footer id="footer" variant="subpage" />
</Layout>

<style lang="scss">
	.p-voice-detail {
		position: relative;
		overflow: hidden;
		padding: size(224) 0 size(160);

		@include mq('sp') {
			padding: size(183) 0 size(160);
		}

		&__mark {
			position: absolute;
			top: size(120);
			left: size(-73);
			width: size(469);
			height: size(469);
			pointer-events: none;

			:global(svg) {
				display: block;
				width: 100%;
				height: 100%;
			}

			@include mq('sp') {
				left: size(-99);
				width: size(634);
				height: size(634);
			}
		}

		&__inner {
			position: relative;
			width: size(900);
			margin-inline: auto;

			@include mq('sp') {
				width: size(650);
			}
		}

		&__photo {
			display: block;
			height: size(380);
			margin-bottom: size(40);
			border-radius: size(10);
			overflow: hidden;

			@include mq('sp') {
				height: size(364);
			}
		}

		&__head {
			display: flex;
			align-items: flex-start;
			justify-content: center;
			gap: size(44);

			@include mq('sp') {
				gap: size(40);
			}
		}

		&__quote {
			display: block;
			flex-shrink: 0;
			width: size(28);
			height: size(28);

			@include mq('sp') {
				width: size(38);
				height: size(38);
			}

			&--close {
				align-self: flex-end;
				transform: rotate(180deg);
			}
		}

		&__headline {
			font-family: $Font;
			font-weight: 700;
			font-size: size(30);
			line-height: 1.5;
			text-align: center;
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(34);
			}
		}

		&__meta {
			margin-top: size(28);
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.4;
			letter-spacing: size(0.65);
			text-align: center;
			color: $brand-blue;

			@include mq('sp') {
				margin-top: size(36);
				font-size: size(25);
			}
		}

		&__body {
			margin-top: size(32);
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 2;
			text-align: justify;
			white-space: pre-line;
			overflow-wrap: break-word;
			color: $brand-text;

			@include mq('sp') {
				margin-top: size(40);
				font-size: size(30);
			}
		}

		&__back {
			display: flex;
			justify-content: center;
			margin-top: size(80);

			@include mq('sp') {
				margin-top: size(100);
			}
		}
	}
</style>
