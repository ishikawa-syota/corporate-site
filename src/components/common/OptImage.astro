---
// 単一ソースの最適化画像（AVIF/WebP生成 + object-fit cover）
// 固定枠内に流し込む用途。width指定で出力解像度を制御（巨大元画像の最適化）。
// srcにURL文字列（microCMS等のリモート画像）も渡せる。
// リモートはastro.config.mjsのimage.domainsに登録されたドメインのみビルド時に最適化される。
import { getImage } from 'astro:assets';

interface Props {
	src: ImageMetadata | string;
	alt?: string;
	class?: string;
	width?: number;
	// リモート画像でwidthを指定する場合はheightも指定（アスペクト比を保った縮小に必要）
	height?: number;
	priority?: boolean;
	fit?: 'cover' | 'contain';
}

const {
	src,
	alt = '',
	class: className,
	width,
	height,
	priority = false,
	fit = 'cover',
} = Astro.props;

// リモート画像で寸法未指定の場合はinferSizeで取得（ビルド時にダウンロードして判定）
const isRemote = typeof src === 'string';

const opt = (format: 'avif' | 'webp', quality: number) =>
	getImage({
		src,
		format,
		quality,
		...(width ? { width } : {}),
		...(height ? { height } : {}),
		...(isRemote && !(width && height) ? { inferSize: true } : {}),
	});

const avif = await opt('avif', 65);
const webp = await opt('webp', 75);
---

<picture class:list={['c-img', className]} style={`--img-fit:${fit}`}>
	<source srcset={avif.src} type="image/avif" />
	<source srcset={webp.src} type="image/webp" />
	<img
		src={webp.src}
		alt={alt}
		width={webp.attributes.width}
		height={webp.attributes.height}
		loading={priority ? 'eager' : 'lazy'}
		fetchpriority={priority ? 'high' : 'auto'}
		decoding="async"
	/>
</picture>

<style lang="scss">
	.c-img {
		display: block;
		width: 100%;
		height: 100%;

		img {
			display: block;
			width: 100%;
			height: 100%;
			object-fit: var(--img-fit, cover);
		}
	}
</style>
