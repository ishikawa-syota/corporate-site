---
interface Props {
  id: string;
  class?: string;
  title?: string;
  showCloseButton?: boolean;
}

const { 
  id,
  class: className,
  title,
  showCloseButton = true
} = Astro.props;
---

<div id={id} class={`c-modal ${className || ''}`} aria-hidden="true" role="dialog" aria-modal="true">
  <div class="c-modal__overlay" data-modal-overlay></div>
  <div class="c-modal__container">
    <div class="c-modal__content">
      {title && (
        <div class="c-modal__header">
          <h2 class="c-modal__title">{title}</h2>
          {showCloseButton && (
            <button class="c-modal__close" data-modal-close aria-label="モーダルを閉じる">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          )}
        </div>
      )}
      <div class="c-modal__body">
        <slot />
      </div>
      {!title && showCloseButton && (
        <button class="c-modal__close c-modal__close--absolute" data-modal-close aria-label="モーダルを閉じる">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      )}
    </div>
  </div>
</div>

<style lang="scss">
  @use "sass:map";
  @use "../../styles/foundation/index" as *;
  
  .c-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: fluid(20);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    
    &.is-open {
      opacity: 1;
      visibility: visible;
      
      .c-modal__content {
        transform: scale(1);
      }
    }
    
    &__overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      cursor: pointer;
    }
    
    &__container {
      position: relative;
      width: fit-content;
      max-width: fluid(1200);
      max-height: 90vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    &__content {
      position: relative;
      width: 100%;
      max-height: 90vh;
      // background: #fff;
      border-radius: fluid(16);
      box-shadow: 0 fluid(20) fluid(40) rgba(0, 0, 0, 0.2);
      overflow: hidden;
      transform: scale(0.9);
      transition: transform 0.3s ease;
      display: flex;
      flex-direction: column;
      @media screen and (max-width: 960px) {
        border-radius: fluid-sp(16);
        box-shadow: 0 fluid-sp(20) fluid-sp(40) rgba(0, 0, 0, 0.2);
      }
    }
    
    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: fluid(24) fluid(32);
      border-bottom: 1px solid #e5e7eb;
      flex-shrink: 0;
      @media screen and (max-width: 960px) {
        padding: fluid-sp(24) fluid-sp(24);
      }
    }
    
    &__title {
      font-size: fluid(24);
      font-weight: bold;
      color: design-color("gray", "900");
      margin: 0;
      line-height: 1.4;
      @media screen and (max-width: 960px) {
        font-size: fluid-sp(24);
      }
    }
    
    &__close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: fluid(40);
      height: fluid(40);
      border: none;
      background: #fff;
      color: design-color("gray", "600");
      cursor: pointer;
      border-radius: 50%;
      transition: all 0.2s ease;
      @media screen and (max-width: 960px) {
        width: fluid-sp(40);
        height: fluid-sp(40);
      }
      
      &:hover {
        background: design-color("gray", "100");
        color: design-color("gray", "900");
      }
      
      &--absolute {
        position: absolute;
        top: fluid(16);
        right: fluid(16);
        z-index: 1;
        @media screen and (max-width: 960px) {
          top: fluid-sp(16);
          right: fluid-sp(16);
        }
      }
      
      svg {
        width: fluid(20);
        height: fluid(20);  
        @media screen and (max-width: 960px) {
          width: fluid-sp(20);
          height: fluid-sp(20);
        }
      }
    }
    
    &__body {
      flex: 1;
      overflow-y: auto;
      padding: fluid(32);
      @media screen and (max-width: 960px) {
        padding: fluid-sp(24);
      }
      &::-webkit-scrollbar {
        width: 6px;
      }
      
      &::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
      }
      
      &::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
        
        &:hover {
          background: #a8a8a8;
        }
      }
    }
    
    // スマホ対応
    @include mq('sp') {
      padding: fluid-sp(16);
      
      &__container {
        max-width: 100%;
        max-height: 95vh;
      }
      
      &__content {
        border-radius: fluid-sp(12);
        max-height: 95vh;
      }
      
      &__header {
        padding: fluid-sp(16) fluid-sp(20);
      }
      
      &__title {
        font-size: fluid-sp(20);
      }
      
      
      &__body {
        padding: fluid-sp(20);
      }
    }
  }
</style>

<script>
  // モーダルの動作を制御するスクリプト
  document.addEventListener('DOMContentLoaded', function() {
    const modals = document.querySelectorAll('.c-modal');
    
    modals.forEach(modal => {
      const overlay = modal.querySelector('[data-modal-overlay]');
      const closeButtons = modal.querySelectorAll('[data-modal-close]');
      
      // オーバーレイクリックで閉じる
      overlay?.addEventListener('click', () => {
        closeModal(modal);
      });
      
      // 閉じるボタンで閉じる
      closeButtons.forEach(button => {
        button.addEventListener('click', () => {
          closeModal(modal);
        });
      });
    });
    
    // ESCキーで閉じる
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const openModal = document.querySelector('.c-modal.is-open');
        if (openModal) {
          closeModal(openModal);
        }
      }
    });
  });
  
  // モーダルを開く関数
  function openModal(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      
      // フォーカス管理
      const focusableElements = modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      if (focusableElements.length > 0) {
        focusableElements[0].focus();
      }
      
      // スクロール防止
      document.body.style.overflow = 'hidden';
    }
  }
  
  // モーダルを閉じる関数
  function closeModal(modal) {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    
    // スクロール復元
    document.body.style.overflow = '';
  }
  
  // グローバルに公開
  window.openModal = openModal;
  window.closeModal = closeModal;
</script>