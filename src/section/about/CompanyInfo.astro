---
import DataSectionHead from '../../components/common/DataSectionHead.astro';
import VerticalLabel from '../../components/common/VerticalLabel.astro';

const rows = [
	{ label: '企業名', value: '株式会社ケイタスプラン' },
	{ label: '設立年月日', value: '2020年10月26日' },
	{ label: '代表者', value: '小林 義典' },
	{ label: '事業内容', value: '不用品の買取及び回収並びに古物の売買' },
	{ label: '従業員数', value: '180名' },
	{ label: '代表番号', value: '03-6812-1272' },
	{ label: 'フリーダイアル', value: '0120-210-180' },
	{ label: '古物営業法許可番号', value: '東京都公安委員会 第305502115691号' },
];

const offices = [
	{
		name: '池袋本社',
		address: '〒171-0014 東京都豊島区池袋2丁目10-7 ビルディングK 7階',
	},
	{
		name: '水道橋支店',
		address: '〒113-0033 東京都文京区本郷2-15-12 T’sビル',
	},
	{
		name: '宇都宮支店',
		address: '〒321-0953 栃木県宇都宮市東宿郷5丁目1-16 ルーセントビル2階',
	},
];
---

<section class="p-company">
	<div class="p-company__inner">
		<VerticalLabel text="COMPANY PROFILE" />
		<div class="p-company__body">
			<div class="p-company__head">
				<DataSectionHead ja="会社情報" />
			</div>
			<dl class="p-company__table">
				{
					rows.map((r) => (
						<div class="p-company__row">
							<dt class="p-company__label">{r.label}</dt>
							<dd class="p-company__value">{r.value}</dd>
						</div>
					))
				}
				<div class="p-company__row p-company__row--tall">
					<dt class="p-company__label">所在地</dt>
					<dd class="p-company__value">
						{
							offices.map((o) => (
								<span class="p-company__addr">
									{o.name}
									<br />
									{o.address}
								</span>
							))
						}
					</dd>
				</div>
			</dl>
		</div>
	</div>
</section>

<style lang="scss">
	.p-company {
		position: relative;
		background: linear-gradient(360deg, #dfefff 48.08%, #b8dbff 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;
		padding-top: size(120);
		padding-bottom: size(143 + $section-card-radius);

		@include mq('sp') {
			padding-top: size(137);
			padding-bottom: size(196 + $section-card-radius);
		}

		&__inner {
			display: flex;
			align-items: stretch;
			width: size(1165);
			margin-inline: size(128) size(243);

			@include mq('sp') {
				width: size(629);
				margin-inline: size(45) auto;
			}
		}

		&__body {
			display: flex;
			flex: 1;
			margin-left: size(81);

			@include mq('sp') {
				flex-direction: column;
			}
		}

		&__head {
			flex-shrink: 0;
			width: size(306);

			@include mq('sp') {
				width: auto;
			}
		}

		&__table {
			flex: 1;
			margin-top: size(-22);

			@include mq('sp') {
				display: flex;
				flex-direction: column;
				gap: size(40);
				margin-top: size(100);
			}
		}

		&__row {
			display: flex;
			align-items: center;
			min-height: size(62);
			border-bottom: 1px solid $brand-text;

			@include mq('sp') {
				flex-direction: column;
				align-items: flex-start;
				gap: size(16);
				min-height: 0;
				padding-bottom: size(30);
			}

			&--tall {
				align-items: flex-start;
				padding-block: size(15) size(22);

				@include mq('sp') {
					padding-block: 0 size(30);
				}
			}
		}

		&__label {
			flex-shrink: 0;
			width: size(240);
			font-family: $Font;
			font-weight: 500;
			font-size: size(18);
			line-height: 1.4;
			color: $brand-text;

			@include mq('sp') {
				width: auto;
				font-weight: 700;
				font-size: size(30);
			}
		}

		&__value {
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.4;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(30);
			}
		}

		&__addr {
			display: block;

			& + & {
				margin-top: size(25);

				@include mq('sp') {
					margin-top: size(42);
				}
			}
		}
	}
</style>
