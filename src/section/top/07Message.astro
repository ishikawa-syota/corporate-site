---
import OptImage from '../../components/common/OptImage.astro';
import SectionHeading from '../../components/common/SectionHeading.astro';
import { message } from '../../data/siteContent';
// 上部に薄く敷くヒーロー写真（Figma node 772-1604 / opacity 50%）
import bgPc from '../../images/keitasplan/message/bg_pc.png';
// 代表ポートレート（Figma node 772-1638 / 132×164 / radius10）
import president from '../../images/keitasplan/message/president.png';

interface Props {
	id?: string;
}
const { id } = Astro.props;
---

<section class="p-message" id={id}>
	<div class="p-message__bg" aria-hidden="true">
		<OptImage src={bgPc} alt="" width={2400} />
	</div>

	<div class="p-message__inner">
		<SectionHeading
			ja="メッセージ"
			en="MESSAGE"
			theme="dark"
			class="p-message__heading"
		/>

		<div class="p-message__columns">
			<div class="p-message__lead">
				<h2 class="p-message__headline">
					{message.headline.map((line) => <span>{line}</span>)}
				</h2>
			</div>

			<div class="p-message__body">
				{message.body.map((p) => <p class="p-message__text">{p}</p>)}

				<div class="p-message__sign">
					<div class="p-message__signName">
						<span class="p-message__signRole"
							>{message.signRole}</span
						>
						<span class="p-message__signPerson"
							>{message.signName}</span
						>
					</div>
					<div class="p-message__portrait">
						<OptImage
							src={president}
							alt={message.signName}
							width={300}
						/>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	.p-message {
		position: relative;

		// overflow: hidden だとスクロールコンテナ化し子孫の __lead sticky を阻害するため clip
		// overflow: clip;
		background: linear-gradient(180deg, $brand-white 0%, #e9e9e9 100%);

		@include mq('sp') {
			padding-bottom: size(146 + $section-card-radius);
		}

		// 上部に薄く敷くヒーロー写真
		&__bg {
			position: absolute;
			top: size(-640);
			left: size(-218);
			width: size(1971);
			height: size(1162);
			opacity: 0.5;
			pointer-events: none;
			z-index: 0;

			:global(img) {
				object-position: center top;
			}

			@include mq('sp') {
				// Figma SP(609:332): top40 / left-218 / 1569×925 / opacity50
				top: size(-340);
				left: size(-218);
				width: size(1569);
				height: size(925);
			}
		}

		&__inner {
			position: relative;
			z-index: 1;
			max-width: size(1050);
			margin-inline: auto;
			padding-bottom: size(204 + $section-card-radius);

			@include mq('sp') {
				max-width: none;
				margin-inline: size(94);
				padding-bottom: 0;
			}
		}

		// 見出しの下〜2カラムの間隔（Figma: heading top653 → body top964）
		&__columns {
			display: grid;
			grid-template-columns: size(452) size(576);
			gap: size(22);
			margin-top: size(200);

			@include mq('sp') {
				// Figma SP: 見出し下端→青コピー top774、青コピー→本文 top1005
				grid-template-columns: 1fr;
				gap: size(92);
				margin-top: size(72);
			}
		}

		// 左カラム：青い見出しコピー（本文スクロール中は追従）
		&__lead {
			padding-left: size(22);

			// grid item はデフォ align-self: stretch で行高いっぱいに伸び sticky の余白が消えるため start
			align-self: start;
			position: sticky;
			top: size(120);

			@include mq('sp') {
				// SP は 1 カラムで見出しが本文の上に来るため sticky 解除
				position: static;
			}
		}

		&__headline {
			display: flex;
			flex-direction: column;
			font-family: $Font;
			font-weight: 500;
			font-size: size(36);
			line-height: 1.62;
			letter-spacing: 0.02em;
			color: $brand-blue;

			@include mq('sp') {
				// Figma SP(609:347): 43px / lh1.62 / #0054ac
				font-size: size(43);
			}
		}

		// 右カラム：本文＋署名
		&__body {
			display: flex;
			flex-direction: column;
		}

		&__text {
			@include ty-body;

			color: $brand-text;
			text-align: justify;

			// Figma SP(609:351) は lh2.2（ty-body の SP 既定 2 を上書き）
			@include mq('sp') {
				line-height: 2.2;
			}

			// 段落間（Figma: 空行 1 行分）
			& + & {
				margin-top: size(36);

				@include mq('sp') {
					margin-top: size(48);
				}
			}
		}

		&__sign {
			display: flex;
			align-items: flex-end;
			justify-content: flex-end;
			gap: size(22);
			margin-top: size(72);

			@include mq('sp') {
				margin-top: size(56);
			}
		}

		&__signName {
			display: flex;
			flex-direction: column;
			align-items: flex-end;
			gap: size(3);
			color: $brand-text;
		}

		&__signRole {
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.4;

			@include mq('sp') {
				// Figma SP(609:355): 代表取締役 23px
				font-size: size(23);
			}
		}

		&__signPerson {
			font-family: $Font;
			font-weight: 500;
			font-size: size(35);
			line-height: 1.4;

			@include mq('sp') {
				// Figma SP(609:357): 小林 義典 39px
				font-size: size(39);
			}
		}

		&__portrait {
			flex-shrink: 0;
			width: size(132);
			height: size(164);
			border-radius: size(10);
			overflow: hidden;

			@include mq('sp') {
				// Figma SP(609:358): 132×164 / radius10
				width: size(132);
				height: size(164);
			}
		}
	}
</style>
