---
// 矢印付きピルボタン（Figma: button1 / button1_s / button2 / button_saiyou）
// variant でサイズ・配色を切り替え、どこでも流用できる汎用ボタン
interface Props {
	href?: string;
	label: string;
	variant?: 'white' | 'blue';
	size?: 'md' | 'sm' | 'lg';
	class?: string;
}

const {
	href = '#',
	label,
	variant = 'white',
	size = 'md',
	class: className,
} = Astro.props;
---

<a
	href={href}
	class:list={[
		'c-arrowBtn',
		`c-arrowBtn--${variant}`,
		`c-arrowBtn--${size}`,
		className,
	]}
>
	<span class="c-arrowBtn__label">{label}</span>
	<span class="c-arrowBtn__icon" aria-hidden="true">
		<svg
			width="17"
			height="15"
			viewBox="0 0 17 15"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M8.92871 0.292745C9.31914 -0.0976805 9.95223 -0.0974828 10.3428 0.292745L16.707 6.657C17.0976 7.04753 17.0976 7.68054 16.707 8.07106L10.3428 14.4353C9.95223 14.8256 9.31914 14.8257 8.92871 14.4353C8.53829 14.0449 8.53848 13.4118 8.92871 13.0213L13.5859 8.36403H0V6.36403H13.5859L8.92871 1.70681C8.53848 1.31626 8.53829 0.68317 8.92871 0.292745Z"
				fill="white"></path>
		</svg>
	</span>
</a>

<style lang="scss">
	@use '../../styles/foundation/index' as *;

	.c-arrowBtn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: size(15);
		width: size(220);
		height: size(60);
		padding: 0 size(24);
		border-radius: 999px;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			background-color 0.3s ease;

		@media (hover: hover) and (pointer: fine) {
			&:hover {
				&::after {
					opacity: 1;
				}

				.c-arrowBtn__icon {
					transform: translateX(#{size(2)});
				}
			}
		}

		&::after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: linear-gradient(90deg, #fff 0%, #dfefff 100%);
			opacity: 0;
			transition: opacity 0.3s ease;
			border-radius: calc(1px / 0);
		}

		&__label {
			@include ty-button;

			position: relative;
			z-index: 1;
			font-size: size(15);
			font-weight: 500;

			@include mq('sp') {
				font-size: size(20);
			}
		}

		&__icon {
			position: absolute;
			z-index: 1;
			right: size(15);
			width: size(29);
			height: size(29);
			background-color: $brand-blue;
			border-radius: 50%;
			display: grid;
			place-items: center;
			transition: transform 0.3s ease;

			svg {
				display: grid;
				place-items: center;
				width: size(17);
				height: size(15);
			}
		}

		// --- 配色バリアント ---
		&--white {
			background-color: $brand-white;
			box-shadow: 0 size(4) size(20) rgba($brand-blue, 0.12);

			.c-arrowBtn__label {
				color: $brand-text;
			}

			.c-arrowBtn__icon circle {
				fill: $brand-blue;
			}

			.c-arrowBtn__icon path {
				// stroke: $brand-white;
			}
		}

		&--blue {
			background-color: $brand-blue;

			.c-arrowBtn__label {
				color: $brand-white;
			}

			.c-arrowBtn__icon circle {
				fill: $brand-white;
			}

			.c-arrowBtn__icon path {
				stroke: $brand-blue;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					background-color: $brand-blue-light;
				}
			}
		}

		// --- サイズバリアント ---
		&--sm {
			width: size(197);
			height: size(50);

			.c-arrowBtn__icon {
				right: size(12);
			}
		}

		&--lg {
			width: size(301);
			height: size(60);
		}
	}
</style>
