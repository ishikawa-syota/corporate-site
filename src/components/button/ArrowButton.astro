---
// 矢印付きピルボタン（Figma: button1 / button1_s / button2 / button_saiyou）
// variant でサイズ・配色を切り替え、どこでも流用できる汎用ボタン
import arrow from '../../images/keitasplan/common/arrow.svg';

interface Props {
	href?: string;
	label: string;
	variant?: 'white' | 'blue';
	size?: 'md' | 'sm' | 'lg';
	class?: string;
}

const {
	href = '#',
	label,
	variant = 'white',
	size = 'md',
	class: className,
} = Astro.props;
---

<a
	href={href}
	class:list={[
		'c-arrowBtn',
		`c-arrowBtn--${variant}`,
		`c-arrowBtn--${size}`,
		className,
	]}
>
	<span class="c-arrowBtn__label">{label}</span>
	<span class="c-arrowBtn__icon" aria-hidden="true">
		<img src={arrow.src} alt="" />
	</span>
</a>

<style lang="scss">
	.c-arrowBtn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: size(15);
		width: size(220);
		height: size(60);
		padding: 0 size(24);
		border-radius: 999px;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			background-color 0.3s ease;

		@include mq('sp') {
			width: size(380);
			height: size(100);
		}

		@media (hover: hover) and (pointer: fine) {
			&:hover {
				&::after {
					opacity: 1;
				}

				.c-arrowBtn__icon {
					transform: translateX(#{size(2)});
				}
			}
		}

		&::after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: linear-gradient(90deg, #fff 0%, #dfefff 100%);
			opacity: 0;
			transition: opacity 0.3s ease;
			border-radius: calc(1px / 0);
		}

		&__label {
			@include ty-button;

			position: relative;
			z-index: 1;
			font-size: size(15);
			font-weight: 500;

			@include mq('sp') {
				font-size: size(33);
			}
		}

		&__icon {
			position: absolute;
			z-index: 1;
			right: size(15);
			width: size(29);
			height: size(29);
			background-color: $brand-blue;
			border-radius: 50%;
			display: grid;
			place-items: center;
			transition: transform 0.3s ease;

			img {
				display: block;
				width: size(17);
				height: size(15);
			}
		}

		// --- 配色バリアント ---
		&--white {
			background-color: $brand-white;
			box-shadow: 0 size(4) size(20) rgba($brand-blue, 0.12);

			.c-arrowBtn__label {
				color: $brand-text;
			}

			.c-arrowBtn__icon circle {
				fill: $brand-blue;
			}

			.c-arrowBtn__icon path {
				// stroke: $brand-white;
			}
		}

		&--blue {
			background-color: $brand-blue;

			.c-arrowBtn__label {
				color: $brand-white;
			}

			.c-arrowBtn__icon circle {
				fill: $brand-white;
			}

			.c-arrowBtn__icon path {
				stroke: $brand-blue;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					background-color: $brand-blue-light;
				}
			}
		}

		// --- サイズバリアント ---
		&--sm {
			width: size(197);
			height: size(50);

			.c-arrowBtn__icon {
				right: size(12);
			}
		}

		&--lg {
			width: size(301);
			height: size(60);
		}
	}
</style>
