---
import CompanyScale from './CompanyScale.astro';
import Events from './Events.astro';
import HomeVisit from './HomeVisit.astro';
import Social from './Social.astro';
import Staff from './Staff.astro';
---

<div class="p-data-stats">
	<CompanyScale id="data-company" />
	<HomeVisit id="data-home-visit" />
	<Events id="data-events" />
	<Staff id="data-staff" />
	<Social id="data-social" />
</div>

<style lang="scss">
	// 指標グループ全体の背景（淡いブルー）。上部を角丸にしてヒーロー(白)から切り替わる
	.p-data-stats {
		position: relative;
		background: linear-gradient(360deg, #dfefff 48.08%, #b8dbff 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;
		padding-block: size(86) size(152);
		display: flex;
		flex-direction: column;
		gap: size(161);

		@include mq('sp') {
			padding-block: size(137) size(141);
		}
	}
</style>
