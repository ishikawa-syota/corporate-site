---
import { siteMetadata } from '../data/meta';
import Footer from '../layouts/Footer.astro';
import Header from '../layouts/Header.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title={`フォーム送信ありがとうございます | ${siteMetadata.siteName}`}>
  <Header id="header" />
  <div class="p-thanks">
    <div class="l-inner">
      <div class="p-thanks__container">
        <!-- タイトル -->
        <h1 class="p-thanks__title">
          フォーム送信<br class="u-sp-only">ありがとうございます
        </h1>

        <!-- メインコンテンツ -->
        <div class="p-thanks__content">
          <!-- メインメッセージ -->
          <p class="p-thanks__message">
            お送りいただいた内容を確認の上、<br class="u-pc-only">担当よりご連絡をさせていただきますので、<br class="u-sp-only">
            今しばらくお待ちいただけますよう、<br class="u-sp-only">お願いいたします。
          </p>

          <!-- 確認メールボックス -->
          <div class="p-thanks__box">
            <p class="p-thanks__box-text">
              ご入力いただいたメールアドレスに、<br>
              <span class="u-sp-only">ご相談内容の</span>確認メールを<br class="u-sp-only">お送りさせていただきましたので、<br class="u-sp-only">ご確認ください。
            </p>
          </div>

          <!-- 注意書き -->
          <div class="p-thanks__notice">
            <p class="p-thanks__notice-text">
              なお、数日お待ちいただいても確認メールが<br class="u-sp-only">届かない場合は、お手数ですが、
            </p>
            
            <div class="p-thanks__email">
              <a href="mailto:info@example.com">E-mail：info@example.com</a>
            </div>

            <p class="p-thanks__notice-text">
              までお問い合わせをお願いいたします。
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
  <Footer id="footer" />
</Layout>

<style lang="scss">
@use "../styles/foundation/index" as *;

.p-thanks {
  padding: fluid(120) 0;
  background-color: #ffffff;
  min-height: 100vh;
  display: flex;
  align-items: center;

  @media screen and (max-width: 768px) {
    padding: fluid-sp(170) 0 fluid-sp(80);
  }

  .l-inner {
    max-width: fluid(1200);
    margin: 0 auto;
    padding: 0 fluid-sp(20);

    @media screen and (max-width: 768px) {
      padding: 0 fluid-sp(40);
      max-width: 100%;
    }
  }

  &__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: fluid(56);
    max-width: fluid(1097);
    margin: 0 auto;
    text-align: center;

    @media screen and (max-width: 768px) {
      gap: fluid-sp(32);
      max-width: 100%;
    }
  }

  &__title {
    background: linear-gradient(90deg, #2cac6f 0%, #00b4ca 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: fluid(40);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.6;
    text-align: center;
    margin: 0;

    @media screen and (max-width: 768px) {
      font-size: fluid-sp(56);
      line-height: 1.4;
    }
  }

  &__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: fluid(32);
    width: 100%;

    @media screen and (max-width: 768px) {
      gap: fluid-sp(24);
    }
  }

  &__message {
    color: #3c3c3c;
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: fluid(20);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.8;
    text-align: center;
    max-width: 900px;
    margin: 0;

    @media screen and (max-width: 768px) {
      font-size: fluid-sp(30);
      line-height: 1.6;
      br {
        display: none;
      }
    }
  }

  &__box {
    background-color: #ecf8ef;
    padding: fluid(32) fluid(48);
    max-width: fluid(800);
    width: 100%;
    border-radius: fluid(4);
    

    @media screen and (max-width: 768px) {
      padding: fluid-sp(24);
      font-size: fluid-sp(30);
      max-width: 100%;
    }
  }

  &__box-text {
    color: #0DAB82;
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: fluid(20);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.8;
    text-align: center;
    margin: 0;

    @media screen and (max-width: 768px) {
      font-size: fluid-sp(30);
      line-height: 1.6;
      br {
        display: none;
      }
    }
  }

  &__notice {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: fluid(24);
    max-width: fluid(1097);
    width: 100%;
    margin-top: fluid(40);

    @media screen and (max-width: 768px) {
      width: 100%;
      gap: fluid-sp(16);
      max-width: 100%;
    }
  }

  &__notice-text {
    color: #3c3c3c;
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: fluid(20);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.8;
    text-align: center;
    margin: 0;

    @media screen and (max-width: 768px) {
      width: max-content;
      font-size: fluid-sp(28);
      line-height: 1.6;
    }
  }

  &__email {
    width: 100%;
    color: #3c3c3c;
    font-family: "Zen Kaku Gothic New", sans-serif;
    font-size: fluid(20);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.8;
    text-align: center;
    border: 1px solid #3c3c3c;
    padding: fluid(8) fluid(24);
    max-width: fluid(800);
    border-radius: fluid(4);

    @media screen and (max-width: 768px) {
      display: block;
      width: 100%;
      font-size: fluid-sp(30);
      line-height: 1.6;
      padding: fluid-sp(6) fluid-sp(16);
      max-width: 100%;
    }

    a {
      display: block;
      width: 100%;
    }
  }

  &__btn {
    width: fit-content;
    position: relative;
    align-items: center;
    display: flex;
    gap: fluid(16);
    color: #3c3c3c;
    font-family: "Zen Kaku Gothic New", sans-serif;
      font-size: fluid(20);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.8;
    text-decoration: none;
    width: fluid(225);
    padding-bottom: fluid(12);
    padding-right: fluid(32);
    border-radius: fluid(4);
    transition: opacity 0.3s ease;
    white-space: nowrap;
    @media screen and (max-width: 768px) {
      width: fit-content;
      padding-right: 0;
      font-size: fluid-sp(30);
    }
    &::after {
      content: "";
      display: block;
      width: 100%;
      height: fluid(1);
      background-color: #3c3c3c;
      position: absolute;
      bottom: 0;
      left: 0;
    }

    &:hover {
      opacity: 0.8;
    }

    @media screen and (max-width: 768px) {
      font-size: fluid-sp(30);
      gap: fluid-sp(12);
      padding: fluid-sp(10) fluid-sp(20);
    }
  }

  &__btn-text {
    display: block;
  }

  &__btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: fluid(16);
    height: fluid(16);
    flex-shrink: 0;

    @media screen and (max-width: 768px) {
      width: fluid-sp(24);
      height: fluid-sp(24);
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }
}
</style>