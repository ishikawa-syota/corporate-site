---
// メンバーカード（写真 + 役職 + 氏名）
import type { MicroCMSImage } from 'microcms-js-sdk';

interface Props {
	role: string;
	name: string;
	photo: MicroCMSImage;
	photoHover: MicroCMSImage;
}

const { role, name, photo, photoHover } = Astro.props;

// microCMS画像API（imgix）でWebP変換・リサイズ
const src = (img: MicroCMSImage) => `${img.url}?fm=webp&w=500`;
const srcset = (img: MicroCMSImage) =>
	`${img.url}?fm=webp&w=500 1x, ${img.url}?fm=webp&w=1000 2x`;
---

<article class="c-member">
	<div class="c-member__photo">
		<span class="c-member__img c-member__img--base">
			<img
				src={src(photo)}
				srcset={srcset(photo)}
				alt={name}
				width={photo.width}
				height={photo.height}
				loading="lazy"
				decoding="async"
			/>
		</span>
		<span class="c-member__img c-member__img--hover" aria-hidden="true">
			<img
				src={src(photoHover)}
				srcset={srcset(photoHover)}
				alt=""
				width={photoHover.width}
				height={photoHover.height}
				loading="lazy"
				decoding="async"
			/>
		</span>
	</div>
	<div class="c-member__info">
		<span class="c-member__role">{role}</span>
		<span class="c-member__name">{name}</span>
	</div>
</article>

<style lang="scss">
	.c-member {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;

		&__photo {
			position: relative;
			width: 100%;
			aspect-ratio: 402 / 504;
			overflow: hidden;
		}

		&__img {
			display: block;
			height: 100%;
			transition: opacity 0.4s ease;

			// transform: scale(1.4);
			width: size(403);
			transform: translateX(-20%);

			img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: contain;
			}

			// hover画像は通常画像の上に重ねて初期は非表示
			&--hover {
				position: absolute;
				inset: 0;
				opacity: 0;
			}
		}

		// Figma: 白カードなし。氏名・役職を青背景に直置き（写真下に重ねる）
		&__info {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: size(4);

			// margin-top: size(-26);
		}

		&__role {
			@include ty-caption;

			color: $brand-white;

			@include mq('sp') {
				font-size: size(23);
			}
		}

		&__name {
			font-family: $Font;
			font-weight: 500;
			font-size: size(22);
			line-height: 1.4;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(30);
			}
		}
	}

	// hoverで通常画像をフェードアウト・hover画像をフェードイン（タッチデバイスでは無効）
	@media (hover: hover) and (pointer: fine) {
		.c-member:hover .c-member__img--base {
			opacity: 0;
		}

		.c-member:hover .c-member__img--hover {
			opacity: 1;
		}
	}
</style>
