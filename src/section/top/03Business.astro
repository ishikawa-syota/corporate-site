---
import BusinessCard from '../../components/card/BusinessCard.astro';
import SectionHeading from '../../components/common/SectionHeading.astro';
import { businessCards } from '../../data/siteContent';
import imgShuccho from '../../images/keitasplan/business/business-01.jpg';
import imgSaiji from '../../images/keitasplan/business/business-icon-01.jpg';

interface Props {
	id?: string;
}
const { id } = Astro.props;

// 催事買取 / 出張買取 の順で画像を割り当て
const cardImages = [imgSaiji, imgShuccho];

const intro = `商業施設で開催する催事買取をメインに、ご自宅へお伺いする出張買取。<br>私たちの仕事は、目利きでお客様の品物を一つひとつ査定し、適正な価格でお預かりして、次の暮らしへとつなぐこと。年間48,000件の実績と180名のスタッフが、それを支えています。`;
---

<section class="p-business" id={id}>
	<div class="p-business__inner">
		<SectionHeading
			ja="事業紹介"
			en="BUSINESS"
			lead='品物を、見極める。<br class="u-sp-only" />その価値を、つなぐ。'
			class="p-business__heading"
		/>
		<div class="p-business__body">
			<p class="p-business__intro" set:html={intro} />
			<div class="p-business__cards">
				{
					businessCards.map((card, i) => (
						<BusinessCard
							title={card.title}
							desc={card.desc}
							href={card.href}
							img={cardImages[i]}
						/>
					))
				}
			</div>
		</div>
	</div>
</section>

<style lang="scss">
	.p-business {
		background-color: $brand-white;
		padding-block: size(100);
		position: relative;
		z-index: 3;

		@include mq('sp') {
			padding-block: size(80);
			border-radius: size(130);
			margin-top: size(-130);
		}

		&__inner {
			// 1050(Figmaコンテンツ幅) + 24*2(padding) = 1098 で実コンテンツを1050pxに
			max-width: size(1098);
			margin-inline: auto;
			padding-inline: size(24);

			@include mq('sp') {
				// SP(768): 左右マージン94px → コンテンツ580px（カード幅と一致）
				padding-inline: size(94);
			}
		}

		&__body {
			display: grid;
			grid-template-columns: size(357) 1fr;
			gap: size(68);
			margin-top: size(72);

			@include mq('sp') {
				grid-template-columns: 1fr;
				gap: size(104); // intro → カード群
				margin-top: size(95); // リード → intro
			}
		}

		&__intro {
			@include ty-body-s;

			font-size: size(20);
			color: $brand-text;
			text-align: justify;

			@include mq('sp') {
				font-size: size(30);
			}
		}

		&__cards {
			display: flex;
			flex-direction: column;
			gap: size(48);

			@include mq('sp') {
				gap: size(68);
			}
		}
	}
</style>
