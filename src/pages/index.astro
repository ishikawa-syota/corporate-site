---
import OptImage from '../components/common/OptImage.astro';
import { siteMetadata } from '../data/meta';
import fvCopyBg from '../images/keitasplan/fv/bg.png';
// 装飾バッグ：FV上部に固定で浮き、p-copy__body 中部で解除して本文と流れる
import imgBag from '../images/keitasplan/fv/fv-04.png';
import Footer from '../layouts/Footer.astro';
import Header from '../layouts/Header.astro';
import Layout from '../layouts/Layout.astro';
import FirstView from '../section/top/01FV.astro';
import Copy from '../section/top/02Copy.astro';
import Business from '../section/top/03Business.astro';
import Data from '../section/top/04Data.astro';
import Member from '../section/top/05Member.astro';
import Voice from '../section/top/06Voice.astro';
import Message from '../section/top/07Message.astro';
import Faq from '../section/top/08Faq.astro';
import { processImages } from '../styles/images';

// FV〜Copy を1枚で覆う統合背景（--fvbg を生成）
const fvCopyStyles = await processImages({ fvbg: fvCopyBg });
---

<Layout title={siteMetadata.siteName}>
	<Header id="header" />
	<div class="l-fvCopy" style={fvCopyStyles}>
		<FirstView id="firstview" />
		<Copy id="copy" />
		{
			/* 装飾バッグ。Rail（FV上端〜p-copy__body中部の縦枠）内で position: sticky させ、
        FV上部の高さに固定で浮く→Rail下端=body中部で解除し本文と一緒に流れる（逆stickyパターン） */
		}
		<div class="l-fvCopy__bagRail" aria-hidden="true">
			<div class="l-fvCopy__bag">
				<OptImage src={imgBag} alt="" width={300} fit="contain" />
			</div>
		</div>
	</div>
	<Business id="business" />
	<Data id="data" />
	<Member id="member" />
	<Voice id="voice" />
	<Message id="message" />
	<Faq id="faq" />
	<Footer id="footer" />
</Layout>

<style>
	/* FV〜Copy 統合背景：1枚を全幅で上から敷き、画像下端色をフォールバックに */
	.l-fvCopy {
		position: relative;
		background-color: #75afeb; /* fv/bg.png 下端色（高さズレ時の隙間防止） */
		background-image: var(--fvbg);
		background-repeat: no-repeat;
		background-position: top center;

		/* 均一な縦グラデのため cover で全面カバー（SPは左右クロップ＝視覚上ほぼ無変化、縦は全域に伸びる） */
		background-size: cover;
	}
</style>

<style lang="scss">
	@use '../styles/foundation/index' as *;

	// 装飾バッグの「逆sticky」枠。
	// l-fvCopy 直下に置くことで FV(p-fv z3) より前面に出し、FV上端〜body中部を縦に覆う。
	// 高さ size(1664) は body 中部(≒doc1594)＋バッグ半分。全要素 size() 由来で幅にスケールするため、
	// 枠の高さも size() で表現でき JS 不要。Rail 下端で sticky が解除＝body中部で本文と流れ出す。
	.l-fvCopy__bagRail {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: size(1664);
		z-index: 5;
		pointer-events: none;

		@include mq('sp') {
			// rail 下端 = copy 本文中盤で解除。3322 では事業紹介セクションまで
			// バッグが浮き続け重なるため、PC同様 copy 内で解除するよう短縮。
			height: size(2172);
		}
	}

	.l-fvCopy__bag {
		position: sticky;
		top: size(340); // FV上部の高さ（元の固定位置）に貼り付く
		width: size(134);
		margin-inline: auto; // 横方向は中央
		// opacity: 0.7;
		will-change: transform;

		@include mq('sp') {
			top: size(
				457
			); // Figma SP: 2人の手の高さ（FV上 y=367 + ヘッダー分）

			width: size(108);

			// opacity は PC と同じ 0.7 を継承（本文へ浮上時にテキストが透ける）
		}
	}
</style>
