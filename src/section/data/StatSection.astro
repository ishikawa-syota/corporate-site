---
import DataStat from '../../components/card/DataStat.astro';

interface Card {
	label: string;
	prefix?: string;
	value: string;
	unit: string;
	caption?: string;
	illust?: 'top' | 'left' | 'right';
	inline?: boolean;
	labelAfter?: boolean;
	figureFirst?: boolean;
	overlay?: boolean;
	illustW?: number;
	illustH?: number;
	illustLabel?: string;
	wide?: boolean;
}
interface Props {
	id?: string;
	en: string;
	ja: string;
	sub?: string;
	note?: string;
	cards: Card[];
}
const { id, en, ja, sub, note, cards } = Astro.props;
---

<section class="p-data-sec" id={id}>
	<div class="p-data-sec__inner">
		<div class="p-data-sec__label" aria-hidden="true">
			<span class="p-data-sec__en">{en}</span>
		</div>
		<div class="p-data-sec__body">
			<div class="p-data-sec__head">
				<h2 class="p-data-sec__ja">{ja}</h2>
				{sub && <p class="p-data-sec__sub">{sub}</p>}
			</div>
			<ul class="p-data-sec__grid">
				{
					cards.map((c) => (
						<li
							class:list={[
								'p-data-sec__cell',
								c.wide && 'p-data-sec__cell--wide',
							]}
						>
							<DataStat {...c} />
						</li>
					))
				}
			</ul>
			{note && <p class="p-data-sec__note">{note}</p>}
		</div>
	</div>
</section>

<style lang="scss">
	.p-data-sec {
		position: relative;

		&__inner {
			display: flex;
			align-items: stretch;
			gap: size(81);
			margin-inline: auto;
			padding-inline: size(128) size(243);

			@include mq('sp') {
				gap: size(80);
				padding-inline: size(45) size(94);
			}
		}

		// 縦組みENラベル + 下方向へ伸びるライン
		&__label {
			flex-shrink: 0;
			display: flex;
			width: size(35);

			&::after {
				content: '';
				flex: 1 1 auto;
				width: size(2);
				background: $brand-blue;
				height: 100%;
			}
		}

		&__en {
			writing-mode: vertical-rl;
			font-family: $Font-Readex;
			font-weight: 500;
			font-size: size(24);
			line-height: 1.4;
			letter-spacing: 0.1em;
			color: $brand-blue;
			white-space: nowrap;
		}

		&__body {
			flex: 1;
			min-width: 0;
		}

		&__head {
			display: flex;
			align-items: baseline;
			gap: size(30);
			flex-wrap: wrap;

			@include mq('sp') {
				flex-direction: column;
				gap: size(16);
			}
		}

		&__ja {
			font-family: $Font;
			font-weight: 700;
			font-size: size(40);
			line-height: 1.4;
			letter-spacing: size(1.2);
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(48);
			}
		}

		&__sub {
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.6;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(24);
			}
		}

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: size(60) size(42);
			margin-top: size(100);

			@include mq('sp') {
				grid-template-columns: minmax(0, 1fr);
				gap: size(70);
			}
		}

		&__cell {
			min-width: 0;

			&--wide {
				grid-column: 1 / -1;
			}
		}

		&__note {
			margin-top: size(40);
			font-family: $Font;
			font-weight: 400;
			font-size: size(14);
			line-height: 1.6;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(20);
			}
		}
	}
</style>
