---
import { VOICES_PAGE_SIZE } from '../../../data/config';
import { siteMetadata } from '../../../data/meta';
import Footer from '../../../layouts/Footer.astro';
import Header from '../../../layouts/Header.astro';
import Layout from '../../../layouts/Layout.astro';
import { getAllVoices } from '../../../lib/microcms';
import PageHero from '../../../section/common/PageHero.astro';
import VoiceList from '../../../section/voices/VoiceList.astro';

// 1ページ目は /voices/ が担うため、ここでは2ページ目以降のみ生成する
export async function getStaticPaths() {
	const voices = await getAllVoices({ orders: 'system:default' });
	const totalPages = Math.ceil(voices.length / VOICES_PAGE_SIZE);
	return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
		const page = i + 2;
		return {
			params: { page: String(page) },
			props: {
				items: voices.slice(
					(page - 1) * VOICES_PAGE_SIZE,
					page * VOICES_PAGE_SIZE
				),
				page,
				totalPages,
			},
		};
	});
}

const { items, page, totalPages } = Astro.props;
---

<Layout title={`お客様の声（${page}ページ目） | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<PageHero id="voices-hero" ja="お客様の声" en="VOICE" spTitleLarge />
	<VoiceList items={items} currentPage={page} totalPages={totalPages} />
	<Footer id="footer" variant="subpage" />
</Layout>
