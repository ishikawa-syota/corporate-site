---
// メンバーカード（写真 + 役職 + 氏名）
import ImagePlaceholder from '../common/ImagePlaceholder.astro';
import OptImage from '../common/OptImage.astro';

interface Props {
  role: string;
  name: string;
  img?: ImageMetadata;
}

const { role, name, img } = Astro.props;
---

<article class="c-member">
  <div class="c-member__photo">
    {img ? <OptImage src={img} alt={name} width={500} fit="contain" /> : <ImagePlaceholder label={name} rounded="0" />}
  </div>
  <div class="c-member__info">
    <span class="c-member__role">{role}</span>
    <span class="c-member__name">{name}</span>
  </div>
</article>

<style lang="scss">
  @use '../../styles/foundation/index' as *;

  .c-member {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;

    &__photo {
      width: 100%;
      aspect-ratio: 402 / 504;
      overflow: hidden;
    }

    // Figma: 白カードなし。氏名・役職を青背景に直置き（写真下に重ねる）
    &__info {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: size(4);
      margin-top: size(-26);
    }

    &__role {
      @include ty-caption;
      color: $brand-white;
    }

    &__name {
      font-family: $Font;
      font-weight: 500;
      font-size: size(22);
      line-height: 1.4;
      color: $brand-text;
    }
  }
</style>
