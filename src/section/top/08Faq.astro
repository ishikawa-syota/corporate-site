---
import { getImage } from 'astro:assets';

import FaqItem from '../../components/card/FaqItem.astro';
import SectionHeading from '../../components/common/SectionHeading.astro';
import { faqs } from '../../data/siteContent';
// 背景写真（FAQ セクション全面）
import bg from '../../images/keitasplan/faq/bg.png';

interface Props {
	id?: string;
}
const { id } = Astro.props;

// 背景写真は巨大（約1.9MB）なので AVIF 化して軽量背景に
const bgImg = await getImage({ src: bg, format: 'avif', width: 2400 });
---

<section class="p-faq" id={id} style={`--bg:url(${bgImg.src})`}>
	<div class="p-faq__inner">
		<SectionHeading ja="よくある質問" en="FAQ" class="p-faq__heading" />
		<div class="p-faq__list">
			{faqs.map((item) => <FaqItem q={item.q} a={item.a} />)}
		</div>
	</div>
</section>

<style lang="scss">
	@use '../../styles/foundation/index' as *;

	// Figma: 上角丸130px / 白背景 / py98 / 前セクション(Message)のグレーに重なるカード表現
	.p-faq {
		position: relative;
		z-index: 1;
		background-color: $brand-white;
		background-image: var(--bg);
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		border-top-left-radius: size(130);
		border-top-right-radius: size(130);

		// 下端を拡張し、白→グレーのグラデ背景をフッター直前まで伸ばす。
		// この余白グレーの上にお問い合わせカードの上半分が重なる（Figma: sec7 下部の余白）
		padding-block: size(98) size(337);
		margin-top: size(-80);
		overflow: clip;

		// Figma SP(768基準): 角丸130 / margin-top-80 はPCと同値。padding上端113 / 下端はカード重なり用に拡張
		@include mq('sp') {
			padding-block: size(113) size(450);
		}

		&__inner {
			max-width: size(1050);
			margin-inline: auto;
			padding-inline: size(24);

			// Figma SP(768基準): コンテンツ幅580
			@include mq('sp') {
				max-width: size(580);
				padding: 0;
			}
		}

		// Figma: 見出し→リスト gap 85 / 上端に区切り線 / 項目間 gap 43
		&__list {
			display: flex;
			flex-direction: column;
			gap: size(43);
			margin-top: size(85);
			padding-top: size(40);
			border-top: 1px solid rgba($brand-text, 0.2);

			// Figma SP(768基準): 見出し→リスト gap84 / 項目間 gap54 / 区切り線なし
			@include mq('sp') {
				gap: size(54);
				margin-top: size(84);
				padding-top: 0;
				border-top: none;
			}
		}
	}
</style>
