{
	"name": "pj_keitasplan",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "run-s lint:check 'astro build' 'replace-path' validate:html",
		"build:check": "NODE_ENV=production astro build",
		"replace-path": "node replacePath.mjs",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint . --ext .js,.ts,.astro",
		"lint:fix": "eslint . --ext .js,.ts,.astro --fix",
		"lint:check": "eslint . --ext .js,.ts,.astro --max-warnings 0",
		"lint:style": "stylelint --fix \"**/*.{scss,astro}\"",
		"lint:style:check": "stylelint \"**/*.{scss,astro}\"",
		"validate:html": "html-validate \"dist/**/*.html\"",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"fix": "eslint . --ext .js,.ts,.astro --fix && stylelint --fix \"**/*.{scss,astro}\" && prettier --write .",
		"check": "npm run lint:check && npm run lint:style:check && npm run format:check",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "npm run check"
	},
	"dependencies": {
		"@fontsource/noto-sans-jp": "^5.2.9",
		"@fontsource/oswald": "^5.2.8",
		"@fontsource/readex-pro": "^5.2.11",
		"@fontsource/roboto": "^5.2.10",
		"@fontsource/zen-kaku-gothic-new": "^5.2.7",
		"@splidejs/splide": "^4.1.4",
		"@vercel/functions": "^3.7.5",
		"astro": "^7.0.4",
		"gsap": "^3.13.0",
		"microcms-js-sdk": "^3.4.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.34.0",
		"@types/node": "^20.11.0",
		"astro-relative-links": "^0.4.2",
		"astro-seo": "^1.1.0",
		"chalk": "^5.4.1",
		"cheerio": "^1.1.2",
		"cssnano": "^7.0.6",
		"eslint": "^9.34.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-astro": "^1.3.1",
		"eslint-plugin-import-x": "^4.16.1",
		"glob": "^13.0.6",
		"html-validate": "^11.5.4",
		"node-html-parser": "^8.0.4",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.3",
		"postcss-combine-media-query": "^2.1.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "^0.14.1",
		"sass-embedded": "^1.100.0",
		"sharp": "^0.35.2",
		"simple-git-hooks": "^2.13.1",
		"stylelint": "^17.14.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"terser": "^5.39.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.42.0"
	}
}
