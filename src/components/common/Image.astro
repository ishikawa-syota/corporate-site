---
import { Image as AstroImage } from 'astro:assets';

interface Props {
	class?: string;
	src: ImageMetadata;
	loading?: 'eager' | 'lazy';
	alt: string;
}

const {
	class: className,
	src,
	loading = 'lazy',
	alt,
	...attrs
}: Props = Astro.props;
---

<AstroImage
	class={className}
	src={src}
	loading={loading}
	alt={alt}
	width={src.width}
	height={src.height}
	{...attrs}
/>
