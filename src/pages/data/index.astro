---

<Layout title={`数字で見るケイタスプラン | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<Hero id="data-hero" />
	<StatSection id="data-company" {...company} />
	<StatSection id="data-home-visit" {...homeVisit} />
	<StatSection id="data-events" {...events} />
	<StatSection id="data-staff" {...staff} />
	<StatSection id="data-social" {...social} />
	<RelatedInfo id="data-related" cards={relatedCards} />
	<Footer id="footer" variant="subpage" />
</Layout>
