---
import VoiceBox from '../../components/card/VoiceBox.astro';
import Pager from '../../components/common/Pager.astro';

interface Props {
	items: any[];
	currentPage: number;
	totalPages: number;
}
const { items, currentPage, totalPages } = Astro.props;
---

<section class="p-voices">
	<div class="p-voices__inner">
		{
			items.length === 0 ? (
				<p class="p-voices__empty">該当のコンテンツはありません</p>
			) : (
				<ul class="p-voices__grid">
					{items.map((v) => (
						<li class="p-voices__cell">
							<VoiceBox
								headline={v.title}
								meta={v.meta}
								body={v.body}
								thumbnail={v.thumbnail}
							/>
						</li>
					))}
				</ul>
			)
		}
		{
			totalPages > 1 && (
				<div class="p-voices__pager">
					<Pager
						currentPage={currentPage}
						totalPages={totalPages}
						basePath="/voices"
					/>
				</div>
			)
		}
	</div>
</section>

<style lang="scss">
	.p-voices {
		position: relative;
		background: linear-gradient(360deg, #dfefff 48.08%, #b8dbff 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;

		&__inner {
			max-width: size(1080);
			margin-inline: auto;
			padding-block: size(98) size(100);

			@include mq('sp') {
				max-width: size(630);
				padding-block: size(148) size(150);
			}
		}

		&__grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: size(80);

			@include mq('sp') {
				grid-template-columns: minmax(0, 1fr);
				gap: size(100);
			}
		}

		&__cell {
			min-width: 0;
		}

		&__empty {
			font-family: $Font;
			font-weight: 400;
			font-size: size(18);
			line-height: 1.8;
			text-align: center;
			color: $brand-text;

			@include mq('sp') {
				font-size: size(30);
			}
		}

		&__pager {
			margin-top: size(108);

			@include mq('sp') {
				margin-top: size(119);
			}
		}
	}
</style>
