---
// セクション共通見出し（エンブレム + 日本語タイトル + 英語サブ + リード文）
// theme: 明るい背景=dark / 暗い背景=light
import markDark from '../../images/keitasplan/common/mark.svg?raw';
import markLight from '../../images/keitasplan/common/mark_white.svg?raw';

interface Props {
	ja: string;
	en: string;
	lead?: string;
	theme?: 'dark' | 'light';
	align?: 'left' | 'center';
	class?: string;
}

const {
	ja,
	en,
	lead,
	theme = 'dark',
	align = 'left',
	class: className,
} = Astro.props;

const markSvg = theme === 'light' ? markLight : markDark;
---

<div
	class:list={[
		'c-heading',
		`c-heading--${theme}`,
		`c-heading--${align}`,
		className,
	]}
>
	<div class="c-heading__main">
		<span class="c-heading__mark" aria-hidden="true" set:html={markSvg} />
		<span class="c-heading__titles">
			<span class="c-heading__ja">{ja}</span>
			<span class="c-heading__en">{en}</span>
		</span>
	</div>
	{lead && <p class="c-heading__lead" set:html={lead} />}
</div>

<style lang="scss">
	@use '../../styles/foundation/index' as *;

	.c-heading {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: size(40);
		width: 100%;

		@include mq('sp') {
			flex-direction: column;
			align-items: flex-start;
			gap: size(94);
		}

		&--center {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		&__main {
			display: flex;
			align-items: center;
			gap: size(16);
			flex-shrink: 0;
		}

		&__mark {
			display: inline-flex;
			width: size(64);
			height: size(64);

			svg {
				width: 100%;
				height: 100%;
			}
		}

		&__titles {
			display: flex;
			flex-direction: column;
			gap: size(6);
		}

		&__ja {
			@include ty-heading;
		}

		&__en {
			@include ty-heading-en;
			color: $brand-text;
			@include mq('sp') {
				font-size: size(20);
			}
		}

		&__lead {
			@include ty-lead;
			padding-bottom: size(34);

			@include mq('sp') {
				padding-bottom: 0;
			}
		}

		// Voice セクションのみ SP リード文サイズを調整
		&.p-voice__heading .c-heading__lead {
			@include mq('sp') {
				font-size: size(30);
			}
		}

		// --- テーマ ---
		&--dark {
			.c-heading__ja {
				color: $brand-text;
			}
			.c-heading__lead {
				color: $brand-text;
			}
		}

		&--light {
			.c-heading__ja {
				color: $brand-white;
			}
			.c-heading__en {
				color: $brand-white;
			}
			.c-heading__lead {
				color: $brand-white;
			}
		}
	}
</style>
