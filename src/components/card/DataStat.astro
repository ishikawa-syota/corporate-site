---
import ImagePlaceholder from '../common/ImagePlaceholder.astro';

interface Props {
	label: string;
	prefix?: string;
	value: string;
	unit: string;
	caption?: string;
	illust?: 'top' | 'left' | 'right';
	inline?: boolean;
	labelAfter?: boolean;
	figureFirst?: boolean;
	overlay?: boolean;
	illustW?: number;
	illustH?: number;
	illustLabel?: string;
	wide?: boolean;
}
const {
	label,
	prefix,
	value,
	unit,
	caption,
	illust = 'top',
	inline = false,
	labelAfter = false,
	figureFirst = false,
	overlay = false,
	illustW = 200,
	illustH = 120,
	illustLabel = 'illust',
	wide = false,
} = Astro.props;
---

<div
	class:list={[
		'c-datastat',
		`c-datastat--${illust}`,
		overlay && 'c-datastat--overlay',
		wide && 'c-datastat--wide',
	]}
>
	<div
		class="c-datastat__img"
		aria-hidden="true"
		style={`--illust-w:${illustW};--illust-h:${illustH}`}
	>
		<ImagePlaceholder label={illustLabel} rounded="8px" />
		{
			overlay && (
				<p class="c-datastat__figure c-datastat__figure--overlay">
					{prefix && <span class="c-datastat__prefix">{prefix}</span>}
					<span class="c-datastat__value">{value}</span>
					<span class="c-datastat__unit">{unit}</span>
				</p>
			)
		}
	</div>

	<div class="c-datastat__text">
		{
			inline ? (
				<p class="c-datastat__figure">
					{labelAfter ? (
						<>
							<span class="c-datastat__value">{value}</span>
							<span class="c-datastat__unit">{unit}</span>
							<span class="c-datastat__label c-datastat__label--inline">
								{label}
							</span>
						</>
					) : (
						<>
							<span class="c-datastat__label c-datastat__label--inline">
								{label}
							</span>
							{prefix && (
								<span class="c-datastat__prefix">{prefix}</span>
							)}
							<span class="c-datastat__value">{value}</span>
							<span class="c-datastat__unit">{unit}</span>
						</>
					)}
				</p>
			) : figureFirst ? (
				<>
					{!overlay && (
						<p class="c-datastat__figure">
							{prefix && (
								<span class="c-datastat__prefix">{prefix}</span>
							)}
							<span class="c-datastat__value">{value}</span>
							<span class="c-datastat__unit">{unit}</span>
						</p>
					)}
					<p class="c-datastat__label">{label}</p>
				</>
			) : (
				<>
					<p class="c-datastat__label">{label}</p>
					{!overlay && (
						<p class="c-datastat__figure">
							{prefix && (
								<span class="c-datastat__prefix">{prefix}</span>
							)}
							<span class="c-datastat__value">{value}</span>
							<span class="c-datastat__unit">{unit}</span>
						</p>
					)}
				</>
			)
		}
		{caption && <p class="c-datastat__caption">{caption}</p>}
	</div>
</div>

<style lang="scss">
	.c-datastat {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: size(12);
		min-height: size(374);
		height: 100%;
		padding: size(30) size(40);
		background: $brand-white;
		border-radius: size(7);

		@include mq('sp') {
			padding: size(40) size(30);
		}

		// SP: 横長カード（wide）は縦積みに切り替え、中央寄せ
		@include mq('sp') {
			&--wide.c-datastat--left,
			&--wide.c-datastat--right {
				flex-direction: column;
			}

			&--wide &__text {
				align-items: center;
			}

			&--wide .c-datastat__label,
			&--wide .c-datastat__caption {
				text-align: center;
			}
		}

		// --- 横並び（イラスト左/右） ---
		&--left,
		&--right {
			flex-direction: row;
			gap: size(48);

			@include mq('sp') {
				gap: size(30);
			}
		}

		&--right {
			flex-direction: row-reverse;
		}

		&__img {
			flex-shrink: 0;
			position: relative;
			width: calc(var(--illust-w) * var(--size-unit));
			height: calc(var(--illust-h) * var(--size-unit));
		}

		&__text {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: size(8);
		}

		// 横並びカードは text を左寄せ
		&--left &__text,
		&--right &__text {
			align-items: flex-start;
		}

		&__figure {
			display: flex;
			align-items: baseline;
			gap: size(4);

			// 数値をイラストに重ねる
			&--overlay {
				position: absolute;
				inset: 0;
				align-items: center;
				justify-content: center;
			}
		}

		&__value {
			font-family: $Font-Num;
			font-weight: 500;
			font-size: size(100);
			line-height: 1.2;
			background-image: $brand-gradient;
			background-clip: text;
			-webkit-text-fill-color: transparent;
			color: transparent;

			@include mq('sp') {
				font-size: size(110);
			}
		}

		&__prefix,
		&__unit {
			font-family: $Font;
			font-weight: 700;
			font-size: size(20);
			line-height: 1.4;
			letter-spacing: size(0.6);
			background-image: $brand-gradient;
			background-clip: text;
			-webkit-text-fill-color: transparent;
			color: transparent;

			@include mq('sp') {
				font-size: size(26);
			}
		}

		&__label {
			font-family: $Font;
			font-weight: 700;
			font-size: size(35);
			line-height: 1.4;
			letter-spacing: size(1.05);
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(40);
			}

			// 数値と同じ行に置くラベル
			&--inline {
				align-self: baseline;
				margin-inline: size(8);
				white-space: nowrap;
			}
		}

		&--left &__label,
		&--right &__label {
			text-align: left;
		}

		&__caption {
			font-family: $Font;
			font-weight: 400;
			font-size: size(20);
			line-height: 1.4;
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(24);
			}
		}

		&--left &__caption,
		&--right &__caption {
			text-align: left;
		}
	}
</style>
