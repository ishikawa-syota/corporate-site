---

<div class="p-data-stats">
	<CompanyScale id="data-company" />
	<StatSection id="data-home-visit" {...homeVisit} />
	<StatSection id="data-events" {...events} />
	<StatSection id="data-staff" {...staff} />
	<StatSection id="data-social" {...social} />
</div>

<style lang="scss">
	// 指標グループ全体の背景（淡いブルー）。上部を角丸にしてヒーロー(白)から切り替わる
	.p-data-stats {
		position: relative;
		background: linear-gradient(360deg, #dfefff 48.08%, #b8dbff 100%);
		border-radius: size($section-card-radius) size($section-card-radius) 0 0;
		padding-block: size(86) size(152);
		display: flex;
		flex-direction: column;
		gap: size(161);

		@include mq('sp') {
			padding-block: size(137) size(141);
		}
	}
</style>
