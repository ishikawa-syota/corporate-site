---
import { siteMetadata } from '../../data/meta';
import Footer from '../../layouts/Footer.astro';
import Header from '../../layouts/Header.astro';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../section/common/PageHero.astro';
import RelatedInfo from '../../section/common/RelatedInfo.astro';
import DataStats from '../../section/data/DataStats.astro';

const relatedCards = [
	{
		ja: '事業紹介',
		en: 'SERVICE',
		desc: 'サービスの詳細はこちら。',
		href: '/business',
	},
	{
		ja: '会社概要',
		en: 'ABOUT',
		desc: '会社の基本情報はこちら。',
		href: '#',
	},
	{
		ja: 'メンバー',
		en: 'MEMBERS',
		desc: 'この会社を動かす人たち。',
		href: '/members',
	},
];
---

<Layout title={`数字で見るケイタスプラン | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<PageHero
		id="data-hero"
		ja='数字で見る<br class="u-sp-only" />ケイタスプラン'
		en="DATA"
	/>
	<DataStats />
	<RelatedInfo id="data-related" cards={relatedCards} />
	<Footer id="footer" variant="subpage" />
</Layout>
