---
import ArrowButton from '../components/button/ArrowButton.astro';
import MemberCard from '../components/card/MemberCard.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import { members } from '../data/siteContent';
import memberA from '../images/keitasplan/member/member-01.png';
import memberB from '../images/keitasplan/member/member-03.png';

interface Props {
  id?: string;
}
const { id } = Astro.props;

// 2枚の写真を交互に使用（デザイン同様）
const memberImages = [memberA, memberB];
---

<section class="p-member" id={id}>
  <span class="p-member__watermark" aria-hidden="true">
    <svg viewBox="0 0 64 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="24" cy="20" rx="16" ry="15" stroke-width="4"></ellipse>
      <ellipse cx="40" cy="20" rx="16" ry="15" stroke-width="4"></ellipse>
    </svg>
  </span>
  <div class="p-member__inner">
    <SectionHeading
      ja="メンバー"
      en="MEMBERS"
      lead="買取のプロフェッショナルが丁寧に対応します"
      theme="light"
      class="p-member__heading"
    />
    <div class="p-member__grid">
      {members.map((m, i) => (
        <MemberCard role={m.role} name={m.name} img={memberImages[i % 2]} />
      ))}
    </div>
    <ArrowButton href="#member" label="詳しく見る" variant="white" class="p-member__btn" />
  </div>
</section>

<style lang="scss">
  @use '../styles/foundation/index' as *;

  .p-member {
    position: relative;
    overflow: hidden;
    // Figma: 濃紺グラデ背景（人物写真がくっきり映える）
    background: linear-gradient(180deg, $brand-blue 0%, #cfe6ff 100%);
    padding-block: size(100);

    @include mq('sp') {
      padding-block: size(80);
    }

    // 中央の大きな⊗透かしロゴ
    &__watermark {
      position: absolute;
      top: 50%;
      left: 50%;
      width: size(900);
      transform: translate(-50%, -55%);
      pointer-events: none;
      opacity: 0.08;

      svg {
        width: 100%;
        height: auto;
      }

      ellipse {
        fill: none;
        stroke: $brand-white;
      }
    }

    &__inner {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      max-width: size(1098);
      margin-inline: auto;
      padding-inline: size(24);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: size(40);
      width: 100%;
      margin-top: size(72);

      @include mq('sp') {
        grid-template-columns: repeat(2, 1fr);
        gap: size(24) size(20);
        margin-top: size(40);
      }
    }

    &__btn {
      margin-top: size(64);

      @include mq('sp') {
        margin-top: size(40);
      }
    }
  }
</style>
