---
import { siteMetadata } from '../../data/meta';
import relatedMembersPc from '../../images/keitasplan/common/related-members-pc.png';
import relatedMembersSp from '../../images/keitasplan/common/related-members-sp.png';
import Footer from '../../layouts/Footer.astro';
import Header from '../../layouts/Header.astro';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../section/common/PageHero.astro';
import RelatedInfo from '../../section/common/RelatedInfo.astro';
import President from '../../section/message/President.astro';
import Profile from '../../section/message/Profile.astro';

const relatedCards = [
	{
		ja: '会社概要',
		en: 'ABOUT',
		desc: '会社の基本情報はこちら。',
		href: '/#about',
	},
	{
		ja: 'メンバー',
		en: 'MEMBERS',
		desc: 'この会社を動かす人たち。',
		href: '/members',
		bgPc: relatedMembersPc,
		bgSp: relatedMembersSp,
	},
];
---

<Layout title={`代表メッセージ | ${siteMetadata.siteName}`}>
	<Header id="header" />
	<PageHero id="message-hero" ja="代表メッセージ" en="MESSAGE" spTitleLarge />
	<President />
	<Profile />
	<RelatedInfo id="message-related" cards={relatedCards} />
	<Footer id="footer" variant="subpage" />
</Layout>
