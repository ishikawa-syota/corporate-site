---
import { siteMetadata } from '../data/meta';
import fvCopyBg from '../images/keitasplan/fv/bg.png';
import Footer from '../layouts/Footer.astro';
import Header from '../layouts/Header.astro';
import Layout from '../layouts/Layout.astro';
import FirstView from '../section/01FV.astro';
import Copy from '../section/02Copy.astro';
import Business from '../section/03Business.astro';
import Data from '../section/04Data.astro';
import Member from '../section/05Member.astro';
import Voice from '../section/06Voice.astro';
import Message from '../section/07Message.astro';
import Faq from '../section/08Faq.astro';
import ContactCta from '../section/10ContactCta.astro';
import { processImages } from '../styles/images';

// FV〜Copy を1枚で覆う統合背景（--fvbg を生成）
const fvCopyStyles = await processImages({ fvbg: fvCopyBg });
---

<Layout title={siteMetadata.siteName}>
  <Header id="header" />
  <div class="l-fvCopy" style={fvCopyStyles}>
    <FirstView id="firstview" />
    <Copy id="copy" />
  </div>
  <Business id="business" />
  <Data id="data" />
  <Member id="member" />
  <Voice id="voice" />
  <Message id="message" />
  <Faq id="faq" />
  <ContactCta id="contact" />
  <Footer id="footer" />
</Layout>

<style>
  /* FV〜Copy 統合背景：1枚を全幅で上から敷き、画像下端色をフォールバックに */
  .l-fvCopy {
    position: relative;
    background-color: #75afeb; /* fv/bg.png 下端色（高さズレ時の隙間防止） */
    background-image: var(--fvbg);
    background-repeat: no-repeat;
    background-position: top center;
    /* 均一な縦グラデのため cover で全面カバー（SPは左右クロップ＝視覚上ほぼ無変化、縦は全域に伸びる） */
    background-size: cover;
  }
</style>
