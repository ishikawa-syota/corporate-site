---
// 矢印付きピルボタン（Figma: button1 / button1_s / button2 / button_saiyou）
// variant でサイズ・配色を切り替え、どこでも流用できる汎用ボタン
interface Props {
	href?: string;
	label: string;
	variant?: 'white' | 'blue';
	size?: 'md' | 'sm' | 'lg';
	class?: string;
}

const {
	href = '#',
	label,
	variant = 'white',
	size = 'md',
	class: className,
} = Astro.props;
---

<a
	href={href}
	class:list={[
		'c-arrowBtn',
		`c-arrowBtn--${variant}`,
		`c-arrowBtn--${size}`,
		className,
	]}
>
	<span class="c-arrowBtn__label">{label}</span>
	<span class="c-arrowBtn__icon" aria-hidden="true">
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="17"
			height="15"
			viewBox="0 0 17 15"
			fill="none"
		>
			<path
				d="M16.7071 8.07088C17.0976 7.68035 17.0976 7.04719 16.7071 6.65666L10.3431 0.292702C9.95262 -0.0978227 9.31946 -0.0978227 8.92893 0.292702C8.53841 0.683226 8.53841 1.31639 8.92893 1.70692L14.5858 7.36377L8.92893 13.0206C8.53841 13.4111 8.53841 14.0443 8.92893 14.4348C9.31946 14.8254 9.95262 14.8254 10.3431 14.4348L16.7071 8.07088ZM0 7.36377V8.36377H16V7.36377V6.36377H0V7.36377Z"
				fill="white"></path>
		</svg>
	</span>
</a>

<style lang="scss">
	@use '../../styles/foundation/index' as *;

	.c-arrowBtn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: size(15);
		width: size(220);
		height: size(60);
		padding: 0 size(24);
		border-radius: 999px;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			background-color 0.3s ease;

		&__label {
			@include ty-button;
			@include mq('sp') {
				font-size: size(20);
			}
		}

		&__icon {
			position: absolute;
			right: size(15);
			display: inline-flex;
			width: size(29);
			height: size(29);
			background-color: $brand-blue;
			border-radius: 50%;
			display: grid;
			place-items: center;

			svg {
				display: grid;
				place-items: center;
				width: size(17);
				height: size(15);
			}
		}

		// --- 配色バリアント ---
		&--white {
			background-color: $brand-white;
			box-shadow: 0 size(4) size(20) rgba($brand-blue, 0.12);

			.c-arrowBtn__label {
				color: $brand-text;
			}
			.c-arrowBtn__icon circle {
				fill: $brand-blue;
			}
			.c-arrowBtn__icon path {
				stroke: $brand-white;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					box-shadow: 0 size(8) size(24) rgba($brand-blue, 0.22);
				}
			}
		}

		&--blue {
			background-color: $brand-blue;

			.c-arrowBtn__label {
				color: $brand-white;
			}
			.c-arrowBtn__icon circle {
				fill: $brand-white;
			}
			.c-arrowBtn__icon path {
				stroke: $brand-blue;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover {
					transform: translateY(#{size(-2)});
					background-color: $brand-blue-light;
				}
			}
		}

		// --- サイズバリアント ---
		&--sm {
			width: size(197);
			height: size(50);

			.c-arrowBtn__icon {
				right: size(12);
			}
		}

		&--lg {
			width: size(301);
			height: size(60);
		}
	}
</style>
