---
import BlockHeading from '../../components/common/BlockHeading.astro';
import Picture from '../../components/common/Picture.astro';
import mapImgPc from '../../images/keitasplan/business/map-pc.png';
import mapImgSp from '../../images/keitasplan/business/map-sp.png';
import arrowCircle from '../../images/keitasplan/common/arrow-circle.svg';
import telIcon from '../../images/keitasplan/common/icon-tel.svg?raw';
---

<div class="p-biz-area">
	<BlockHeading text="対応エリア" />

	<div class="p-biz-area__body">
		<div class="p-biz-area__map">
			<Picture
				src={mapImgPc}
				srcSp={mapImgSp}
				alt="対応エリア地図（全国）"
			/>
		</div>
		<p class="p-biz-area__text">
			<span class="p-biz-area__textLead">北海道から沖縄まで</span>
			<span class="p-biz-area__textMain">
				<span class="p-biz-area__textBig">全国対応</span>しております。
			</span>
		</p>
	</div>

	<div class="p-biz-area__contact">
		<h3 class="p-biz-area__contactTitle">出張買取のお申込み・ご相談</h3>
		<div class="p-biz-area__actions">
			<a href="tel:0120210180" class="p-biz-area__tel">
				<span
					class="p-biz-area__telIcon"
					aria-hidden="true"
					set:html={telIcon}
				/>
				<span class="p-biz-area__telBody">
					<span class="p-biz-area__telNum">0120-210-180</span>
					<span class="p-biz-area__telHours">
						営業時間 9:00 - 19:00（年中無休）
					</span>
				</span>
			</a>
			<a href="#" class="p-biz-area__formBtn">
				<span class="p-biz-area__formLabel">
					メールでの<br />お申込み・ご相談
				</span>
				<span class="p-biz-area__formArrow" aria-hidden="true">
					<img src={arrowCircle.src} alt="" />
				</span>
			</a>
		</div>
	</div>
</div>

<style lang="scss">
	.p-biz-area {
		position: relative;
		margin-top: size(160);

		@include mq('sp') {
			margin-top: size(120);
		}

		&__body {
			display: flex;
			align-items: center;
			margin-top: size(28);

			@include mq('sp') {
				flex-direction: column;
				gap: size(20);
				margin-top: size(76);
			}
		}

		&__map {
			flex-shrink: 0;
			width: size(493);
			aspect-ratio: 493 / 400;
			border-radius: size(10);

			@include mq('sp') {
				width: 100%;
				aspect-ratio: 580 / 588;
			}
		}

		&__text {
			flex: 1;
			font-family: $Font;
			font-weight: 500;
			color: $brand-blue;
			text-align: center;
		}

		&__textLead {
			display: block;
			font-size: size(33);
			line-height: 1.7;

			@include mq('sp') {
				font-size: size(40);
			}
		}

		&__textMain {
			display: block;
			font-size: size(33);
			line-height: 1.7;

			@include mq('sp') {
				font-size: size(40);
			}
		}

		&__textBig {
			font-size: size(51);
			line-height: 1.5;

			@include mq('sp') {
				font-size: size(64);
			}
		}

		&__contact {
			margin-top: size(115);
			padding: size(46) size(51) size(76);
			background: linear-gradient(180deg, #fff 0%, #f9f9f9 100%);
			border-radius: size(20);
			box-shadow: 0 size(4) size(17) rgba(#000, 0.25);

			// SP: 内側コンテナ(580)より広い678でセクション中央に。左右-49で食み出す
			@include mq('sp') {
				width: size(678);
				margin-inline: size(-49);
				padding: size(50) size(40) size(60);
			}
		}

		&__contactTitle {
			font-family: $Font;
			font-weight: 500;
			font-size: size(33);
			line-height: 1.4;
			letter-spacing: size(3.3);
			color: $brand-text;
			text-align: center;

			@include mq('sp') {
				font-size: size(40);
				letter-spacing: normal;
			}
		}

		&__actions {
			display: flex;
			justify-content: center;
			gap: size(48);
			margin-top: size(36);

			@include mq('sp') {
				flex-direction: column;
				align-items: center;
				gap: size(30);
			}
		}

		&__tel {
			display: flex;
			align-items: center;
			gap: size(9);
			width: size(425);
			height: size(108);
			padding: 0 size(22);
			border-radius: size(150);
			background: linear-gradient(180deg, #e9e9e9 0%, #efefef 100%);

			@include mq('sp') {
				width: 100%;
				justify-content: center;
			}
		}

		&__telIcon {
			flex-shrink: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			width: size(64);
			height: size(64);
			border-radius: 50%;
			background: $brand-white;

			:global(svg) {
				display: block;
				width: size(34);
				height: size(38);
			}
		}

		&__telBody {
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		&__telNum {
			font-family: $Font-Sub;
			font-weight: 700;
			font-size: size(39);
			line-height: 1.4;
			letter-spacing: size(0.72);
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(48);
			}
		}

		&__telHours {
			font-family: $Font;
			font-weight: 400;
			font-size: size(12);
			line-height: 1.4;
			color: $brand-blue;

			@include mq('sp') {
				font-size: size(17);
			}
		}

		&__formBtn {
			position: relative;
			width: size(425);
			height: size(108);
			border-radius: size(150);
			background: linear-gradient(
				180deg,
				$brand-blue 0%,
				$brand-blue-pale 100%
			);
			transition: transform 0.3s ease;

			@include mq('sp') {
				width: 100%;
			}

			@media (hover: hover) and (pointer: fine) {
				&:hover .p-biz-area__formArrow {
					transform: translate(#{size(2)}, -50%);
				}
			}
		}

		&__formLabel {
			position: absolute;
			top: 50%;
			left: 20%;
			right: 29.18%;
			transform: translateY(-50%);
			font-family: $Font;
			font-weight: 500;
			font-size: size(27);
			line-height: 1.4;
			color: $brand-white;
			text-align: center;

			@include mq('sp') {
				font-size: size(30);
			}
		}

		&__formArrow {
			position: absolute;
			top: 50%;
			right: size(15);
			transform: translateY(-50%);
			width: size(58);
			height: size(58);
			transition: transform 0.3s ease;

			img {
				display: block;
				width: 100%;
				height: 100%;
			}
		}
	}
</style>
